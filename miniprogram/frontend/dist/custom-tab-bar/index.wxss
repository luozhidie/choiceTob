.custom-tab-bar{background:#fff;border-top:1rpx solid #f0f0f0;bottom:0;display:-webkit-flex;display:-ms-flexbox;display:flex;height:100rpx;left:0;padding-bottom:env(safe-area-inset-bottom);position:fixed;right:0;z-index:999}.tab-item{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex:1;-ms-flex:1;flex:1;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;justify-content:center;position:relative}.tab-icon{background-position:50%;background-repeat:no-repeat;background-size:contain;height:48rpx;margin-bottom:4rpx;width:48rpx}.tab-icon-home{background-image:url(data:image/png;base64,)}.tab-icon-home.active{background-image:url(data:image/png;base64,)}.tab-icon-courses{background-image:url(data:image/png;base64,)}.tab-icon-courses.active{background-image:url(data:image/png;base64,)}.tab-icon-news{background-image:url(data:image/png;base64,)}.tab-icon-news.active{background-image:url(data:image/png;base64,)}.tab-icon-category{background-image:url(data:image/png;base64,)}.tab-icon-category.active{background-image:url(data:image/png;base64,)}.tab-icon-hot{background-image:url(data:image/png;base64,)}.tab-icon-hot.active{background-image:url(data:image/png;base64,)}.tab-icon-vip{background-image:url(data:image/png;base64,)}.tab-icon-vip.active{background-image:url(data:image/png;base64,)}.tab-text{color:#999;font-size:20rpx}.tab-text.active{color:#2d1b2e;font-weight:600}