.page{background:#f5f5f5;min-height:100vh}.user-card{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-ms-flex-align:center;align-items:center;background:-webkit-linear-gradient(315deg,#1a56db,#4f8cff);background:linear-gradient(135deg,#1a56db,#4f8cff);color:#fff;padding:50rpx 30rpx}.user-avatar{-webkit-align-items:center;background:hsla(0,0%,100%,.2);border-radius:50%;display:-webkit-flex;display:-ms-flexbox;display:flex;height:100rpx;width:100rpx;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;color:#fff;font-size:40rpx;font-weight:600;justify-content:center}.user-info{margin-left:24rpx}.user-name{display:block;font-size:36rpx;font-weight:600}.user-role{display:block;font-size:24rpx;margin-top:4rpx;opacity:.7}.menu-card{padding:0}.menu-item{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-ms-flex-align:center;align-items:center;border-bottom:1rpx solid #f5f5f5;padding:30rpx 24rpx}.menu-icon{font-size:36rpx;margin-right:20rpx}.menu-label{color:#333;-webkit-flex:1;-ms-flex:1;flex:1;font-size:28rpx}.menu-arrow{color:#ccc;font-size:36rpx}.version{color:#ccc;font-size:22rpx;margin-top:60rpx;text-align:center}