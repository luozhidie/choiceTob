.category-page{background:#f5f5f5;display:-webkit-flex;display:-ms-flexbox;display:flex;height:100vh;overflow:hidden}.left-nav{background:#fff;-webkit-flex-shrink:0;height:100%;width:180rpx;-ms-flex-negative:0;border-right:1rpx solid #f0f0f0;flex-shrink:0}.nav-item{padding:28rpx 16rpx;position:relative;text-align:center;-webkit-transition:all .2s;transition:all .2s}.nav-item-active{background:#f5f5f5}.nav-item-active::before{background:#2d1b2e;border-radius:0 4rpx 4rpx 0;content:"";height:60%;left:0;position:absolute;top:20%;width:6rpx}.nav-text{color:#666;font-size:26rpx}.nav-text-active{color:#2d1b2e;font-weight:600}.right-content-wrap{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex:1;-ms-flex:1;flex:1;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;height:100%;overflow:hidden}.occasion-tags{background:#fff;-webkit-flex-shrink:0;padding:16rpx 12rpx;white-space:nowrap;-ms-flex-negative:0;border-bottom:1rpx solid #f0f0f0;flex-shrink:0}.tag-item{background:#f5f5f5;border:1rpx solid #eee;border-radius:32rpx;display:-webkit-inline-flex;display:-ms-inline-flexbox;display:inline-flex;margin-right:12rpx;padding:10rpx 24rpx}.tag-active{background:#2d1b2e;border-color:#2d1b2e}.tag-text{color:#666;font-size:24rpx;white-space:nowrap}.tag-text-active{color:#fff}.right-content{-webkit-flex:1;-ms-flex:1;flex:1;height:100%;overflow:hidden;padding:16rpx}.empty,.loading{color:#999;font-size:26rpx;padding:60rpx 0;text-align:center}.empty-text{color:#999;font-size:26rpx}.product-grid-3col{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-wrap:wrap;-ms-flex-wrap:wrap;flex-wrap:wrap;gap:12rpx}.product-card{background:#fff;border-radius:12rpx;margin-bottom:8rpx;overflow:hidden;width:calc(33.33% - 8rpx)}.product-img-wrap{background:#f8f8f8;overflow:hidden;padding-top:133%;position:relative;width:100%}.product-img{height:100%;left:0;position:absolute;top:0;width:100%}.product-img-blur{-webkit-filter:blur(8rpx);filter:blur(8rpx);opacity:.7}.product-img-placeholder{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;height:100%;left:0;position:absolute;top:0;width:100%;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;font-size:40rpx;justify-content:center}.product-lock-overlay{-webkit-align-items:center;background:rgba(0,0,0,.4);bottom:0;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;left:0;position:absolute;right:0;top:0;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;justify-content:center}.lock-icon{font-size:36rpx;margin-bottom:8rpx}.lock-text{color:#fff;font-size:20rpx;font-weight:600}.product-info{padding:8rpx 6rpx}.product-title{color:#333;display:-webkit-box;font-size:20rpx;-webkit-line-clamp:2;-webkit-box-orient:vertical;line-height:1.3;overflow:hidden}.product-price{color:#e64340;display:block;font-size:22rpx;font-weight:600;margin-top:4rpx}.product-price-locked{color:#999;display:block;font-size:20rpx;margin-top:4rpx}