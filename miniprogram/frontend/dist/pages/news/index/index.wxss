.news-page{background:#f5f5f5;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;height:100vh}.tab-bar{background:#fff;border-bottom:1rpx solid #eee;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-shrink:0;-ms-flex-negative:0;flex-shrink:0}.tab-item{color:#666;-webkit-flex:1;-ms-flex:1;flex:1;font-size:28rpx;padding:24rpx 0;position:relative;text-align:center}.tab-item.active{color:#2d1b2e;font-weight:600}.tab-item.active::after{background:#2d1b2e;border-radius:2rpx;bottom:0;content:"";height:4rpx;left:50%;position:absolute;-webkit-transform:translateX(-50%);-ms-transform:translateX(-50%);transform:translateX(-50%);width:48rpx}.content{-webkit-flex:1;-ms-flex:1;flex:1;height:0}.news-list{padding:16rpx 24rpx}.news-card{background:#fff;border-radius:12rpx;display:-webkit-flex;display:-ms-flexbox;display:flex;gap:20rpx;margin-bottom:16rpx;padding:24rpx}.news-card-img{-webkit-flex-shrink:0;-ms-flex-negative:0;flex-shrink:0}.img-placeholder{background:#e9ecef;border-radius:8rpx;height:120rpx;width:160rpx}.news-card-info{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex:1;-ms-flex:1;flex:1;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;-webkit-justify-content:center;-ms-flex-pack:center;justify-content:center}.news-category{background:#eff6ff;border-radius:4rpx;color:#2d1b2e;display:inline-block;font-size:20rpx;margin-bottom:12rpx;padding:4rpx 12rpx;width:-webkit-fit-content;width:-moz-fit-content;width:fit-content}.news-title{color:#1a1a1a;display:block;font-size:26rpx;font-weight:600;margin-bottom:12rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.news-date{color:#999;font-size:22rpx}