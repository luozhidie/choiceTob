.planning-page{background:#f5f5f5;min-height:100vh}.page-header{background:-webkit-linear-gradient(315deg,#2d1b2e,#0d47a1);background:linear-gradient(135deg,#2d1b2e,#0d47a1);padding:40rpx 32rpx}.page-title{color:#fff;display:block;font-size:36rpx;font-weight:700;margin-bottom:8rpx}.page-desc{color:hsla(0,0%,100%,.8);font-size:24rpx}.tool-section{padding:24rpx}.tool-card{background:#fff;border-radius:16rpx;margin-bottom:20rpx;padding:32rpx}.tool-title{color:#1a1a1a;display:block;font-size:30rpx;font-weight:700;margin-bottom:12rpx}.tool-desc{color:#666;font-size:24rpx}