.agent-recruit-page{background:#f9fafb;min-height:100vh}.hero{background:-webkit-linear-gradient(315deg,#2d1b2e,#4a1a4e);background:linear-gradient(135deg,#2d1b2e,#4a1a4e);min-height:380rpx;overflow:hidden;position:relative}.hero-overlay{background:rgba(0,0,0,.25);inset:0;position:absolute}.hero-content{color:#fff;padding:60rpx 40rpx 80prx;position:relative;z-index:2}.hero-badge{background:hsla(0,0%,100%,.12);border:1rpx solid rgba(244,114,182,.18);border-radius:40rpx;color:#f472b6;display:inline-block;font-size:22rpx;margin-bottom:16rpx;padding:10rpx 24rpx}.hero-title{display:block;font-size:48rpx;font-weight:700;margin-bottom:16rpx}.hero-desc{color:hsla(0,0%,100%,.82);display:block;font-size:28rpx}.section-header{margin-bottom:32rpx}.section-label{color:#f472b6;display:block;font-size:22rpx;font-weight:500;letter-spacing:2rpx;margin-bottom:8rpx;text-transform:uppercase}.section-title{color:#2d1b2e;display:block;font-size:36rpx;font-weight:700}.advantages-section{background:#fff;padding:48rpx 32rpx}.advantages-grid{display:grid;gap:20rpx;grid-template-columns:1fr 1fr}.advantage-card{background:#f9fafb;border-radius:20rpx;padding:32rpx 24rpx;text-align:center}.adv-icon{display:block;font-size:56rpx;margin-bottom:16rpx}.adv-title{color:#2d1b2e;display:block;font-size:28rpx;font-weight:600;margin-bottom:8rpx}.adv-desc{color:#6b7280;display:block;font-size:24rpx;line-height:1.5}.conditions-section{background:#f9fafb;padding:48rpx 32rpx}.conditions-list{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;gap:20rpx}.condition-item{-webkit-align-items:flex-start;display:-webkit-flex;display:-ms-flexbox;display:flex;-ms-flex-align:start;align-items:flex-start;background:#fff;border-radius:16rpx;gap:16rpx;padding:24rpx}.condition-check{-webkit-flex-shrink:0;font-size:32rpx;-ms-flex-negative:0;color:#22c55e;flex-shrink:0}.condition-text{color:#374151;font-size:28rpx;line-height:1.5}.form-section{background:#fff;padding:48rpx 32rpx 80rpx}.form-card{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;gap:24rpx}.form-item{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;gap:8rpx}.form-label{color:#374151;font-size:26rpx;font-weight:500}.form-input{background:#f9fafb;border:1rpx solid #e5e7eb;border-radius:12rpx;font-size:28rpx;height:80rpx;padding:0 24rpx}.form-picker{-webkit-align-items:center;background:#f9fafb;border:1rpx solid #e5e7eb;border-radius:12rpx;display:-webkit-flex;display:-ms-flexbox;display:flex;height:80rpx;padding:0 24rpx;-ms-flex-align:center;align-items:center;-webkit-justify-content:space-between;-ms-flex-pack:justify;justify-content:space-between}.picker-text{color:#374151;font-size:28rpx}.picker-arrow{color:#9ca3af;font-size:24rpx}.form-textarea{background:#f9fafb;border:1rpx solid #e5e7eb;border-radius:12rpx;font-size:28rpx;min-height:180rpx;padding:20rpx 24rpx}.form-submit{background:-webkit-linear-gradient(315deg,#c44569,#f472b6);background:linear-gradient(135deg,#c44569,#f472b6);border-radius:16rpx;margin-top:16rpx;padding:28rpx 0;text-align:center}.submit-text{color:#fff;font-size:30rpx;font-weight:600}