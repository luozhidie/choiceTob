.page{background:#f5f5f5;min-height:100vh;padding-bottom:120rpx}.tab-bar{background:#fff;border-bottom:1rpx solid #eee;display:-webkit-flex;display:-ms-flexbox;display:flex}.tab-item{-webkit-flex:1;-ms-flex:1;flex:1;padding:24rpx 0;position:relative;text-align:center}.tab-item.active .tab-text{color:#1a56db;font-weight:600}.tab-item.active::after{background:#1a56db;border-radius:2rpx;bottom:0;content:"";height:4rpx;left:30%;position:absolute;right:30%}.tab-text{color:#666;font-size:28rpx}.stats-row{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:space-around;-ms-flex-pack:distribute;justify-content:space-around}.stats-col{text-align:center}.stats-num{display:block;font-size:40rpx;font-weight:700}.stats-num.danger{color:#e74c3c}.stats-num.warning{color:#fa9d3b}.stats-label{color:#999;display:block;font-size:22rpx}.inventory-item{margin:0 20rpx 16rpx}.item-header{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:space-between;-ms-flex-pack:justify;-webkit-align-items:center;justify-content:space-between;-ms-flex-align:center;align-items:center}.item-sku{color:#999;font-size:22rpx}.item-status{border:1rpx solid;border-radius:8rpx;font-size:20rpx;padding:2rpx 12rpx}.item-name{color:#333;display:block;font-size:30rpx;font-weight:600;margin:8rpx 0}.item-footer{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:space-between;-ms-flex-pack:justify;justify-content:space-between}.item-sales,.item-stock{color:#666;font-size:24rpx}.hint{color:#999;display:block;font-size:26rpx;margin:40rpx 0;text-align:center}.btn-text{color:#fff;display:block;font-size:30rpx;line-height:88rpx;text-align:center}