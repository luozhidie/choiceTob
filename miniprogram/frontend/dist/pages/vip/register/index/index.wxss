.register-page{-webkit-align-items:center;background:#f5f5f5;display:-webkit-flex;display:-ms-flexbox;display:flex;min-height:100vh;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;justify-content:center;padding:0 40rpx}.register-card{background:#fff;border-radius:20rpx;padding:48rpx 36rpx;width:100%}.register-title{color:#2d1b2e;display:block;font-size:40rpx;font-weight:700;margin-bottom:8rpx;text-align:center}.register-subtitle{color:#666;display:block;font-size:26rpx;margin-bottom:48rpx;text-align:center}.form-item{margin-bottom:28rpx}.form-label{color:#333;display:block;font-size:26rpx;font-weight:500;margin-bottom:12rpx}.form-input{background:#f9fafb;border:2rpx solid #e5e7eb;border-radius:12rpx;font-size:28rpx;height:88rpx;padding:0 24rpx;width:100%}.submit-btn{background:#2d1b2e!important;border-radius:12rpx;color:#fff!important;font-size:30rpx!important;font-weight:600;height:88rpx;margin-top:16rpx;width:100%!important}.footer-link{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:center;-ms-flex-pack:center;color:#666;font-size:26rpx;gap:8rpx;justify-content:center;margin-top:32rpx}.link{color:#2d1b2e;font-weight:500}