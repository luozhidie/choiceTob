.profile-page{background:#f5f5f5;min-height:100vh}.loading{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;color:#999;font-size:28rpx;height:100vh;justify-content:center}.profile-header{-webkit-align-items:center;background:-webkit-linear-gradient(315deg,#2d1b2e,#0d47a1);background:linear-gradient(135deg,#2d1b2e,#0d47a1);display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;padding:60rpx 32rpx 48rpx;-ms-flex-align:center;align-items:center}.avatar{-webkit-align-items:center;background:hsla(0,0%,100%,.2);border-radius:50%;display:-webkit-flex;display:-ms-flexbox;display:flex;height:120rpx;width:120rpx;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;color:#fff;font-size:48rpx;font-weight:700;justify-content:center;margin-bottom:16rpx}.name{color:#fff;font-size:32rpx;font-weight:700;margin-bottom:8rpx}.phone{color:hsla(0,0%,100%,.8);font-size:24rpx}.menu-section{background:#fff;border-radius:16rpx;margin:16rpx 24rpx;overflow:hidden}.menu-item{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-ms-flex-align:center;align-items:center;-webkit-justify-content:space-between;-ms-flex-pack:justify;border-bottom:1rpx solid #f0f0f0;justify-content:space-between;padding:32rpx 28rpx}.menu-item:last-child{border-bottom:none}.menu-label{color:#333;font-size:28rpx}.menu-arrow{color:#ccc;font-size:28rpx}.logout-section{padding:32rpx 24rpx}.logout-btn{background:#fff;border-radius:16rpx;padding:28rpx 0;text-align:center}.logout-text{color:#ef4444;font-size:28rpx;font-weight:500}