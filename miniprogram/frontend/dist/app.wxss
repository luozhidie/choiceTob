page{background-color:#f5f5f5;color:#333;font-family:-apple-system,BlinkMacSystemFont,Helvetica Neue,Helvetica,PingFang SC,Microsoft YaHei,Arial,sans-serif;font-size:28rpx}.card{background:#fff;border-radius:16rpx;-webkit-box-shadow:0 2rpx 12rpx rgba(0,0,0,.04);box-shadow:0 2rpx 12rpx rgba(0,0,0,.04);margin:20rpx;padding:24rpx}.btn-primary{background:#1a56db;border-radius:44rpx;color:#fff;font-size:30rpx;font-weight:600;height:88rpx;line-height:88rpx;text-align:center}.btn-primary:active{opacity:.85}.stat-value{color:#333;font-size:44rpx;font-weight:700}.stat-label{color:#999;font-size:22rpx;margin-top:8rpx}