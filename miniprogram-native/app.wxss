/* ============================================================
   全局设计令牌 (Design Tokens)
   统一品牌色 / 间距 / 圆角 / 阴影 / 文字色
   各页面通过 var(--xxx) 引用，保证全站视觉一致
   ============================================================ */
page {
  /* 品牌色 */
  --brand: #2d1b2e;          /* 主品牌深紫（全站唯一强调色） */
  --brand-soft: #4a3a4b;
  --accent: #2d1b2e;         /* 强调=品牌深紫，价格/主按钮统一 */
  --accent-2: #4a3a4b;
  --warm: #ff7a3d;           /* 暖橙（辅助 CTA，如首页底部爆款区） */
  /* 中性色 */
  --bg: #00BE5A;             /* 页面底色：首页顶部绿色，全站统一 */
  --surface: #ffffff;        /* 卡片底 */
  --line: rgba(0,0,0,0.14);  /* 分割线：深色调，绿底/白卡上都清晰（原浅米色在绿底上几乎隐形） */
  --text: #1a1a2e;           /* 主文字 */
  --text-2: #666;            /* 次文字 */
  --text-3: #555;            /* 弱文字：加深，绿底上可读（原 #999 在绿底对比过低） */
  --text-4: #6e6e6e;         /* 最弱：加深，绿底上可读（原 #ccc 在绿底几乎隐形） */
  /* 间距 */
  --sp-xs: 8rpx;
  --sp-sm: 16rpx;
  --sp-md: 24rpx;
  --sp-lg: 32rpx;
  /* 圆角 */
  --r-sm: 12rpx;
  --r-md: 18rpx;
  --r-lg: 28rpx;
  --r-pill: 999rpx;
  /* 阴影 */
  --sh-1: 0 2rpx 10rpx rgba(0,0,0,.04);
  --sh-2: 0 6rpx 22rpx rgba(0,0,0,.06);
  --sh-3: 0 8rpx 30rpx rgba(45,27,46,.12);

  background: transparent !important;       /* 页面底色改为由 app.js 动态注入（= 后台「首页第一个板块」bgColor），故此处透明，让窗口底色透出；!important 中和各页写死的 page{background:var(--bg)} */
  color: var(--text);
  font-family: -apple-system,BlinkMacSystemFont,'Segoe UI','PingFang SC','Hiragino Sans GB',sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
}

/* 各页根容器原本写死 background:var(--bg)，此处统一置透明并加 !important，
   让 app.js 注入的窗口底色（后台可改的全局绿）透出，实现全站底色后台自调 */
.page { background: transparent !important; }

/* ===== 共享：卡片 ===== */
.card {
  background: var(--surface);
  border-radius: var(--r-md);
  overflow: hidden;
  box-shadow: var(--sh-1);
}

/* ===== 共享：主按钮 ===== */
.btn-primary {
  background: linear-gradient(135deg, var(--accent), var(--accent-2));
  color: #fff;
  font-weight: 600;
  border-radius: var(--r-sm);
  text-align: center;
}

/* ===== 共享：空状态 ===== */
.empty {
  text-align: center;
  padding: 100rpx 0;
}
.empty .ei {
  font-size: 84rpx;
  display: block;
  filter: grayscale(1);
  opacity: .25;
  margin-bottom: 14rpx;
}
.empty .et {
  font-size: 28rpx;
  color: var(--text-4);
  display: block;
  margin-bottom: 28rpx;
}
.empty .eb {
  display: inline-block;
  padding: 20rpx 44rpx;
  background: linear-gradient(135deg, var(--accent), var(--accent-2));
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  border-radius: var(--r-md);
  box-shadow: var(--sh-2);
}

/* ===== 共享：骨架屏 ===== */
.sk {
  background: var(--surface);
  border-radius: var(--r-md);
  overflow: hidden;
}
.sk-img { width: 100%; background: #f0ece8; }
.sk-l1 { height: 22rpx; background: #f0ece8; border-radius: 8rpx; }
.sk-l2 { height: 20rpx; background: #f0ece8; border-radius: 8rpx; }
@keyframes sk-pulse { 0% { opacity: 1 } 50% { opacity: .4 } 100% { opacity: 1 } }
.sk-img, .sk-l1, .sk-l2 { animation: sk-pulse 1.5s infinite; }

/* ===== 共享：分区标题 ===== */
.sec-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text);
}
.sec-sub { font-size: 23rpx; color: var(--text-4); }
