<view class="page">
  <!-- Hero -->
  <view class="hero">
    <text class="h-icon">👑</text>
    <text class="h-title">骆芷蝶 · VIP会员</text>
    <text class="h-desc">企划定品控方向，供应链稳货源</text>
  </view>

  <!-- 当前会员状态 -->
  <view class="status-card" wx:if="{{isMember}}">
    <view class="sc-left">
      <text class="sc-type">{{memberLabel}}</text>
      <text class="sc-exp">有效期至 {{expireDate}}</text>
    </view>
    <view class="sc-badge">✓ 已开通</view>
  </view>

  <!-- ═════ 过渡引导：选择你的升级方式 ══════ -->
  <view class="guide-section">
    <text class="guide-title">选择你的升级方式</text>
    <view class="guide-cards">
      <!-- 左：累计拿货（免费赛道） -->
      <view class="gc-card gc-free" bindtap="goBackMy">
        <view class="gc-icon"><text>免</text></view>
        <text class="gc-name">累计拿货升级</text>
        <text class="gc-sub">认证后拿货，累计自动升折扣</text>
        <view class="gc-features">
          <text class="gc-f">✓ 免费</text><text class="gc-f">✓ 批发价</text><text class="gc-f">✓ 2.8/2.6折</text>
          <text class="gc-f" style="color:#999;">— 无退换额度</text>
        </view>
        <view class="gc-btn gc-btn-sec">查看我的进度 →</view>
      </view>
      <!-- 右：直接充值（付费赛道） -->
      <view class="gc-card gc-pay" bindtap="scrollToDeposit">
        <view class="gc-icon"><text>充</text></view>
        <text class="gc-name">直接充值解锁</text>
        <text class="gc-sub">充值即同时享折扣+退换额度</text>
        <view class="gc-features">
          <text class="gc-f">✓ 退换额度</text><text class="gc-f">✓ 拿货折扣</text><text class="gc-f">✓ 优先发货</text>
        </view>
        <view class="gc-btn gc-btn-main">选套餐 ↓</view>
      </view>
    </view>
  </view>

  <!-- 拿货升级进度（锚点 id="deposit"） -->
  <view id="deposit" class="plans">
    <!-- 累计进度展示 -->
    <view class="upgrade-card" wx:if="{{purchaseAmount !== undefined}}">
      <view class="uc-header">
        <text class="uc-title">我的累计拿货进度</text>
        <text class="uc-amount">已拿货 ¥{{purchaseAmountLabel}}</text>
      </view>
      <view class="uc-progress-bar">
        <view class="uc-progress-fill" style="width:{{upgradeProgress}}%;"></view>
      </view>
      <view class="uc-levels">
        <text class="uc-level {{currentLevel>=0?'uc-level-active':''}}">普通</text>
        <text class="uc-level {{currentLevel>=1?'uc-level-active':''}}">5万</text>
        <text class="uc-level {{currentLevel>=2?'uc-level-active':''}}">10万</text>
        <text class="uc-level {{currentLevel>=3?'uc-level-active':''}}">30万</text>
      </view>
      <view class="uc-tip" wx:if="{{nextLevelLabel}}">
        再拿货 ¥{{nextLevelGapLabel}} 升级为 <text class="uc-next">{{nextLevelLabel}}</text>
      </view>
      <view class="uc-tip uc-tip-done" wx:if="{{!nextLevelLabel}}">
        已达最高等级 🎉
      </view>
    </view>

    <!-- 充值会员套餐 -->
    <view class="deposit-header"><text class="dh-title">充值会员套餐</text><text class="dh-sub">充值即得 折扣权 + 退换额度</text></view>

    <view class="plan-card {{item.highlight?'pc-hl':''}}" wx:for="{{depositPlans}}" wx:key="id">
      <view class="pc-tag" wx:if="{{item.highlight}}">推荐</view>
      <text class="pc-name">{{item.name}}</text>
      <text class="pc-price">{{item.priceLabel}}</text>
      <text class="pc-desc">{{item.discountLabel}}</text>
      <view class="pc-features">
        <text class="pc-f" wx:for="{{item.features}}" wx:key="*this" wx:for-item="feat">✓ {{feat}}</text>
      </view>
      <view class="pc-btn" bindtap="selectPlan" data-plan="{{item}}">立即充值</view>
    </view>
  </view>

  <!-- 支付弹窗 -->
  <view class="modal-mask" wx:if="{{showPay}}" bindtap="closePay">
    <view class="modal" catchtap="noop">
      <view class="modal-close" bindtap="closePay">✕</view>
      <text class="m-title">确认开通</text>
      <text class="m-name">{{selectedPlan.name}}</text>
      <text class="m-price">{{selectedPlan.priceLabel}}</text>
      <text class="m-tip">支付成功后即刻生效</text>
      <view class="m-btn" bindtap="confirmPay">微信支付</view>
    </view>
  </view>
</view>
