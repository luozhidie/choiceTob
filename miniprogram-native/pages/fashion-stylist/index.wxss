.page {
  min-height: 100vh;
  background: #f6f6f8;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.topbar {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  position: sticky;
  top: 0;
  background: #f6f6f8;
  z-index: 10;
}
.topbar .back {
  font-size: 32rpx;
  color: #2d1b2e;
  width: 120rpx;
}
.topbar .title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
  color: #2d1b2e;
  margin-right: 120rpx;
}

.svc-scroll {
  width: 100%;
  white-space: nowrap;
}
.svc-row {
  display: inline-flex;
  gap: 16rpx;
  padding: 8rpx 0;
}
.svc-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 120rpx;
  padding: 16rpx 20rpx;
  background: #fff;
  border-radius: 16rpx;
  border: 2rpx solid #eee;
}
.svc-item.active {
  background: #2d1b2e;
  border-color: #2d1b2e;
}
.svc-item.active .svc-label {
  color: #fff;
}
.svc-icon {
  font-size: 40rpx;
}
.svc-label {
  font-size: 22rpx;
  color: #555;
  margin-top: 6rpx;
}

.current {
  font-size: 24rpx;
  color: #888;
  margin: 20rpx 0 16rpx;
}
.current .cur-name {
  color: #2d1b2e;
  font-weight: 700;
}

.input-box {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}
.ta {
  width: 100%;
  min-height: 180rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
}
.btn-submit {
  margin-top: 20rpx;
  background: #2d1b2e;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 14rpx;
  padding: 18rpx 0;
}
.btn-submit.loading {
  opacity: 0.7;
}

.result-box {
  margin-top: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}
.result-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.result-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2d1b2e;
}
.copy {
  font-size: 24rpx;
  color: #C9A24B;
  border: 2rpx solid #C9A24B;
  border-radius: 20rpx;
  padding: 4rpx 20rpx;
}
.result-content {
  font-size: 28rpx;
  line-height: 1.7;
  color: #333;
  white-space: pre-wrap;
}

.history-box {
  margin-top: 24rpx;
}
.history-title {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 12rpx;
}
.history-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 12rpx;
}
.hi-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.hi-svc {
  font-size: 26rpx;
  font-weight: 600;
  color: #2d1b2e;
}
.hi-time {
  font-size: 22rpx;
  color: #bbb;
}
.hi-input {
  display: block;
  font-size: 24rpx;
  color: #888;
  margin-top: 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.bottom-space {
  height: 40rpx;
}
