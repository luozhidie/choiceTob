page { background: var(--bg); color: var(--text); }

.page { padding-bottom: 20rpx; }

/* 加载骨架 */
.loading { display: flex; flex-wrap: wrap; padding: 24rpx; gap: 16rpx; }
.sk { width: calc(50% - 8rpx); height: 460rpx; background: #f0ece8; border-radius: 18rpx; animation: sk-pulse 1.5s infinite; }

/* 顶部横幅 */
.hero { position: relative; width: 100%; height: 460rpx; overflow: hidden; background: linear-gradient(135deg, #2d1b2e, #6b3f70); }
.hero-img { width: 100%; height: 100%; display: block; }
.hero-ph { display: flex; }
.hero-mask { position: absolute; left: 0; right: 0; top: 0; bottom: 0; background: linear-gradient(to top, rgba(0,0,0,.7), rgba(0,0,0,.15) 55%, transparent); }
.hero-info { position: absolute; left: 0; right: 0; bottom: 0; padding: 32rpx; color: #fff; }
.hero-title { display: block; font-size: 40rpx; font-weight: 800; line-height: 1.35; }
.hero-sub { display: block; font-size: 24rpx; color: rgba(255,255,255,.85); margin-top: 10rpx; line-height: 1.45; }

/* 进度概览 */
.overview { background: #fff; margin: -28rpx 24rpx 0; border-radius: 20rpx; padding: 28rpx; position: relative; z-index: 2; box-shadow: var(--sh-2); }
.ov-row { display: flex; align-items: center; gap: 16rpx; }
.ov-label { font-size: 24rpx; color: var(--text-2); white-space: nowrap; }
.ov-bar { flex: 1; height: 14rpx; background: #f0ece8; border-radius: 999rpx; overflow: hidden; }
.ov-fill { height: 100%; background: var(--brand); border-radius: 999rpx; transition: width .4s; }
.ov-pct { font-size: 26rpx; font-weight: 700; color: var(--brand); }
.ov-count { display: block; font-size: 22rpx; color: var(--text-3); margin-top: 10rpx; }

/* 卖点 */
.points { display: flex; flex-wrap: wrap; gap: 12rpx; padding: 24rpx; }
.point { font-size: 22rpx; color: var(--brand); background: rgba(45,27,46,.06); border: 1rpx solid rgba(45,27,46,.12); padding: 10rpx 20rpx; border-radius: 999rpx; }

/* 品类 tab */
.tabs { background: #fff; margin: 0 24rpx; border-radius: 18rpx; padding: 8rpx 0; }
.tab-scroll { white-space: nowrap; }
.tab-row { display: inline-flex; gap: 12rpx; padding: 16rpx 20rpx; }
.tab { padding: 12rpx 24rpx; border-radius: 999rpx; font-size: 24rpx; color: var(--text-2); background: #f5f2ef; white-space: nowrap; }
.tab-on { color: #fff; background: var(--brand); font-weight: 700; }
.tab-badge { font-size: 18rpx; margin-left: 8rpx; opacity: .8; }

/* 商品网格 */
.grid { display: flex; flex-wrap: wrap; justify-content: space-between; padding: 20rpx 24rpx; }
.card { width: 47%; background: #fff; border-radius: 18rpx; overflow: hidden; margin-bottom: 20rpx; box-shadow: var(--sh-1); }
.ci { width: 100%; height: 320rpx; display: block; background: #eee; }
.ci-ph { display: flex; align-items: center; justify-content: center; color: #ccc; font-size: 22rpx; }
.cnf { padding: 16rpx 14rpx 18rpx; }
.cn { font-size: 24rpx; color: var(--text); font-weight: 500; line-height: 1.38; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.cpri { font-size: 28rpx; color: var(--brand); font-weight: 800; display: block; margin-top: 8rpx; }
.cwp { font-size: 20rpx; color: #4caf50; display: block; margin-top: 2rpx; }

.sb { height: 30rpx; }
