page{background: var(--bg);}
/* 标签 */
.tabs{display:flex;background:#fff;padding:0 20rpx;border-bottom:1rpx solid #eee;}
.tab{flex:1;text-align:center;padding:24rpx 0;font-size:26rpx;color:#888;position:relative;}
.tab-on{color:#2d1b2e;font-weight:700;}
.tab-on::after{content:'';position:absolute;bottom:0;left:50%;transform:translateX(-50%);width:60rpx;height:4rpx;background:#2d1b2e;border-radius:2rpx;}

/* 列表 */
.list{padding:20rpx;}
.c-card{display:flex;align-items:center;background:#fff;border-radius:16rpx;margin-bottom:16rpx;overflow:hidden;position:relative;}
.c-card-used{opacity:0.5;}
.cc-left{width:200rpx;background:linear-gradient(135deg,#2d1b2e,#ff6090);color:#fff;padding:28rpx 0;text-align:center;flex-shrink:0;}
.cc-amount{font-size:44rpx;font-weight:800;display:block;}
.cc-condition{font-size:20rpx;opacity:0.85;display:block;margin-top:4rpx;}
.cc-right{flex:1;padding:20rpx 16rpx;}
.cc-title{font-size:26rpx;font-weight:600;color:#333;display:block;margin-bottom:6rpx;}
.cc-desc{font-size:22rpx;color:#888;display:block;margin-bottom:4rpx;}
.cc-expire{font-size:20rpx;color:#bbb;display:block;}
.cc-btn{background:#2d1b2e;color:#fff;font-size:22rpx;padding:10rpx 24rpx;border-radius:20rpx;margin-right:16rpx;flex-shrink:0;}
.cc-status{font-size:22rpx;color:#ccc;margin-right:16rpx;flex-shrink:0;}
.cc-status-expire{color:#ccc;}

/* 空状态 */
.empty{text-align:center;padding:120rpx 0;color:#ccc;}
.empty-icon{font-size:80rpx;display:block;margin-bottom:20rpx;}
.empty-text{font-size:26rpx;}
.empty-btn{margin-top:30rpx;background:#2d1b2e;color:#fff;font-size:26rpx;padding:14rpx 56rpx;border-radius:40rpx;display:inline-block;}

/* loading */
.loading{text-align:center;padding:80rpx 0;}
.loading-spinner{width:48rpx;height:48rpx;border:3rpx solid #eee;border-top-color:#2d1b2e;border-radius:50%;display:inline-block;animation:spin 0.8s linear infinite;}
@keyframes spin{to{transform:rotate(360deg);}}
