page{background:#fff;}

/* Logo 区域 */
.logo-area{display:flex;flex-direction:column;align-items:center;padding:120rpx 40rpx 60rpx;}
.logo-box{
  width:140rpx;height:140rpx;border-radius:36rpx;
  background:linear-gradient(135deg,#ec4899,#db2777);
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  box-shadow:0 8rpx 30rpx rgba(236,72,153,.35);margin-bottom:28rpx;
}
.logo-icon{font-size:42rpx;color:#fff;font-weight:900;line-height:1.2;}
.logo-sub{font-size:18rpx;color:rgba(255,255,255,.85);font-weight:600;}
.logo-title{font-size:34rpx;font-weight:bold;color:#1a1a2e;margin-top:4rpx;}
.logo-en{font-size:20rpx;color:#999;margin-top:6rpx;letter-spacing:1rpx;}

/* 按钮区 */
.btn-area{padding:0 48rpx;display:flex;flex-direction:column;gap:24rpx;}

/* 手机号一键登录（粉色主按钮）*/
.btn-phone{
  width:100%;height:96rpx;border-radius:48rpx;background:linear-gradient(135deg,#ec4899,#e11d48);
  color:#fff;font-size:32rpx;font-weight:600;display:flex;align-items:center;justify-content:center;
  border:none;box-shadow:0 8rpx 28rpx rgba(236,72,153,.35);
  margin:0;padding:0;line-height:96rpx;
}
.btn-phone::after{display:none;}
.btn-phone:active{transform:scale(.98);opacity:.92;}
.btn-disabled{background:#f9a8d4!important;box-shadow:none!important;}

/* 其它方式登录 */
.btn-other{
  width:100%;height:96rpx;border-radius:48rpx;background:#fff;
  color:#ec4899;font-size:30rpx;font-weight:500;display:flex;align-items:center;justify-content:center;
  border:2rpx solid #ec4899;box-sizing:border-box;margin:0;padding:0;line-height:92rpx;
}
.btn-other::after{display:none;}
.btn-other:active{background:#fdf2f8;}

/* 协议勾选 */
.agree-row{display:flex;align-items:flex-start;gap:12rpx;padding:32rpx 56rpx 0;}
.checkbox{
  width:36rpx;height:36rpx;border-radius:6rpx;border:2rpx solid #ddd;
  display:flex;align-items:center;justify-content:center;shrink:0;margin-top:2rpx;
  background:#fff;
}
.checkbox.checked{background:#ec4899;border-color:#ec4899;}
.checkbox text{color:#fff;font-size:22rpx;font-weight:bold;}
.agree-text{font-size:23rpx;color:#999;line-height:1.5;flex:1;}
.link{color:#ec4899;font-weight:500;}

/* 底部提示 */
.footer-hint{text-align:center;padding:60rpx 40rpx 40rpx;}
.footer-hint text{font-size:21rpx;color:#ccc;}
