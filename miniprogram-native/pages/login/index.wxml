<view class="page">
  <!-- Logo 区域 -->
  <view class="logo-area">
    <view class="logo-box">
      <text class="logo-icon">一手</text>
      <text class="logo-sub">1件起批</text>
    </view>
    <text class="logo-title">骆芷蝶·智选｜供应链平台</text>
    <text class="logo-en">WOMEN CLOTHING WHOLESALE APP</text>
  </view>

  <!-- 登录按钮区 -->
  <view class="btn-area">
    <!-- 手机号一键登录（必须用 open-type=getPhoneNumber） -->
    <button
      class="btn-phone {{loading||!agreed?'btn-disabled':''}}"
      disabled="{{loading||!agreed}}"
      open-type="getPhoneNumber"
      bindgetphonenumber="onGetPhoneCode"
    >
      {{loading?'登录中...':'手机号一键登录'}}
    </button>

    <!-- 使用其它方式登录 -->
    <button class="btn-other" bindtap="goOtherLogin">使用其它方式登录</button>
  </view>

  <!-- 协议勾选 -->
  <view class="agree-row" bindtap="toggleAgree">
    <view class="checkbox {{agreed?'checked':''}}">
      <text wx:if="{{agreed}}">✓</text>
    </view>
    <text class="agree-text">
      阅读并同意
      <text class="link" catchtap="goAgreement">《一手用户服务协议》</text>
      和
      <text class="link" catchtap="goPrivacy">《隐私政策》</text>
    </text>
  </view>

  <!-- 底部提示 -->
  <view class="footer-hint">
    <text>登录即表示您已满18周岁并同意平台规则</text>
  </view>
</view>
