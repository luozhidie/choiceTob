<view class="page">
  <view class="hd">
    <text class="ht">欢迎回来</text>
    <text class="hs">请选择登录方式</text>
  </view>

  <!-- 会员登录 -->
  <view class="card">
    <text class="ct">会员登录</text>
    <text class="cs">登录后查看批发价、享受会员权益</text>

    <view class="fg">
      <text class="fl">邮箱地址</text>
    </view>
    <input class="inp" type="text" placeholder="请输入邮箱" value="{{email}}" bindinput="onEmail"/>

    <view class="fg">
      <text class="fl">登录密码</text>
      <text class="fr" bindtap="togglePw">忘记密码？</text>
    </view>
    <input class="inp" type="{{showPw?'text':'password'}}" placeholder="请输入密码" value="{{pw}}" bindinput="onPw"/>

    <view class="btn-login" bindtap="doLogin"><text>立即登录</text></view>

    <view class="reg-row">
      <text>还没有账号？</text><text class="reg-link" bindtap="goReg">去注册</text>
    </view>
  </view>

  <!-- 分割线 -->
  <view class="divider"><text>管理员入口</text></view>

  <!-- 管理员登录 -->
  <view class="card card-admin">
    <text class="ct ct-a"><text>🛡 </text>管理员登录</text>
    <text class="cs cs-a">仅限授权管理员访问管理后台</text>

    <view class="fg fg-a">
      <text class="fl fl-a">管理员邮箱</text>
    </view>
    <input class="inp inp-a" type="text" placeholder="请输入管理员邮箱" value="{{adminEmail}}" bindinput="onAdminEmail"/>

    <view class="fg fg-a">
      <text class="fl fl-a">管理员密码</text>
    </view>
    <input class="inp inp-a" type="password" placeholder="请输入密码" value="{{adminPw}}" bindinput="onAdminPw"/>

    <view class="btn-admin" bindtap="doAdminLogin"><text>管理员登录</text></view>
  </view>

  <view class="back-home" bindtap="goHome"><text>← 返回首页</text></view>
</view>
