page{background:#f8f6f4;}

/* Hero */
.hero{background:linear-gradient(160deg,#2d1b2e,#4a3a5a);padding:44rpx 28rpx 36rpx;}
.hdate{font-size:24rpx;color:rgba(255,255,255,.7);background:rgba(255,255,255,.12);display:inline-block;padding:6rpx 20rpx;border-radius:20rpx;margin-bottom:16rpx;}
.htitle{font-size:40rpx;font-weight:bold;color:#fff;display:block;letter-spacing:3rpx;}
.hsub{font-size:25rpx;color:rgba(255,255,255,.75);display:block;margin-top:8rpx;}

/* VIP条 */
.vip-bar{display:flex;align-items:center;justify-content:space-between;padding:16rpx 24rpx;background:#fff0f5;border-bottom:1rpx solid #fce4ec;}
.vb-left{font-size:24rpx;color:#4a3a4b;font-weight:600;}
.vb-btns{display:flex;gap:10rpx;}
.vbm{font-size:21rpx;color:#fff;background:#2d1b2e;padding:6rpx 18rpx;border-radius:14rpx;font-weight:700;}
.vby{font-size:21rpx;color:#2d1b2e;background:#fce4ec;padding:6rpx 18rpx;border-radius:14rpx;font-weight:700;}

/* 分类Tab */
.cats{padding:16rpx 20rpx;white-space:nowrap;background:#fff;display:flex;gap:12rpx;border-bottom:1rpx solid #f0ece8;}
.cat{flex-shrink:0;padding:12rpx 30rpx;border-radius:30rpx;font-size:25rpx;color:#666;background:#f5f2ef;}
.cat-on{background:#2d1b2e;color:#fff;font-weight:600;}

/* 网格 */
.grid{display:flex;flex-wrap:wrap;padding:16rpx 14rpx;gap:14rpx;}
.lcard{
  width:calc(50% - 7rpx);
  background:#fff;
  border-radius:22rpx;
  overflow:hidden;
  box-shadow:0 2rpx 12rpx rgba(0,0,0,.04);
  position:relative;
}
.lcard-locked{opacity:.85;}

.lock-icn{position:absolute;top:12rpx;right:12rpx;width:48rpx;height:48rpx;background:rgba(233,33,99,.9);border-radius:50%;display:flex;align-items:center;justify-content:center;z-index:2;}
.lock-icn text{font-size:24rpx;color:#fff;}

/* 搭配图区 */
.pic{position:relative;width:100%;height:300rpx;background:#faf8f6;overflow:hidden;}
.pimg{width:100%;height:300rpx;display:block;}
.pblur{filter:blur(8rpx);transform:scale(1.08);}
.pfallback{height:300rpx;display:flex;align-items:center;justify-content:center;gap:20rpx;padding:20rpx;}
.ccircle{width:64rpx;height:64rpx;border-radius:50%;box-shadow:0 3rpx 10rpx rgba(0,0,0,.15);}
/* 水印 */
.wm{position:absolute;top:14rpx;left:14rpx;font-size:20rpx;color:rgba(255,255,255,.9);background:rgba(45,27,46,.45);padding:4rpx 14rpx;border-radius:10rpx;}
/* 锁定遮罩 */
.plock{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,.28);}
.plt{font-size:24rpx;color:#fff;font-weight:bold;text-shadow:0 2rpx 6rpx rgba(0,0,0,.4);}

/* 信息区 */
.linfo{padding:18rpx 18rpx 22rpx;}
.ltag{font-size:20rpx;color:#2d1b2e;background:#fce4ec;padding:3rpx 14rpx;border-radius:12rpx;display:inline-block;margin-bottom:8rpx;}
.lname{font-size:28rpx;font-weight:bold;color:#333;display:block;margin-bottom:6rpx;}
.ldesc{font-size:23rpx;color:#888;line-height:1.4;display:block;margin-bottom:12rpx;}
.cdots{display:flex;gap:10rpx;}
.cdot{width:22rpx;height:22rpx;border-radius:50%;}

/* 空/加载 */
.emp{text-align:center;padding:120rpx 0;}
.ei{font-size:80rpx;display:block;color:#ddd;}
.et{font-size:27rpx;color:#ccc;display:block;margin-top:12rpx;}
.ld{text-align:center;padding:80rpx 0;color:#999;font-size:26rpx;}
.sbtm{height:30rpx;}
