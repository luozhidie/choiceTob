page { background: #faf8f6; }

/* Hero */
.hero { background: linear-gradient(135deg, #2d1b2e, #4a3a4b); padding: 64rpx 32rpx 80rpx; text-align: center; }
.h-inner { display: flex; flex-direction: column; align-items: center; }
.h-icon { font-size: 72rpx; margin-bottom: 16rpx; }
.h-title { display: block; font-size: 38rpx; font-weight: 900; color: #fff; margin-bottom: 12rpx; }
.h-desc { display: block; font-size: 26rpx; color: rgba(255,255,255,0.7); }

/* VIP提示 */
.vip-tip { margin: 32rpx 24rpx 0; background: #fff; border-radius: 20rpx; padding: 32rpx; text-align: center; box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.06); }
.vt-text { display: block; font-size: 26rpx; color: #666; margin-bottom: 24rpx; }
.vt-btn { display: inline-block; padding: 18rpx 48rpx; background: linear-gradient(135deg, #2d1b2e, #4a3a4b); color: #fff; font-size: 26rpx; font-weight: 700; border-radius: 28rpx; }

/* 列表 */
.list { padding: 16rpx 24rpx; }
.look-card { background: #fff; border-radius: 20rpx; overflow: hidden; margin-bottom: 24rpx; }
.lc-images { display: flex; gap: 4rpx; padding: 4rpx; }
.lc-img { flex: 1; height: 320rpx; border-radius: 12rpx; background: #f5f3f1; }
.lc-info { padding: 20rpx 24rpx; }
.lc-title { display: block; font-size: 28rpx; font-weight: 700; color: #1a1a2e; margin-bottom: 8rpx; }
.lc-desc { display: block; font-size: 24rpx; color: #888; line-height: 1.6; margin-bottom: 16rpx; }
.lc-tags { display: flex; flex-wrap: wrap; gap: 12rpx; }
.lc-tag { padding: 8rpx 20rpx; background: #f5f3f1; border-radius: 16rpx; font-size: 22rpx; color: #666; }

/* 空状态 */
.empty { text-align: center; padding: 120rpx 0; }
.ec { display: block; font-size: 80rpx; margin-bottom: 20rpx; }
.et { display: block; font-size: 28rpx; color: #ccc; margin-bottom: 32rpx; }
.eb { display: inline-block; padding: 18rpx 44rpx; background: linear-gradient(135deg, #2d1b2e, #4a3a4b); color: #fff; font-size: 26rpx; font-weight: 700; border-radius: 28rpx; }
