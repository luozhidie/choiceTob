.page{background:#f5f3f0;min-height:100vh;padding:24rpx;box-sizing:border-box;padding-bottom:160rpx;}

.c-head{display:flex;align-items:center;gap:20rpx;background:#fff;border-radius:20rpx;padding:24rpx;margin-bottom:20rpx;}
.c-avatar{width:96rpx;height:96rpx;border-radius:50%;background:#f0ede9;display:flex;align-items:center;justify-content:center;font-size:44rpx;}
.c-info{flex:1;}
.c-name{font-size:32rpx;font-weight:600;color:#2d1b2e;display:block;}
.c-sub{font-size:24rpx;color:#999;margin-top:6rpx;display:block;}

.row{display:flex;align-items:center;justify-content:space-between;background:#fff;border-radius:16rpx;padding:26rpx 24rpx;margin-bottom:16rpx;}
.rl{font-size:28rpx;color:#666;}
.rv{font-size:28rpx;color:#333;max-width:60%;text-align:right;}
.ri{flex:1;text-align:right;font-size:28rpx;color:#333;}

.block{background:#fff;border-radius:16rpx;padding:26rpx 24rpx;margin-bottom:16rpx;}
.bl{font-size:28rpx;color:#666;display:block;margin-bottom:20rpx;}
.slot-grid{display:flex;flex-wrap:wrap;gap:16rpx;}
.slot{width:200rpx;height:80rpx;background:#f5f3f0;border-radius:12rpx;display:flex;align-items:center;justify-content:center;font-size:28rpx;color:#333;}
.slot.sel{background:#2d1b2e;color:#fff;font-weight:600;}
.slot.rest{background:#f0f0f0;color:#ccc;text-decoration:line-through;}
.sel-tip{font-size:24rpx;color:#C9A24B;margin-top:16rpx;display:block;}

.footer{position:fixed;left:0;right:0;bottom:0;background:#fff;display:flex;align-items:center;justify-content:space-between;padding:24rpx 32rpx;box-shadow:0 -2rpx 10rpx rgba(0,0,0,.06);padding-bottom:calc(24rpx + env(safe-area-inset-bottom));}
.total{font-size:28rpx;color:#666;}
.t-num{font-size:36rpx;font-weight:bold;color:#C9A24B;}
.submit-btn{background:#000;color:#fff;padding:22rpx 64rpx;border-radius:40rpx;font-size:30rpx;font-weight:600;}
