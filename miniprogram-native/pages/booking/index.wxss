.page{background:#f5f3f0;min-height:100vh;padding:24rpx;box-sizing:border-box;padding-bottom:160rpx;}

/* 日期 */
.date-bar{white-space:nowrap;margin-bottom:24rpx;}
.date-item{display:inline-flex;flex-direction:column;align-items:center;justify-content:center;width:120rpx;height:130rpx;background:#fff;border-radius:20rpx;margin-right:16rpx;box-shadow:0 2rpx 8rpx rgba(0,0,0,.04);}
.date-item.on{background:#2d1b2e;}
.date-item.on .dw,.date-item.on .dm{color:#fff;}
.dw{font-size:24rpx;color:#888;}
.dm{font-size:30rpx;font-weight:600;color:#333;margin-top:6rpx;}

/* 营销方案 */
.plans{margin-bottom:24rpx;}
.plans-title{font-size:28rpx;font-weight:600;color:#2d1b2e;margin-bottom:16rpx;}
.plan-scroll{white-space:nowrap;}
.plan-card{display:inline-flex;flex-direction:column;width:220rpx;background:#fff;border-radius:20rpx;margin-right:16rpx;padding:16rpx;box-shadow:0 2rpx 8rpx rgba(0,0,0,.04);vertical-align:top;}
.plan-img{width:100%;height:160rpx;border-radius:12rpx;background:#eee;}
.plan-img.ph{display:flex;align-items:center;justify-content:center;font-size:60rpx;background:#f0ede9;}
.plan-name{font-size:24rpx;color:#333;margin-top:12rpx;display:block;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.plan-price{font-size:24rpx;color:#C9A24B;font-weight:600;}

/* 顾问列表 */
.list{display:flex;flex-direction:column;gap:20rpx;}
.c-card{background:#fff;border-radius:20rpx;padding:24rpx;box-shadow:0 2rpx 10rpx rgba(0,0,0,.04);}
.c-head{display:flex;align-items:flex-start;gap:20rpx;}
.c-avatar{width:110rpx;height:110rpx;border-radius:50%;background:#eee;flex-shrink:0;}
.c-avatar.ph{display:flex;align-items:center;justify-content:center;font-size:48rpx;background:#f0ede9;}
.c-info{flex:1;}
.c-name{font-size:32rpx;font-weight:600;color:#2d1b2e;display:block;}
.c-title{font-size:22rpx;color:#999;font-weight:400;margin-left:12rpx;}
.c-desc{font-size:24rpx;color:#777;margin-top:8rpx;display:block;line-height:1.5;}
.c-actions{display:flex;flex-direction:column;gap:10rpx;}
.act-btn{font-size:22rpx;padding:8rpx 18rpx;border-radius:30rpx;border:none;margin:0;line-height:1;}
.act-btn::after{border:none;}
.act-btn.follow{background:#2d1b2e;color:#fff;}
.act-btn.follow.on{background:#ddd;color:#666;}
.act-btn.share{background:#4caf50;color:#fff;}

.week-list{margin-top:20rpx;}
.week-row{display:flex;align-items:center;justify-content:space-between;padding:18rpx 0;border-bottom:1rpx solid #f5f3f0;}
.wr-date{font-size:28rpx;color:#333;}
.wr-remain{font-size:26rpx;color:#C9A24B;}
.wr-arrow{font-size:34rpx;color:#ccc;}
.view-all{text-align:center;padding:16rpx 0;font-size:26rpx;color:#999;}

.empty{padding:80rpx 40rpx;text-align:center;color:#999;font-size:26rpx;}

/* 我的预约 */
.my-bar{position:fixed;left:24rpx;right:24rpx;bottom:40rpx;background:#000;color:#fff;display:flex;align-items:center;justify-content:space-between;padding:28rpx 36rpx;border-radius:40rpx;font-size:30rpx;font-weight:600;box-shadow:0 8rpx 24rpx rgba(0,0,0,.3);}
.mb-arrow{font-size:36rpx;}
