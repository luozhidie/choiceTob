.page{padding:24rpx;background:#f5f3f0;min-height:100vh;box-sizing:border-box;padding-bottom:160rpx;}

.tip-card{background:linear-gradient(135deg,#2d1b2e,#3d243e);border-radius:16rpx;padding:28rpx 24rpx;margin-bottom:24rpx;}
.tc-txt{font-size:26rpx;color:#fff;line-height:1.6;}

.form{background:#fff;border-radius:16rpx;padding:8rpx 24rpx;}
.fi{display:flex;align-items:flex-start;padding:28rpx 0;border-bottom:1rpx solid #f0ede9;}
.fi:last-of-type{border-bottom:none;}
.fl{width:180rpx;font-size:28rpx;color:#333;flex-shrink:0;padding-top:6rpx;}
.req{color:#e11d48;}
.fin{flex:1;font-size:28rpx;color:#333;}
.fin.static{color:#666;}
.fta{flex:1;font-size:28rpx;color:#333;height:160rpx;}

.submit-btn{background:#000;color:#fff;text-align:center;padding:26rpx 0;border-radius:40rpx;font-size:32rpx;font-weight:600;margin-top:40rpx;}
