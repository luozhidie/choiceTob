.page{background:#f5f3f0;min-height:100vh;padding:24rpx;box-sizing:border-box;padding-bottom:40rpx;}

.tabs{display:flex;gap:12rpx;margin-bottom:24rpx;flex-wrap:wrap;}
.tab{font-size:24rpx;padding:12rpx 24rpx;border-radius:30rpx;background:#fff;color:#666;}
.tab.on{background:#2d1b2e;color:#fff;font-weight:600;}

.list{display:flex;flex-direction:column;gap:20rpx;}
.b-card{background:#fff;border-radius:16rpx;padding:24rpx;box-shadow:0 2rpx 10rpx rgba(0,0,0,.04);}
.b-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:14rpx;}
.b-name{font-size:30rpx;font-weight:600;color:#2d1b2e;}
.b-status{font-size:24rpx;color:#C9A24B;}
.b-meta{font-size:24rpx;color:#777;display:block;margin-top:6rpx;}
.b-total{font-size:28rpx;color:#C9A24B;font-weight:600;margin-top:14rpx;display:block;}
.b-cancel{margin-top:16rpx;align-self:flex-end;font-size:24rpx;color:#999;padding:10rpx 28rpx;border:1rpx solid #ddd;border-radius:30rpx;float:right;}

.empty{padding:100rpx 40rpx;text-align:center;color:#999;font-size:26rpx;}
