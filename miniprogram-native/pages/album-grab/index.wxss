page {
  padding: 24rpx;
  background: #f5f3f0;
  min-height: 100vh;
}

.head {
  margin-bottom: 24rpx;
}
.ht {
  display: block;
  font-size: 36rpx;
  font-weight: 800;
  color: #1a1a2e;
}
.hs {
  display: block;
  font-size: 24rpx;
  color: #888;
  margin-top: 8rpx;
  line-height: 1.5;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}
.ct {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 16rpx;
}

.ta {
  width: 100%;
  box-sizing: border-box;
  padding: 16rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: 12rpx;
  font-size: 24rpx;
  min-height: 120rpx;
  margin-bottom: 16rpx;
}
.row {
  display: flex;
  gap: 16rpx;
}
.btn-ghost {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border: 1rpx solid #2d1b2e;
  color: #2d1b2e;
  border-radius: 12rpx;
  font-size: 26rpx;
}

.step {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f5f2ef;
}
.step:last-of-type {
  border-bottom: none;
}
.sn {
  flex-shrink: 0;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #2d1b2e, #4a3a4b);
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  text-align: center;
  line-height: 44rpx;
}
.sb {
  flex: 1;
}
.st {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
}
.sd {
  display: block;
  font-size: 23rpx;
  color: #888;
  margin-top: 6rpx;
  line-height: 1.6;
}

.btn-copy {
  margin-top: 20rpx;
  background: linear-gradient(135deg, #2d1b2e, #4a3a4b);
  color: #fff;
  text-align: center;
  padding: 22rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
}
.tool-url {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #aaa;
  margin-top: 12rpx;
  word-break: break-all;
}

.note {
  font-size: 22rpx;
  color: #999;
  line-height: 1.6;
  padding: 0 8rpx;
}
