<view class="page" style="{{pageBgStyle}}">
  <!-- 搜索栏（始终显示） -->
  <view class="search-bar">
    <text class="si">🔍</text>
    <input class="sinput" placeholder="搜索商品或品牌..." value="{{keyword}}" bindinput="onSearchInput" confirm-type="search" bindconfirm="doSearch" />
    <text class="sclr" wx:if="{{keyword}}" bindtap="clearSearch">✕</text>
  </view>

  <!-- ========== 分类视图 ========== -->
  <view class="cat-page" wx:if="{{viewMode==='category'}}">
    <scroll-view class="cat-sidebar" scroll-y>
      <view wx:for="{{mainCategories}}" wx:key="id"
        class="cat-side-item {{activeMainId===item.id?'active':''}}"
        bindtap="selectMainCat" data-id="{{item.id}}">
        <text>{{item.name}}</text>
      </view>
    </scroll-view>

    <scroll-view class="cat-content" scroll-y scroll-into-view="{{activeMainId}}" scroll-with-animation>
      <block wx:for="{{mainCategories}}" wx:key="id" wx:for-item="main">
        <view id="{{main.id}}" class="cat-section">
          <view class="cat-section-title">{{categoryTree[main.id].title}}</view>

          <view wx:if="{{categoryTree[main.id].type==='market'}}">
            <view wx:for="{{categoryTree[main.id].items}}" wx:key="name" wx:for-item="it"
              class="market-card" style="{{it.ps}}" bindtap="enterCategory" data-name="{{it.name}}">
              <view class="market-body">
                <text class="market-title">{{it.name}}</text>
                <text class="market-desc">{{it.desc}}</text>
              </view>
            </view>
          </view>

          <view wx:else class="cat-grid">
            <view wx:for="{{categoryTree[main.id].items}}" wx:key="name" wx:for-item="it"
              class="cat-tile" bindtap="enterCategory" data-name="{{it.name}}">
              <view class="cat-tile-img">
                <view class="cat-ph" style="{{it.ps}}"><text>{{it.name}}</text></view>
              </view>
              <text class="cat-tile-name">{{it.name}}</text>
            </view>
          </view>
        </view>
      </block>
      <view class="cat-bottom"></view>
    </scroll-view>
  </view>

  <!-- ========== 商品列表视图 ========== -->
  <scroll-view class="list-scroll" scroll-y wx:else bindscrolltolower="onListScrollLower">
    <!-- 返回 + 标题 -->
    <view class="list-header">
      <text class="back-btn" bindtap="backToCategory">‹ 分类</text>
      <text class="list-title">{{activeTab}}</text>
      <text class="list-spacer"></text>
    </view>

    <!-- 第一行：排序 -->
    <view class="sort-bar">
      <block wx:for="{{filterConfig.sorts}}" wx:key="key">
        <text class="st {{sortType===item.key?'st-on':''}}" bindtap="setSort" data-sort="{{item.key}}">
          {{item.label}}{{sortType==='price_asc'&&item.key==='price_asc'?'↑':''}}{{sortType==='price_desc'&&item.key==='price_asc'?'↓':''}}
        </text>
      </block>
      <text class="st {{filterOpen?'st-on':''}} filter-trigger" bindtap="openFilter">筛选 ▽</text>
    </view>

    <!-- 第二行：快捷筛选 -->
    <view class="quick-bar">
      <block wx:for="{{filterConfig.quickFilters}}" wx:key="key">
        <view class="quick-item {{selectedFilters[item.key]&&selectedFilters[item.key].length?'quick-on':''}} {{quickPopup===item.key?'quick-active':''}}"
          bindtap="toggleQuick" data-key="{{item.key}}" data-type="{{item.type}}">
          <text wx:if="{{item.type==='toggle'&&selectedFilters[item.key]&&selectedFilters[item.key].length}}">✓ </text>
          <text>{{item.label}}</text>
          <text wx:if="{{item.type==='popup'}}"> ▼</text>
        </view>
      </block>
    </view>

    <!-- 第三行：品类货品面料分类 -->
    <scroll-view wx:if="{{filterConfig.subCategories.length}}" class="subcat-scroll" scroll-x show-scrollbar="{{false}}">
      <view class="subcat-row">
        <view wx:for="{{filterConfig.subCategories}}" wx:key="*this" class="subcat-chip"
          bindtap="switchSubCategory" data-name="{{item}}">{{item}}</view>
      </view>
    </scroll-view>

    <!-- 认证店主入口 -->
    <view class="cert-banner" wx:if="{{!isPriceMember}}" bindtap="goCertify">
      <text class="cb-icon">🛡️</text>
      <view class="cb-body">
        <text class="cb-title">认证店主，免费看批发价</text>
        <text class="cb-desc">通过行业知识答题即可解锁</text>
      </view>
      <text class="cb-btn">去认证 →</text>
    </view>

    <!-- 商品数 -->
    <view class="count-bar"><text>共{{products.length}}件</text></view>

    <!-- 加载骨架 -->
    <view class="grid" wx:if="{{loading && products.length===0}}">
      <view wx:for="{{[1,2,3,4,5,6]}}" wx:key="*this" class="sk"><view class="ski"></view><view class="skl1"></view><view class="skl2"></view></view>
    </view>

    <block wx:else>
      <view class="empty" wx:if="{{!loading && products.length===0}}">
        <text class="ei">📦</text><text class="et">该分类暂无商品</text>
        <view class="eb" bindtap="backToCategory">返回分类 →</view>
      </view>

      <view class="grid" wx:else>
        <view wx:for="{{products}}" wx:key="id" class="card" bindtap="goShop" data-id="{{item.id}}">
          <image src="{{item.image_url||item.cover_image||''}}" mode="aspectFill" class="ci" lazy-load/>
          <view wx:if="{{!item.image_url&&!item.cover_image}}" class="cp"><text>暂无图</text></view>
          <text class="cn">{{item.name||item.title||'商品'}}</text>
          <text class="cpri">{{item.priceText}}</text>
          <text class="cwpri" wx:if="{{item.wholesalePriceText}}">批发价 {{item.wholesalePriceText}}</text>
          <view class="cbtn" catchtap="addToCart" data-product="{{item}}"><text>+加购</text></view>
        </view>
      </view>
    </block>

    <view class="more" wx:if="{{hasMore&&products.length>0}}"><text>上拉加载更多</text></view>
    <view class="nomore" wx:if="{{!hasMore&&products.length>0}}"><text>— 已展示全部 —</text></view>
    <view class="sb"></view>
  </scroll-view>

  <!-- ========== 全部筛选抽屉 ========== -->
  <view class="filter-mask {{filterOpen?'show':''}}" bindtap="closeFilter" wx:if="{{filterOpen}}"></view>
  <view class="filter-panel {{filterOpen?'in':''}}" wx:if="{{filterOpen}}">
    <view class="filter-head">
      <text class="filter-title">全部筛选</text>
      <text class="filter-close" bindtap="closeFilter">✕</text>
    </view>
    <scroll-view class="filter-body" scroll-y>
      <block wx:for="{{filterConfig.filterPanel.sections}}" wx:key="key">
        <view class="filter-sec">
          <view class="filter-sec-title">{{item.title}}<text wx:if="{{item.type!=='price'}}" class="filter-mode">({{item.multiple?'多选':'单选'}})</text></view>
          <view wx:if="{{item.type==='price'}}" class="price-row">
            <input class="price-input" type="digit" placeholder="最低价格" value="{{minPrice}}" data-type="min" bindinput="onPriceInput"/>
            <text class="price-line">-</text>
            <input class="price-input" type="digit" placeholder="最高价格" value="{{maxPrice}}" data-type="max" bindinput="onPriceInput"/>
          </view>
          <view wx:else class="filter-tags">
            <view wx:for="{{item.options}}" wx:key="*this" wx:for-item="opt"
              class="filter-tag {{selectedFilters[item.key]&&selectedFilters[item.key].indexOf(opt)>=0?'tag-on':''}}"
              bindtap="toggleFilter" data-key="{{item.key}}" data-value="{{opt}}" data-multiple="{{item.multiple}}">
              {{opt}}
            </view>
          </view>
        </view>
      </block>
      <view class="filter-foot-space"></view>
    </scroll-view>
    <view class="filter-foot">
      <view class="filter-reset" bindtap="resetFilter">重置</view>
      <view class="filter-confirm" bindtap="confirmFilter">确定</view>
    </view>
  </view>

  <!-- ========== quickFilter 弹窗（尺码/面料等） ========== -->
  <view class="popup-mask {{quickPopup?'show':''}}" bindtap="closeQuickPopup" wx:if="{{quickPopup}}"></view>
  <view class="popup-panel {{quickPopup?'in':''}}" wx:if="{{quickPopup}}">
    <view class="popup-head">
      <text class="popup-title">{{quickPopupLabel}}</text>
      <text class="popup-close" bindtap="closeQuickPopup">✕</text>
    </view>
    <scroll-view class="popup-body" scroll-y>
      <view class="filter-tags">
        <view wx:for="{{quickPopupOptions}}" wx:key="*this"
          class="filter-tag {{selectedFilters[quickPopup]&&selectedFilters[quickPopup].indexOf(item)>=0?'tag-on':''}}"
          bindtap="selectQuickPopup" data-key="{{quickPopup}}" data-value="{{item}}">
          {{item}}
        </view>
      </view>
    </scroll-view>
    <view class="filter-foot">
      <view class="filter-reset" bindtap="closeQuickPopup">取消</view>
      <view class="filter-confirm" bindtap="confirmQuickPopup">完成</view>
    </view>
  </view>
</view>
