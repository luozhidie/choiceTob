.page{padding:24rpx;background:#f5f3f0;min-height:100vh;box-sizing:border-box;}
.tip-card{background:#fff;border-radius:16rpx;padding:24rpx;margin-bottom:20rpx;}
.tc-txt{font-size:26rpx;color:#666;line-height:1.5;}
.form{background:#fff;border-radius:16rpx;padding:24rpx;}
.fi{margin-bottom:24rpx;}
.fl{font-size:26rpx;color:#333;font-weight:500;margin-bottom:12rpx;display:block;}
.req{color:#e11d48;}
.rg{display:flex;gap:32rpx;}
.rl{font-size:28rpx;color:#333;display:flex;align-items:center;gap:8rpx;}
.fin{background:#f7f5f3;border-radius:12rpx;padding:22rpx 24rpx;font-size:28rpx;}
.fta{background:#f7f5f3;border-radius:12rpx;padding:22rpx 24rpx;font-size:28rpx;height:240rpx;width:auto;box-sizing:border-box;}
.submit-btn{margin-top:20rpx;background:#2d1b2e;color:#fff;text-align:center;padding:28rpx 0;border-radius:14rpx;font-size:30rpx;font-weight:500;}
