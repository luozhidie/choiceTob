<view class="page">
  <view class="tip-card">
    <text class="tc-txt">您的反馈会帮助我们做得更好，客服将在 1-3 个工作日内回复。</text>
  </view>

  <view class="form">
    <view class="fi">
      <text class="fl">反馈类型</text>
      <radio-group class="rg" bindchange="onType">
        <label class="rl"><radio value="建议" checked="{{form.type==='建议'}}"/>建议</label>
        <label class="rl"><radio value="投诉" checked="{{form.type==='投诉'}}"/>投诉</label>
        <label class="rl"><radio value="其他" checked="{{form.type==='其他'}}"/>其他</label>
      </radio-group>
    </view>
    <view class="fi">
      <text class="fl">反馈内容 <text class="req">*</text></text>
      <textarea class="fta" placeholder="请详细描述您遇到的问题或建议" value="{{form.content}}" bindinput="onContent"/>
    </view>
    <view class="fi">
      <text class="fl">联系方式（选填）</text>
      <input class="fin" placeholder="手机号 / 微信号，方便我们回访" value="{{form.contact}}" bindinput="onContact"/>
    </view>
    <view class="submit-btn" bindtap="submit">提交反馈</view>
  </view>
</view>
