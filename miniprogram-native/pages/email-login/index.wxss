page{background:#fff;}
.hd{text-align:center;padding:60rpx 40rpx 30rpx;}
.ht{font-size:36rpx;font-weight:bold;color:#1a1a2e;display:block;}
.hs{font-size:24rpx;color:#999;margin-top:8rpx;display:block;}
.card{margin:32rpx;padding:28rpx;}
.inp{height:88rpx;background:#f5f5f5;border-radius:12rpx;padding:0 24rpx;margin-bottom:20rpx;font-size:28rpx;border:none;}
.btn-login{height:88rpx;background:linear-gradient(135deg,#ec4899,#e11d48);color:#fff;font-size:30rpx;font-weight:600;border-radius:44rpx;display:flex;align-items:center;justify-content:center;border:none;box-shadow:0 6rpx 20rpx rgba(236,72,153,.3);}
.btn-login::after{display:none;}
.back-row{text-align:center;padding:40rpx;color:#999;font-size:26rpx;}
