<view class="page">
  <!-- ====== 头部：头像+用户信息+操作图标 ====== -->
  <view class="header">
    <view class="header-left" bindtap="{{isLoggedIn?'goSettings':'goLogin'}}">
      <image class="avatar" src="{{avatarUrl||'/assets/avatar-ph.png'}}" mode="aspectFill"/>
      <view class="user-meta">
        <text class="uid">{{isLoggedIn?(userId||'用户'):'登录/注册'}}</text>
        <text class="role">{{roleText}}</text>
      </view>
    </view>
    <view class="header-icons">
      <view class="hi" bindtap="goContact"><text>🎧</text></view>
      <view class="hi" bindtap="goSettings"><text>⚙</text></view>
      <view class="hi"><text>🔔</text></view>
    </view>
  </view>

  <!-- ═══════ 已登录 + 未认证：金色认证引导卡（同行截图1）═══════ -->
  <view wx:if="{{isLoggedIn && !isCertified}}" class="cert-guide-card">
    <view class="cg-body">
      <!-- 左侧：未认证提示 -->
      <view class="cg-left">
        <text class="cg-status">您暂未认证</text>
        <text class="cg-hint">仅能</text>
        <text class="cg-restrict">零售价拿货</text>
      </view>

      <!-- 右侧：认证店主权益 -->
      <view class="cg-right">
        <view class="cg-title-row">
          <text class="cg-shield">🛡</text>
          <text class="cg-cert-title">认证店主</text>
        </view>
        <!-- 4个权益图标 -->
        <view class="cg-icons">
          <block wx:for="{{certBenefits}}" wx:key="title">
            <view class="cgi-item">
              <view class="cgi-circle"><text>{{item.icon}}</text></view>
              <text class="cgi-label">{{item.title}}</text>
            </view>
          </block>
        </view>
        <!-- 一键认证按钮 -->
        <view class="cg-btn" bindtap="goCertify">一键认证 解锁权益</view>
      </view>
    </view>
  </view>

  <!-- ═══════ 已登录 + 已认证：深色等级卡（同行截图2）═══════ -->
  <view wx:if="{{isLoggedIn && isCertified}}" class="tier-card-dark">
    <!-- 标题行 -->
    <view class="tcd-header">
      <text class="tcd-level">{{tierName}}<text class="tcd-badge">{{tierBadge}}</text></text>
      <view class="tcd-view-btn" bindtap="goVip"><text>查看权益</text></view>
    </view>
    <!-- 进度条 -->
    <view class="tcd-bar-wrap">
      <view class="tcd-bar-track">
        <view class="tcd-bar-fill" style="width:{{tierProgress}}%"></view>
      </view>
    </view>
    <!-- 拿货额文字 -->
    <view class="tcd-spent-text">
      当月拿货额 <text class="tcd-spent-num">{{spentYuan}}</text> ，还差<text class="tcd-diff-num">{{nextTierDiff}}</text>元升级{{nextTierName}}
    </view>
    <!-- 4个权益图标行 -->
    <view class="tcd-benefits">
      <block wx:for="{{tierCardBenefits}}" wx:key="title">
        <view class="tcdb-item">
          <view class="tcdb-circle"><text>{{item.icon}}</text></view>
          <text class="tcdb-label">{{item.title}}</text>
        </view>
      </block>
    </view>
  </view>

  <!-- ═══════ 未登录：轻量认证入口（同行截图3粉色卡）═══════ -->
  <view wx:if="{{!isLoggedIn}}" class="cert-entry-card" bindtap="goLogin">
    <div class="ce-row">
      <text class="ce-icon">🛡</text>
      <div class="ce-body">
        <text class="ce-title">认证店主</text>
        <text class="ce-desc">免费通过答题，解锁批发价查看权</text>
      </div>
      <text class="ce-arrow">免费认证 →</text>
    </div>
  </view>

  <!-- ═══════ 未登录后：正常显示下方内容 ═══════ -->

  <!-- ========== 快捷数据（3格）========== -->
  <view class="stats-row">
    <view class="stat-card" bindtap="goBuyer">
      <text class="sc-icon">🏪</text>
      <text class="sc-num">{{subCount}}</text>
      <text class="sc-label">订阅档口</text>
    </view>
    <view class="stat-card" bindtap="goFavorites">
      <text class="sc-icon">⭐</text>
      <text class="sc-num">{{favCount}}</text>
      <text class="sc-label">收藏商品</text>
    </view>
    <view class="stat-card" bindtap="goHistory">
      <text class="sc-icon">👣</text>
      <text class="sc-num">{{historyCount}}</text>
      <text class="sc-label">足迹</text>
    </view>
  </view>

  <!-- ========== 我的订单 ========== -->
  <view class="section">
    <view class="sec-header">
      <text class="sec-title">我的订单</text>
      <text class="sec-more" bindtap="goOrders">查看全部 ›</text>
    </view>
    <view class="order-row">
      <view class="oi" bindtap="goOrders" data-status="unpaid">
        <text class="oi-icon">💰</text><text class="oi-label">待付款</text>
      </view>
      <view class="oi" bindtap="goOrders" data-status="toship">
        <text class="oi-icon">🚚</text><text class="oi-label">待发货</text>
      </view>
      <view class="oi" bindtap="goOrders" data-status="toreceive">
        <text class="oi-icon">📦</text><text class="oi-label">待收货</text>
      </view>
      <view class="oi" bindtap="goOrders" data-status="aftersale">
        <text class="oi-icon">↩️</text><text class="oi-label">售后进度</text>
      </view>
    </view>
  </view>

  <!-- ========== 活动横幅 ========== -->
  <view class="promo-banner" bindtap="goPromo">
    <text class="pb-tag">HOT</text>
    <text class="pb-title">首单4重福利 · 限时福利</text>
    <text class="pb-sub">169包邮/免费退货/新人红包/优先发货</text>
    <text class="pb-go">GO →</text>
  </view>

  <!-- ========== 我的资产 ========== -->
  <view class="section">
    <text class="sec-title">我的资产</text>
    <view class="asset-row">
      <view class="asset-item" bindtap="goSettings">
        <text class="asset-num">{{walletBalance}}</text><text class="asset-label">钱包</text>
      </view>
      <view class="asset-divider"></view>
      <view class="asset-item" bindtap="goCoupons">
        <text class="asset-num">{{couponCount}}</text><text class="asset-label">卡券</text>
      </view>
      <view class="asset-divider"></view>
      <view class="asset-item" bindtap="goRedPackets">
        <text class="asset-num">{{redPackCount}}</text><text class="asset-label">红包</text>
      </view>
    </view>
  </view>

  <!-- ========== 我的活动（2x3网格）========== -->
  <view class="section" wx:if="{{isLoggedIn}}">
    <text class="sec-title">我的活动</text>
    <view class="activity-grid">
      <view class="ac-item" bindtap="goBuyer">
        <text class="ac-title">发现宝藏档口</text>
        <text class="ac-desc">2026全国精选...</text>
        <image class="ac-img" src="/assets/icon-store.png" mode="aspectFit"/>
      </view>
      <view class="ac-item ac-highlight" bindtap="goGroupBuy">
        <text class="ac-title">店主福利社群</text>
        <text class="ac-desc">运费券/红包活动</text>
        <image class="ac-img" src="/assets/icon-group.png" mode="aspectFit"/>
      </view>
      <view class="ac-item ac-hot" bindtap="goLuckDraw">
        <text class="ac-title">集财运</text>
        <text class="ac-desc">赚财运享福利</text>
        <image class="ac-img" src="/assets/icon-luck.png" mode="aspectFit"/>
      </view>
      <view class="ac-item" bindtap="goInvite">
        <text class="ac-title">邀请有奖</text>
        <text class="ac-desc">返8-100元券包</text>
        <view class="ac-badge-new">New</view>
        <image class="ac-img" src="/assets/icon-invite.png" mode="aspectFit"/>
      </view>
    </view>
  </view>

  <!-- ========== 我的服务 ========== -->
  <view class="section">
    <text class="sec-title">我的服务</text>
    <view class="service-list">
      <view class="sv-item" bindtap="goImport">
        <text class="sv-icon-text">📦</text>
        <text class="sv-label">一键导入</text>
      </view>
      <view class="sv-item" bindtap="goOneKeyImport">
        <text class="sv-icon-text">📥</text>
        <text class="sv-label">一键入库</text>
      </view>
    </view>
  </view>

  <view class="sbtm"></view>
</view>
