<view class="page">
  <!-- 用户头部 -->
  <view class="user-hero">
    <view class="avatar-box">
      <image wx:if="{{userInfo.avatarUrl}}" src="{{userInfo.avatarUrl}}" class="avatar" mode="aspectFill"/>
      <view wx:else class="avatar-ph"><text>{{userInfo.nickName?userInfo.nickName[0]:'?'}}</text></view>
    </view>
    <view class="user-info">
      <text class="uname">{{userInfo.nickName||'用户'}}</text>
      <text class="uemail">{{userInfo.email||''}}</text>
    </view>
  </view>

  <!-- 快捷入口 -->
  <view class="quick-cards">
    <view class="qc" bindtap="goCart">
      <view class="qci"><text>🛒</text></view>
      <text class="qct">购物车</text>
    </view>
    <view class="qc" bindtap="goOrders">
      <view class="qci"><text>📦</text></view>
      <text class="qct">我的订单</text>
      <text class="qc-badge" wx:if="{{orderCount>0}}">{{orderCount}}笔</text>
    </view>
    <view class="qc" bindtap="goVip">
      <view class="qci"><text>👑</text></view>
      <text class="qct">会员服务</text>
    </view>
  </view>

  <!-- 会员状态卡片 -->
  <view class="vip-card" wx:if="{{!isVip}}">
    <view class="vc-header">
      <text class="vc-icon">👑</text>
      <text class="vc-title">会员状态</text>
      <text class="vc-link" bindtap="goVip">立即开通 ›</text>
    </view>
    <view class="vc-body">
      <text class="vc-tip">还不是会员？开通后可享受 ¥19.9起 的超值权益！</text>
      <view class="vc-btn" bindtap="goVip"><text>立即开通</text></view>
    </view>
  </view>

  <!-- 已是会员卡片 -->
  <view class="vip-card vip-active" wx:if="{{isVip}}">
    <view class="vc-header">
      <text class="vc-icon">👑</text>
      <text class="vc-title">会员状态</text>
      <text class="vc-status">✓ 已开通</text>
    </view>
    <view class="vc-body">
      <text class="vc-tip">{{memberType||'价格会员'}} · 有效期至 {{expireDate||'2027-07-03'}}</text>
      <view class="vc-btn vc-btn-renew" bindtap="goVip"><text>续费/升级</text></view>
    </view>
  </view>

  <!-- 常用功能 -->
  <view class="func-section">
    <text class="fs-title">常用功能</text>
    <view class="flist">
      <view class="fi" bindtap="goBuyer">
        <text class="fi-icon">🛍️</text><text class="fi-text">继续选购</text><text class="fi-arrow">›</text>
      </view>
      <view class="fi" bindtap="goMember">
        <text class="fi-icon">👑</text><text class="fi-text">会员功能中心</text><text class="fi-arrow">›</text>
      </view>
      <view class="fi" bindtap="goContact">
        <text class="fi-icon">📍</text><text class="fi-text">联系客服</text><text class="fi-arrow">›</text>
      </view>
      <view class="fi" bindtap="goFavorites">
        <text class="fi-icon">♡</text><text class="fi-text">我的收藏</text><text class="fi-arrow">›</text>
      </view>
      <view class="fi" bindtap="goHistory">
        <text class="fi-icon">📋</text><text class="fi-text">浏览记录</text>
        <text class="fi-count" wx:if="{{historyCount>0}}">{{historyCount}}</text><text class="fi-arrow">›</text>
      </view>
      <view class="fi" bindtap="goArticles">
        <text class="fi-icon">📰</text><text class="fi-text">时尚资讯</text><text class="fi-arrow">›</text>
      </view>
      <view class="fi" bindtap="goStyleTest">
        <text class="fi-icon">🎨</text><text class="fi-text">风格测试</text><text class="fi-arrow">›</text>
      </view>
      <view class="fi" bindtap="goAbout">
        <text class="fi-icon">ℹ️</text><text class="fi-text">关于我们</text><text class="fi-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="sbtm"></view>
</view>
