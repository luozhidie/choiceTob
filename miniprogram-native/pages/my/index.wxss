page{background:#f5f3f0;}

/* ====== 头部 ====== */
.header{display:flex;align-items:center;justify-content:space-between;padding:28rpx 24rpx 16rpx;background:linear-gradient(180deg,#fff5f8 0%,#fce4ec 40%,#fff 100%);}
.header-left{display:flex;align-items:center;gap:18rpx;flex:1;}
.avatar{width:80rpx;height:80rpx;border-radius:50%;background:#fdd7e4;overflow:hidden;}
.user-meta{display:flex;flex-direction:column;gap:2rpx;}
.uid{font-size:30rpx;font-weight:700;color:#1a1a2e;}
.role{font-size:22rpx;color:#999;}
.header-icons{display:flex;gap:20rpx;}
.hi{width:56rpx;height:56rpx;background:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:26rpx;box-shadow:0 2rpx 10rpx rgba(0,0,0,.06);}

/* ═══════ 未认证：金色认证引导卡（同行截图1）════════ */
.cert-guide-card{margin:16rpx 20rpx;border-radius:24rpx;overflow:hidden;
  background:linear-gradient(135deg,#fef3c7 0%,#fcd34d 30%,#f59e0b 70%,#d97706 100%);
  border:2rpx solid #fbbf24;box-shadow:0 8rpx 30rpx rgba(245,158,11,.25);}
.cg-body{display:flex;padding:32rpx 24rpx;}

/* 左侧：未认证提示 */
.cg-left{width:35%;display:flex;flex-direction:column;justify-content:center;align-items:center;
  padding-right:16rpx;border-right:2rpx dashed rgba(120,53,15,.25);}
.cg-status{font-size:26rpx;color:#78350f;font-weight:700;margin-bottom:8rpx;
  letter-spacing:6rpx;}
.cg-hint{font-size:23rpx;color:#92400e;display:block;text-align:center;}
.cg-restrict{font-size:28rpx;color:#78350f;font-weight:bold;display:block;text-align:center;margin-top:4rpx;}

/* 右侧：认证店主权益 */
.cg-right{flex:1;padding-left:20rpx;display:flex;flex-direction:column;align-items:center;}
.cg-title-row{display:flex;align-items:center;gap:8rpx;margin-bottom:16rpx;}
.cg-shield{font-size:36rpx;}
.cg-cert-title{font-size:30rpx;font-weight:bold;color:#78350f;}
/* 4个权益图标 */
.cg-icons{display:flex;justify-content:space-around;width:100%;margin-bottom:20rpx;}
.cgi-item{display:flex;flex-direction:column;align-items:center;gap:6rpx;}
.cgi-circle{width:68rpx;height:68rpx;border-radius:50%;
  background:rgba(255,255,255,.55);display:flex;align-items:center;justify-content:center;
  font-size:30rpx;border:2rpx solid rgba(255,255,255,.7);box-shadow:0 2rpx 8rpx rgba(0,0,0,.08);}
.cgi-label{font-size:19rpx;color:#78350f;font-weight:500;text-align:center;line-height:1.2;}
/* 一键认证按钮 */
.cg-btn{width:100%;text-align:center;font-size:26rpx;font-weight:600;color:#92400e;
  padding:18rpx 0;border-radius:40rpx;border:2rpx solid #92400e;
  background:linear-gradient(135deg,rgba(255,255,255,.75),rgba(255,255,255,.45));
  box-shadow:0 4rpx 12rpx rgba(0,0,0,.08);}

/* ═══════ 已认证：深色等级卡（同行截图2）════════ */
.tier-card-dark{margin:16rpx 20rpx;border-radius:24rpx;overflow:hidden;
  background:linear-gradient(160deg,#292524 0%,#1c1917 50%,#0c0a09 100%);
  padding:28rpx 24rpx 24rpx;box-shadow:0 8rpx 30rpx rgba(0,0,0,.2);
  color:#fff;}

/* 标题行 */
.tcd-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:16rpx;}
.tcd-level{font-size:32rpx;font-weight:bold;display:flex;align-items:center;gap:10rpx;}
.tcd-badge{font-size:19rpx;background:linear-gradient(135deg,#fcd34d,#f59e0b);color:#78350f;
  padding:4rpx 14rpx;border-radius:10rpx;font-weight:800;vertical-align:middle;
  box-shadow:0 2rpx 8rpx rgba(245,158,11,.4);}
.tcd-desc{display:block;font-size:21rpx;color:rgba(255,255,255,.6);line-height:1.4;margin:-4rpx 0 14rpx;}
.tcd-view-btn{background:rgba(252,211,77,.18);border:1rpx solid rgba(252,211,77,.35);
  border-radius:30rpx;padding:8rpx 22rpx;font-size:21rpx;color:#fcd34d;font-weight:600;}

/* 进度条 */
.tcd-bar-wrap{margin:14rpx 0 10rpx;}
.tcd-bar-track{height:8rpx;background:rgba(255,255,255,.12);border-radius:10rpx;overflow:hidden;}
.tcd-bar-fill{height:100%;background:linear-gradient(90deg,#fcd34d,#f59e0b);border-radius:10rpx;
  transition:width .6s ease;}

/* 拿货额文字 */
.tcd-spent-text{font-size:23rpx;color:rgba(255,255,255,.65);line-height:1.5;margin-bottom:18rpx;}
.tcd-spent-num{color:#fcd34d;font-weight:bold;font-size:28rpx;}
.tcd-diff-num{color:#fcd34d;font-weight:bold;font-size:26rpx;}

/* 4个权益图标行 */
.tcd-benefits{display:flex;justify-content:space-around;padding-top:18rpx;
  border-top:1rpx solid rgba(255,255,255,.08);}
.tcdb-item{display:flex;flex-direction:column;align-items:center;gap:6rpx;flex:1;}
.tcdb-circle{width:72rpx;height:72rpx;border-radius:50%;
  background:rgba(255,255,255,.08);border:2rpx solid rgba(255,255,255,.15);
  display:flex;align-items:center;justify-content:center;font-size:32rpx;}
.tcdb-label{font-size:19rpx;color:rgba(255,255,255,.6);text-align:center;}
.tcd-foot{display:block;font-size:18rpx;color:rgba(255,255,255,.4);text-align:center;margin-top:16rpx;line-height:1.4;}
.tcd-price-entry{margin-top:14rpx;padding:16rpx 20rpx;border-radius:12rpx;
  background:linear-gradient(135deg,rgba(252,211,77,.12),rgba(245,158,11,.08));
  border:1rpx solid rgba(252,211,77,.2);}
.tcd-price-txt{font-size:21rpx;color:#fcd34d;font-weight:600;text-align:center;}

/* ====== 快捷数据行（3格）===== */
.stats-row{display:flex;gap:12rpx;padding:0 20rpx;margin-top:12rpx;}
.stat-card{flex:1;background:#fff;border-radius:16rpx;padding:20rpx 12rpx;display:flex;flex-direction:column;align-items:center;gap:6rpx;box-shadow:0 2rpx 10rpx rgba(0,0,0,.04);}
.sc-icon{font-size:38rpx;}
.sc-num{font-size:30rpx;font-weight:bold;color:#333;}
.sc-label{font-size:20rpx;color:#999;}

/* ====== 通用section ====== */
.section{margin:16rpx 20rpx 0;background:#fff;border-radius:20rpx;padding:22rpx 20rpx 16rpx;box-shadow:0 2rpx 10rpx rgba(0,0,0,.03);}
.sec-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:16rpx;}
.sec-title{font-size:30rpx;font-weight:700;color:#1a1a2e;}
.sec-more{font-size:23rpx;color:#999;font-weight:400;}

/* ====== 订单行 ====== */
.order-row{display:flex;justify-content:space-around;padding:8rpx 0;}
.oi{display:flex;flex-direction:column;align-items:center;gap:6rpx;flex:1;padding:14rpx 6rpx;border-radius:14rpx;background:#faf8f6;}
.oi-icon{font-size:34rpx;}
.oi-label{font-size:21rpx;color:#555;font-weight:500;}

/* ====== 活动横幅 ====== */
.promo-banner{margin:16rpx 20rpx;background:linear-gradient(135deg,#fff5f7,#ffecb3);border-radius:16rpx;padding:22rpx 24rpx;display:flex;align-items:center;gap:12rpx;border:1rpx solid #ffe0b2;}
.pb-tag{background:#e91e63;color:#fff;font-size:19rpx;font-weight:700;padding:4rpx 14rpx;border-radius:8rpx;shrink:0;}
.pb-title{font-size:28rpx;font-weight:800;color:#c2185b;shrink:0;}
.pb-sub{font-size:20rpx;color:#c2185b;opacity:.7;flex:1;}
.pb-go{background:#333;color:#fff;font-size:21rpx;font-weight:600;padding:8rpx 18rpx;border-radius:16rpx;shrink:0;}

/* ====== 资产行 ====== */
.asset-row{display:flex;align-items:center;justify-content:space-around;padding:16rpx 0;}
.asset-item{display:flex;flex-direction:column;align-items:center;flex:1;gap:4rpx;}
.asset-num{font-size:32rpx;font-weight:bold;color:#333;}
.asset-label{font-size:21rpx;color:#999;}
.asset-divider{width:1rpx;height:32rpx;background:#eee;}

/* ====== 活动网格 ====== */
.activity-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12rpx;}
.ac-item{position:relative;background:#faf8f6;border-radius:14rpx;padding:18rpx 16rpx;display:flex;flex-direction:column;gap:4rpx;overflow:hidden;border:1rpx solid #f0ede9;}
.ac-highlight{border-color:#ffccbc;background:#fffafdc;}
.ac-hot{border-color:#ffcdd2;background:#fff5f5;}
.ac-title{font-size:25rpx;font-weight:600;color:#333;line-height:1.3;}
.ac-desc{font-size:19rpx;color:#999;line-height:1.3;}
.ac-img{position:absolute;right:10rpx;top:10rpx;width:52rpx;height:52rpx;opacity:.85;}
.ac-badge-new{position:absolute;left:12rpx;top:12rpx;background:#e91e63;color:#fff;font-size:16rpx;font-weight:700;padding:2rpx 10rpx;border-radius:8rpx;}

/* ====== 服务列表 ====== */
.service-list{display:flex;flex-wrap:wrap;gap:12rpx;}
.sv-item{flex:1;min-width:140rpx;background:#faf8f6;border-radius:14rpx;padding:18rpx 14rpx;display:flex;align-items:center;gap:12rpx;border:1rpx solid #f0ede9;}
.sv-label{font-size:24rpx;font-weight:500;color:#333;}

/* ====== 个人形象服务：5 图标网格 ====== */
.service-grid{display:flex;justify-content:space-between;padding:8rpx 0 24rpx;}
.sg-item{display:flex;flex-direction:column;align-items:center;gap:10rpx;flex:1;}
.sg-icon{width:88rpx;height:88rpx;border-radius:50%;background:#faf8f6;border:1rpx solid #f0ede9;display:flex;align-items:center;justify-content:center;font-size:42rpx;}
.sg-label{font-size:22rpx;color:#555;font-weight:500;}

/* ====== 个人形象诊断 banner ====== */
.image-diag-card{margin-top:8rpx;border-radius:20rpx;overflow:hidden;
  background:linear-gradient(135deg,#2d1b2e 0%,#4a2b4d 50%,#2d1b2e 100%);
  box-shadow:0 8rpx 24rpx rgba(45,27,46,.25);}
.idc-body{padding:32rpx 28rpx;display:flex;flex-direction:column;gap:14rpx;}
.idc-title{font-size:34rpx;font-weight:bold;color:#fff;letter-spacing:2rpx;}
.idc-desc{font-size:24rpx;color:rgba(255,255,255,.78);line-height:1.5;}
.idc-highlight{color:#C9A24B;font-weight:600;}
.idc-btn{align-self:flex-start;background:#C9A24B;color:#2d1b2e;font-size:24rpx;font-weight:600;padding:14rpx 32rpx;border-radius:32rpx;margin-top:6rpx;}

/* ═══════ 未登录：轻量认证入口（粉色·同行截图3）═══════ */
.cert-entry-card{margin:16rpx 20rpx 12rpx;background:linear-gradient(135deg,#fef2f2,#fce7f3);border:2rpx solid #fecdd3;border-radius:20rpx;overflow:hidden;}
.cert-entry-card:active{background:linear-gradient(135deg,#fee2e2,#fecaca);}
.ce-row{display:flex;align-items:center;padding:24rpx 20rpx;gap:14rpx;}
.ce-icon{font-size:40rpx;shrink:0;}
.ce-body{flex:1;display:flex;flex-direction:column;gap:4rpx;}
.ce-title{font-size:28rpx;font-weight:bold;color:#be123c;}
.ce-desc{font-size:22rpx;color:#b91c1c;}
.ce-arrow{font-size:24rpx;font-weight:bold;color:#e11d48;shrink:0;}

.sbtm{height:100rpx;}

/* 退出登录 */
.logout-wrap{padding:20rpx 40rpx 40rpx;}
.btn-logout{height:80rpx;background:#fff;color:#e11d48;font-size:28rpx;font-weight:500;border-radius:16rpx;display:flex;align-items:center;justify-content:center;border:2rpx solid #fecdd3;box-sizing:border-box;}
.btn-logout::after{display:none;}
.btn-logout:active{background:#fef2f2;}
