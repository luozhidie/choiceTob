page{background:#f5f3f0;}

/* ====== 头部 ====== */
.header{display:flex;align-items:center;justify-content:space-between;padding:28rpx 24rpx 16rpx;background:linear-gradient(180deg,#fff5f8 0%,#fce4ec 40%,#fff 100%);}
.header-left{display:flex;align-items:center;gap:18rpx;flex:1;}
.avatar{width:80rpx;height:80rpx;border-radius:50%;background:#fdd7e4;overflow:hidden;}
.avatar-ph{width:80rpx;height:80rpx;border-radius:50%;background:#f8bbd0;display:flex;align-items:center;justify-content:center;font-size:32rpx;color:#e91e63;font-weight:bold;}
.user-meta{display:flex;flex-direction:column;gap:2rpx;}
.uid{font-size:30rpx;font-weight:700;color:#1a1a2e;}
.role{font-size:22rpx;color:#999;}
.header-icons{display:flex;gap:20rpx;}
.hi{width:56rpx;height:56rpx;background:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:26rpx;box-shadow:0 2rpx 10rpx rgba(0,0,0,.06);}

/* ====== 成长等级卡（渐进解锁）====== */
.tier-card-wrap{margin:16rpx 20rpx;background:#fff;border-radius:24rpx;padding:28rpx 24rpx;box-shadow:0 4rpx 20rpx rgba(0,0,0,.05);}
.tier-card{border-radius:20rpx;padding:32rpx 28rpx;color:#fff;margin-bottom:24rpx;}
.tier-normal{background:linear-gradient(135deg,#9ca3af,#6b7280);}
.tier-silver{background:linear-gradient(135deg,#60a5fa,#3b82f6);}
.tier-gold{background:linear-gradient(135deg,#f59e0b,#d97706);}
.tier-platinum{background:linear-gradient(135deg,#a855f7,#7c3aed);}
.tier-diamond{background:linear-gradient(135deg,#ec4899,#db2777);}

.tc-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:20rpx;}
.tc-left{display:flex;align-items:center;gap:16rpx;}
.tc-emoji{font-size:48rpx;}
.tc-meta{display:flex;flex-direction:column;gap:4rpx;}
.tc-label{font-size:22rpx;opacity:.85;}
.tc-name{font-size:34rpx;font-weight:bold;}
.tc-upgrade{background:rgba(255,255,255,.22);border-radius:40rpx;padding:8rpx 22rpx;font-size:22rpx;}

.tc-progress-row{display:flex;justify-content:space-between;margin-top:20rpx;font-size:22rpx;opacity:.9;}
.tc-progress-l{opacity:.85;}
.tc-bar-track{height:14rpx;background:rgba(255,255,255,.25);border-radius:10rpx;margin-top:12rpx;overflow:hidden;}
.tc-bar-fill{height:100%;background:#fff;border-radius:10rpx;transition:width .5s;}
.tc-max-tag{margin-top:20rpx;display:inline-block;background:rgba(255,255,255,.2);padding:10rpx 24rpx;border-radius:30rpx;font-size:22rpx;}

/* 等级阶梯 */
.tier-steps{display:flex;justify-content:space-between;position:relative;padding:0 4rpx;}
.ts-node-wrap{flex:1;display:flex;flex-direction:column;align-items:center;position:relative;}
.ts-line{position:absolute;top:26rpx;left:50%;width:100%;height:4rpx;background:#e5e7eb;z-index:0;}
.ts-line-active{background:#e91e63;}
.ts-dot{width:52rpx;height:52rpx;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:22rpx;z-index:1;background:#f3f4f6;color:#9ca3af;}
.ts-dot-active{background:#e91e63;color:#fff;font-weight:bold;}
.ts-dot-current{border:3rpx solid #fce7f3;background:#fff;color:#e91e63;}
.ts-name{font-size:19rpx;color:#9ca3af;margin-top:10rpx;}
.ts-name-cur{color:#e91e63;font-weight:bold;}
.tc-footnote{display:block;text-align:center;font-size:19rpx;color:#bbb;margin-top:16rpx;}
.tc-link{color:#e91e63;font-weight:500;}

/* 权益解锁等级（5列横排·同行同款）*/
.benefit-wrap{margin:16rpx 20rpx 12rpx;background:#fff;border-radius:24rpx;padding:28rpx 20rpx;box-shadow:0 4rpx 20rpx rgba(0,0,0,.05);}
.bw-head{margin-bottom:20rpx;}
.bw-title{font-size:30rpx;font-weight:700;color:#1a1a2e;display:block;}
.bw-sub{font-size:21rpx;color:#bbb;display:block;margin-top:4rpx;}
.bw-row{display:flex;justify-content:space-between;gap:6rpx;}
.bw-item{flex:1;display:flex;flex-direction:column;align-items:center;}
.bw-circle{width:90rpx;height:90rpx;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:36rpx;margin-bottom:8rpx;}
.bw-c-on{background:linear-gradient(135deg,#fcd34d,#f97316);color:#fff;box-shadow:0 6rpx 20rpx rgba(249,115,22,.3);}
.bw-c-off{background:#f3f4f6;color:#ccc;}
.bw-name{font-size:21rpx;font-weight:500;text-align:center;line-height:1.3;}
.bw-n-on{color:#333;}
.bw-n-off{color:#999;}
.bw-status{font-size:18rpx;margin-top:2rpx;}
.bw-s-on{color:#d97706;}
.bw-s-off{color:#ccc;}

/* 认证店主联盟（深色·同行同款）*/
.cert-alliance-wrap{margin:0 20rpx 16rpx;border-radius:24rpx;padding:28rpx 24rpx;background:linear-gradient(135deg,#1e293b,#0f172a);box-shadow:0 4rpx 20rpx rgba(0,0,0,.15);}
.ca-head{display:flex;align-items:center;gap:12rpx;margin-bottom:16rpx;}
.ca-icon{font-size:32rpx;}
.ca-title{font-size:30rpx;font-weight:700;color:#fff;}
.ca-badge{font-size:19rpx;background:rgba(52,211,153,.15);color:#34d399;padding:6rpx 18rpx;border-radius:30rpx;font-weight:600;border:1rpx solid rgba(52,211,153,.25);}
.ca-desc{font-size:24rpx;color:rgba(255,255,255,.55);line-height:1.6;margin-bottom:20rpx;}
.ca-btn{background:linear-gradient(135deg,#10b981,#14b8a6);color:#fff;font-size:26rpx;font-weight:600;text-align:center;padding:22rpx 0;border-radius:18rpx;box-shadow:0 6rpx 20rpx rgba(16,185,129,.3);}
.ca-done{background:rgba(255,255,255,.08);border:1rpx solid rgba(255,255,255,.12);border-radius:18rpx;padding:20rpx;display:flex;align-items:center;gap:12rpx;}
.ca-check{font-size:32rpx;}
.ca-msg{font-size:24rpx;color:rgba(255,255,255,.85);}

/* ====== 快捷数据行（3格）===== */
.stats-row{display:flex;gap:12rpx;padding:0 20rpx;margin-top:12rpx;}
.stat-card{flex:1;background:#fff;border-radius:16rpx;padding:20rpx 12rpx;display:flex;flex-direction:column;align-items:center;gap:6rpx;box-shadow:0 2rpx 10rpx rgba(0,0,0,.04);}
.sc-icon{font-size:38rpx;}
.sc-num{font-size:30rpx;font-weight:bold;color:#333;}
.sc-label{font-size:20rpx;color:#999;}

/* ====== 通用section ====== */
.section{margin:16rpx 20rpx 0;background:#fff;border-radius:20rpx;padding:22rpx 20rpx 16rpx;box-shadow:0 2rpx 10rpx rgba(0,0,0,.03);}
.sec-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:16rpx;}
.sec-title{font-size:30rpx;font-weight:700;color:#1a1a2e;}
.sec-more{font-size:23rpx;color:#999;font-weight:400;}

/* ====== 订单行 ====== */
.order-row{display:flex;justify-content:space-around;padding:8rpx 0;}
.oi{display:flex;flex-direction:column;align-items:center;gap:6rpx;flex:1;padding:14rpx 6rpx;border-radius:14rpx;background:#faf8f6;}
.oi-icon{font-size:34rpx;}
.oi-label{font-size:21rpx;color:#555;font-weight:500;}

/* ====== 活动横幅 ====== */
.promo-banner{margin:16rpx 20rpx;background:linear-gradient(135deg,#fff5f7,#ffecb3);border-radius:16rpx;padding:22rpx 24rpx;display:flex;align-items:center;justify-content:space-between;border:1rpx solid #ffe0b2;}
.pb-tag{background:#e91e63;color:#fff;font-size:19rpx;font-weight:700;padding:4rpx 14rpx;border-radius:8rpx;}
.pb-title{font-size:28rpx;font-weight:800;color:#c2185b;margin-left:12rpx;}
.pb-btn{background:#333;color:#fff;font-size:21rpx;font-weight:500;padding:8rpx 20rpx;border-radius:16rpx;}

/* ====== 资产行 ====== */
.asset-row{display:flex;align-items:center;justify-content:space-around;padding:16rpx 0;}
.asset-item{display:flex;flex-direction:column;align-items:center;flex:1;gap:4rpx;}
.asset-num{font-size:32rpx;font-weight:bold;color:#333;}
.asset-label{font-size:21rpx;color:#999;}
.asset-divider{width:1rpx;height:32rpx;background:#eee;}

/* ====== 活动网格 ====== */
.activity-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12rpx;}
.ac-item{position:relative;background:#faf8f6;border-radius:14rpx;padding:18rpx 16rpx;display:flex;flex-direction:column;gap:4rpx;overflow:hidden;border:1rpx solid #f0ede9;}
.ac-highlight{border-color:#ffccbc;background:#fffafdc;}
.ac-hot{border-color:#ffcdd2;background:#fff5f5;}
.ac-title{font-size:25rpx;font-weight:600;color:#333;line-height:1.3;}
.ac-desc{font-size:19rpx;color:#999;line-height:1.3;}
.ac-img{position:absolute;right:10rpx;top:10rpx;width:52rpx;height:52rpx;opacity:.85;}
.ac-badge-new{position:absolute;left:12rpx;top:12rpx;background:#e91e63;color:#fff;font-size:16rpx;font-weight:700;padding:2rpx 10rpx;border-radius:8rpx;}

/* ====== 服务列表 ====== */
.service-list{display:flex;flex-wrap:wrap;gap:12rpx;}
.sv-item{flex:1;min-width:140rpx;background:#faf8f6;border-radius:14rpx;padding:18rpx 14rpx;display:flex;align-items:center;gap:12rpx;border:1rpx solid #f0ede9;}
.sv-icon{width:44rpx;height:44rpx;border-radius:10rpx;}
.sv-label{font-size:24rpx;font-weight:500;color:#333;}

.sbtm{height:100rpx;}

/* 认证店主徽章 */
.cert-badge{display:inline-block;margin-left:12rpx;padding:4rpx 14rpx;background:rgba(34,197,94,0.1);color:#16a34a;font-size:20rpx;font-weight:bold;border-radius:10rpx;vertical-align:middle;}

/* 认证店主入口 */
.cert-entry{display:flex;align-items:center;gap:18rpx;padding:24rpx;background:linear-gradient(135deg,#fef8f0,#fdeef6);border:2rpx solid #f5d0b8;border-radius:18rpx;}
.ce-icon{font-size:44rpx;shrink:0;}
.ce-body{flex:1;}
.ce-title{display:block;font-size:30rpx;font-weight:bold;color:#c44d26;}
.ce-desc{display:block;font-size:22rpx;color:#b87a58;margin-top:4rpx;}
.ce-btn{font-size:26rpx;font-weight:bold;color:#e85d5d;shrink:0;}
