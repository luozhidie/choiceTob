page{background:#f5f2ef;}

/* 用户头部 */
.user-hero{
  background:linear-gradient(160deg,#4a1a6b 0%,#7b3f9e 40%,#c44a8c 100%);
  padding:50rpx 28rpx 36rpx;
  display:flex;
  align-items:center;
}
.avatar-box{flex-shrink:0;margin-right:24rpx;}
.avatar{width:100rpx;height:100rpx;border-radius:50%;border:3rpx solid rgba(255,255,255,.5);}
.avatar-ph{width:100rpx;height:100rpx;border-radius:50%;background:rgba(255,255,255,.2);display:flex;align-items:center;justify-content:center;font-size:44rpx;color:#fff;font-weight:bold;}
.uname{font-size:34rpx;font-weight:bold;color:#fff;display:block;}
.uemail{font-size:23rpx;color:rgba(255,255,255,.65);display:block;margin-top:6rpx;}

/* 快捷入口 */
.quick-cards{display:flex;padding:16rpx 20rpx;background:#fff;margin:-24rpx 20rpx 0;border-radius:18rpx;box-shadow:0 4rpx 20rpx rgba(0,0,0,.08);position:relative;z-index:2;}
.qc{flex:1;display:flex;flex-direction:column;align-items:center;padding:20rpx 0;position:relative;}
.qci{width:52rpx;height:52rpx;background:#f5f3f0;border-radius:14rpx;display:flex;align-items:center;justify-content:center;font-size:28rpx;margin-bottom:8rpx;}
.qct{font-size:25rpx;color:#333;font-weight:500;}
.qc-badge{font-size:19rpx;color:#e91e63;position:absolute;top:12rpx;}

/* 会员卡片 */
.vip-card{margin:20rpx 20rpx 0;background:#fff;border-radius:22rpx;overflow:hidden;box-shadow:0 2rpx 14rpx rgba(0,0,0,.04);}
.vip-active{border:2rpx solid #ffd54f;}
.vc-header{display:flex;align-items:center;padding:22rpx 24rpx;border-bottom:1rpx solid #f5f2ef;}
.vc-icon{font-size:30rpx;margin-right:10rpx;}
.vc-title{font-size:28rpx;font-weight:bold;color:#333;flex:1;}
.vc-link{font-size:25rpx;color:#e91e63;font-weight:600;}
.vc-status{font-size:25rpx;color:#4caf50;font-weight:600;}
.vc-body{padding:24rpx;text-align:center;}
.vc-tip{font-size:26rpx;color:#888;display:block;margin-bottom:20rpx;line-height:1.5;}
.vc-btn{background:linear-gradient(135deg,#2d1b2e,#4a3a5a);color:#fff;padding:22rpx 80rpx;border-radius:40rpx;font-size:29rpx;font-weight:bold;display:inline-block;}
.vc-btn-renew{background:linear-gradient(135deg,#ffc107,#ffb300);color:#333;}

/* 功能区 */
.func-section{margin:24rpx 20rpx 0;}
.fs-title{font-size:28rpx;font-weight:bold;color:#1a1a2e;display:block;margin-bottom:16rpx;padding-left:4rpx;}
.flist{background:#fff;border-radius:20rpx;overflow:hidden;box-shadow:0 2rpx 10rpx rgba(0,0,0,.03);}
.fi{display:flex;align-items:center;padding:26rpx 24rpx;border-bottom:1rpx solid #f8f6f3;}
.fi:last-child{border:none;}
.fi-icon{font-size:32rpx;width:48rpx;flex-shrink:0;}
.fi-text{flex:1;font-size:28rpx;color:#333;margin-left:16rpx;}
.fi-arrow{font-size:34rpx;color:#ccc;}
.fi-count{font-size:21rpx;color:#e91e63;background:#fce4ec;padding:2rpx 12rpx;border-radius:12rpx;margin-right:8rpx;}

.sbtm{height:30rpx;}
