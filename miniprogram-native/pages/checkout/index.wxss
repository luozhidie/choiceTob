page{background: var(--bg);}

/* 地址 */
.addr-sec{background:#fff;padding:24rpx 24rpx;display:flex;align-items:center;margin-bottom:12rpx;border-radius:0 0 16rpx 16rpx;box-shadow:0 2rpx 10rpx rgba(0,0,0,.04);}
.addr-icon{font-size:36rpx;margin-right:16rpx;}
.addr-info{flex:1;}
.addr-name{font-size:28rpx;font-weight:600;color:#1a1a2e;display:block;}
.addr-detail{font-size:24rpx;color:#888;display:block;margin-top:4rpx;line-height:1.4;}
.addr-tip{font-size:27rpx;color:#999;flex:1;}
.addr-arrow{font-size:30rpx;color:#ccc;}

/* 商品列表 */
.goods-sec{background:#fff;padding:0 24rpx;margin-bottom:12rpx;}
.gi{display:flex;padding:20rpx 0;border-bottom:1rpx solid #f5f2ef;}
.gi:last-child{border:none;}
.gi{width:140rpx;height:140rpx;border-radius:12rpx;background:#eee;flex-shrink:0;margin-right:16rpx;}
.gi-info{flex:1;display:flex;flex-direction:column;justify-content:space-between;}
.gi-name{font-size:27rpx;color:#333;font-weight:500;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;line-height:1.4;}
.gi-meta{display:flex;justify-content:space-between;align-items:baseline;}
.gi-price{font-size:30rpx;color:#2d1b2e;font-weight:700;}
.gi-qty{font-size:24rpx;color:#999;}

/* 备注 */
.remark-sec{background:#fff;padding:20rpx 24rpx;display:flex;align-items:center;margin-bottom:12rpx;}
.rl{font-size:27rpx;color:#333;font-weight:500;margin-right:16rpx;}
.ri{flex:1;height:72rpx;font-size:26rpx;color:#333;}

/* 费用 */
.fee-sec{background:#fff;padding:20rpx 24rpx;margin-bottom:12rpx;}
.fee-row{display:flex;justify-content:space-between;padding:10rpx 0;font-size:26rpx;color:#666;}
.fee-total{border-top:1rpx solid #f0ece8;padding-top:16rpx;margin-top:8rpx;}
.fee-num{font-size:34rpx;font-weight:800;color:#2d1b2e;}

/* 提交栏 */
.submit-bar{position:fixed;bottom:0;left:0;width:100%;background:#fff;display:flex;align-items:center;padding:16rpx 24rpx;box-shadow:0 -2rpx 12rpx rgba(0,0,0,.06);padding-bottom:env(safe-area-inset-bottom);z-index:50;}
.st-label{font-size:26rpx;color:#666;}
.st-total{font-size:36rpx;font-weight:800;color:#2d1b2e;margin-right:16rpx;}
.st-btn{background:linear-gradient(135deg,#2d1b2e,#4a3a4b);color:#fff;padding:20rpx 80rpx;border-radius:40rpx;font-size:29rpx;font-weight:700;}
