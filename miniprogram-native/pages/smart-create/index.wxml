<view class="sc-page">
  <!-- 步骤1：选图 -->
  <view class="sc-card">
    <view class="sc-card-title">① 选商品图（转发/相册里的供应商图，最多9张）</view>
    <view class="sc-imgs">
      <view class="sc-img" wx:for="{{images}}" wx:key="*this" wx:for-item="src">
        <image src="{{src}}" mode="aspectFill" bindtap="previewImg" data-src="{{src}}"/>
        <view class="sc-img-del" catchtap="removeImage" data-i="{{index}}">×</view>
      </view>
      <view class="sc-img sc-add" bindtap="chooseImages" wx:if="{{images.length<9}}">＋</view>
    </view>
    <textarea class="sc-note" placeholder="可选：粘贴供应商报价文字（如：棉麻连衣裙 批发68 零售139 均码 杏色）" value="{{note}}" bindinput="onNote"/>
  </view>

  <!-- 步骤2：识别 -->
  <button class="sc-btn sc-btn-primary" loading="{{extracting}}" bindtap="extract">
    {{extracting ? 'AI 识别中…' : 'AI 一键识别参数'}}
  </button>

  <!-- 步骤3：核对 -->
  <view class="sc-card" wx:if="{{product}}">
    <view class="sc-card-title">② 核对并修改（确认即上架）</view>

    <view class="sc-field">
      <text class="sc-label">标题</text>
      <input class="sc-input" value="{{product.title}}" data-field="title" bindinput="onField" placeholder="商品标题"/>
    </view>
    <view class="sc-field">
      <view class="sc-label-row">
        <text class="sc-label">品类</text>
        <text class="sc-custom-toggle" bindtap="toggleCategoryCustom">{{categoryCustomMode ? '选择预设' : '自定义'}}</text>
      </view>
      <block wx:if="{{categoryCustomMode}}">
        <input class="sc-input" value="{{product.category}}" bindinput="onCategoryCustomInput" placeholder="输入自定义品类"/>
      </block>
      <block wx:else>
        <picker mode="selector" range="{{categoryOptions}}" bindchange="onCategory">
          <view class="sc-input sc-picker">{{product.category || '选择品类'}}</view>
        </picker>
      </block>
    </view>
    <view class="sc-row">
      <view class="sc-field sc-half">
        <text class="sc-label">零售价(元)</text>
        <input class="sc-input" type="digit" value="{{product.price}}" data-field="price" bindinput="onField"/>
      </view>
      <view class="sc-field sc-half">
        <text class="sc-label">原价(划线参考)</text>
        <input class="sc-input" type="digit" value="{{product.original_price}}" data-field="original_price" bindinput="onField" placeholder="留空=同零售价"/>
      </view>
    </view>
    <view class="sc-row">
      <view class="sc-field sc-half">
        <text class="sc-label">批发价(元)</text>
        <input class="sc-input" type="digit" value="{{product.wholesale_price}}" data-field="wholesale_price" bindinput="onField"/>
      </view>
      <view class="sc-field sc-half">
        <text class="sc-label">成本价(元)</text>
        <input class="sc-input" type="digit" value="{{product.cost_price}}" data-field="cost_price" bindinput="onCostPrice" placeholder="输入自动换算"/>
      </view>
    </view>
    <view class="sc-row">
      <view class="sc-field sc-half">
        <text class="sc-label">5件起批(元)</text>
        <input class="sc-input" type="digit" value="{{product.bulk_price}}" data-field="bulk_price" bindinput="onField"/>
      </view>
    </view>

    <!-- 套装拆分价（上下装/两件套/三件套） -->
    <view class="sc-set">
      <view class="sc-set-head">
        <text class="sc-label">套装拆分价（上下装/两件套/三件套）</text>
        <text class="sc-set-add" bindtap="addSetItem">＋ 添加部件</text>
      </view>
      <view class="sc-set-item" wx:for="{{setItems}}" wx:key="index" wx:for-item="it">
        <input class="sc-set-name" placeholder="部件名 如 上衣" value="{{it.name}}" data-i="{{index}}" data-f="name" bindinput="onSetItem"/>
        <input class="sc-set-num" type="digit" placeholder="零售" value="{{it.retail}}" data-i="{{index}}" data-f="retail" bindinput="onSetItem"/>
        <input class="sc-set-num" type="digit" placeholder="批发" value="{{it.wholesale}}" data-i="{{index}}" data-f="wholesale" bindinput="onSetItem"/>
        <input class="sc-set-num" type="digit" placeholder="批量" value="{{it.bulk}}" data-i="{{index}}" data-f="bulk" bindinput="onSetItem"/>
        <input class="sc-set-num" type="digit" placeholder="成本" value="{{it.cost}}" data-i="{{index}}" data-f="cost" bindinput="onSetItem"/>
        <text class="sc-set-del" catchtap="removeSetItem" data-i="{{index}}">×</text>
      </view>
      <view class="sc-set-sum" wx:if="{{setItems.length}}">
        <text class="sc-set-sum-txt">合计：零售 ¥{{setSumR}} ／ 批发 ¥{{setSumW}} ／ 批量 ¥{{setSumB}} ／ 成本 ¥{{setSumC}}</text>
        <text class="sc-set-apply" bindtap="applySetTotal">填入总价</text>
      </view>
    </view>
    <view class="sc-row">
      <view class="sc-field sc-half">
        <text class="sc-label">尺码</text>
        <input class="sc-input" value="{{product.sizes}}" data-field="sizes" bindinput="onField" placeholder="S,M,L 或 均码"/>
      </view>
      <view class="sc-field sc-half">
        <text class="sc-label">颜色</text>
        <input class="sc-input" value="{{product.color}}" data-field="color" bindinput="onField" placeholder="黑,白,杏"/>
      </view>
    </view>
    <view class="sc-row">
      <view class="sc-field sc-half">
        <text class="sc-label">材质</text>
        <input class="sc-input" value="{{product.material}}" data-field="material" bindinput="onField" placeholder="棉/涤纶"/>
      </view>
      <view class="sc-field sc-half">
        <view class="sc-label-row">
          <text class="sc-label">季节</text>
          <text class="sc-custom-toggle" bindtap="toggleSeasonCustom">{{seasonCustomMode ? '选择预设' : '自定义'}}</text>
        </view>
        <block wx:if="{{seasonCustomMode}}">
          <input class="sc-input" value="{{product.season}}" bindinput="onSeasonCustomInput" placeholder="自定义季节"/>
        </block>
        <block wx:else>
          <picker mode="selector" range="{{seasonOptions}}" bindchange="onSeason">
            <view class="sc-input sc-picker">{{product.season || '选择季节'}}</view>
          </picker>
        </block>
      </view>
    </view>
    <view class="sc-field">
      <text class="sc-label">卖点</text>
      <input class="sc-input" value="{{product.description}}" data-field="description" bindinput="onField" placeholder="一句话卖点"/>
    </view>

    <!-- 模特图 -->
    <view class="sc-media">
      <view class="sc-label-row">
        <text class="sc-label">模特图（最多6张）</text>
        <text class="sc-custom-toggle" bindtap="chooseModelImages" wx:if="{{modelImages.length<6}}">＋ 选图</text>
      </view>
      <view class="sc-imgs">
        <view class="sc-img" wx:for="{{modelImages}}" wx:key="*this" wx:for-item="src">
          <image src="{{src}}" mode="aspectFill" data-src="{{src}}" bindtap="previewModel"/>
          <view class="sc-img-del" catchtap="removeModelImage" data-i="{{index}}">×</view>
        </view>
      </view>
    </view>

    <!-- 详情图 -->
    <view class="sc-media">
      <view class="sc-label-row">
        <text class="sc-label">详情图（最多15张，自动拼成详情页）</text>
        <text class="sc-custom-toggle" bindtap="chooseDetailImages" wx:if="{{detailImages.length<15}}">＋ 选图</text>
      </view>
      <view class="sc-imgs">
        <view class="sc-img" wx:for="{{detailImages}}" wx:key="*this" wx:for-item="src">
          <image src="{{src}}" mode="aspectFill" data-src="{{src}}" bindtap="previewDetail"/>
          <view class="sc-img-del" catchtap="removeDetailImage" data-i="{{index}}">×</view>
        </view>
      </view>
    </view>

    <!-- 展示视频 -->
    <view class="sc-media">
      <view class="sc-label-row">
        <text class="sc-label">展示视频（短视频，≤20MB）</text>
        <text class="sc-custom-toggle" bindtap="chooseVideo" wx:if="{{!videoPath}}">＋ 选视频</text>
      </view>
      <view class="sc-video-box" wx:if="{{videoPath}}">
        <video src="{{videoPath}}" class="sc-video" controls/>
        <view class="sc-img-del" catchtap="removeVideo">×</view>
      </view>
    </view>

    <view class="sc-actions">
      <button class="sc-btn sc-btn-ghost" loading="{{saving}}" bindtap="save" data-publish="0">存草稿</button>
      <button class="sc-btn sc-btn-primary" loading="{{saving}}" bindtap="save" data-publish="1">直接上架</button>
    </view>
  </view>

  <view class="sc-tip">原理：选图/转发供应商图 → AI 自动识别标题、品类、价格、尺码、材质 → 你只核对确认。</view>
</view>

<!-- toast -->
<view wx:if="{{toastText}}" class="sc-toast">{{toastText}}</view>
