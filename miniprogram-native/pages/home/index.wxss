/* ===== 全局变量 ===== */
page {
  background-color: #faf8f6;
  color: #1a1a2e;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', sans-serif;
}

/* ===== Hero 区域 ===== */
.hero {
  background: linear-gradient(135deg, #2d1b2e 0%, #4a3a4b 100%);
  padding: 60rpx 32rpx 40rpx 32rpx;
  position: relative;
  overflow: hidden;
}

/* 背景装饰 */
.hero::before {
  content: '';
  position: absolute;
  top: -80rpx;
  right: -80rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: rgba(232, 154, 172, 0.08);
}

.hero::after {
  content: '';
  position: absolute;
  bottom: -40rpx;
  left: -40rpx;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(184, 148, 90, 0.06);
}

.hero-badge {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(255,255,255,0.10);
  border: 1px solid rgba(255,255,255,0.15);
  font-size: 18rpx;
  color: rgba(255,255,255,0.7);
  font-weight: 500;
  letter-spacing: 2rpx;
  margin-bottom: 12rpx;
  position: relative;
  z-index: 1;
}

.hero-title {
  display: block;
  font-size: 44rpx;
  font-weight: 900;
  color: #fff;
  line-height: 1.25;
  letter-spacing: 2rpx;
  position: relative;
  z-index: 1;
  text-shadow: 0 4rpx 12rpx rgba(0,0,0,0.2);
}

.hero-accent {
  color: #e89aac;
}

.hero-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 8rpx;
  position: relative;
  z-index: 1;
}

/* ===== 搜索栏 ===== */
.search-bar {
  display: flex;
  align-items: center;
  margin-top: 28rpx;
  background: rgba(255,255,255,0.10);
  backdrop-filter: blur(10px);
  border-radius: 24rpx;
  padding: 8rpx 8rpx 8rpx 24rpx;
  border: 1px solid rgba(255,255,255,0.15);
  position: relative;
  z-index: 1;
}

.search-icon {
  font-size: 26rpx;
  color: rgba(255,255,255,0.35);
  margin-right: 12rpx;
}

.search-placeholder {
  flex: 1;
  font-size: 26rpx;
  color: rgba(255,255,255,0.4);
}

.search-btn {
  background: #fff;
  color: #333;
  font-size: 24rpx;
  font-weight: 600;
  padding: 14rpx 28rpx;
  border-radius: 20rpx;
  white-space: nowrap;
}

/* ===== 分类标签 ===== */
.tag-scroll {
  margin-top: 24rpx;
  white-space: nowrap;
  position: relative;
  z-index: 1;
}

.tag-row {
  display: inline-flex;
  gap: 12rpx;
}

.tag-item {
  display: inline-block;
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  white-space: nowrap;
  color: rgba(255,255,255,0.65);
  transition: all 0.25s ease;
  border: 1px solid transparent;
}

.tag-active {
  background: rgba(255,255,255,0.92);
  color: #333;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
}

/* ===== 功能入口卡片 ===== */
.func-card {
  display: flex;
  background: #fff;
  margin: -24rpx 24rpx 0 24rpx;
  border-radius: 24rpx;
  padding: 36rpx 20rpx;
  position: relative;
  z-index: 10;
  box-shadow: 0 4rpx 24rpx rgba(45, 27, 46, 0.06);
}

.func-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.func-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
}

.func-icon-buyer { background: linear-gradient(135deg, #fff5f0, #ffe8dc); }
.func-icon-course { background: linear-gradient(135deg, #f0f5ff, #dce8ff); }
.func-icon-look { background: linear-gradient(135deg, #fef5ff, #fce8ff); }
.func-icon-vip { background: linear-gradient(135deg, #fff9ec, #fff0cc); }

.func-label {
  font-size: 23rpx;
  color: #666;
  margin-top: 12rpx;
  font-weight: 500;
}

/* ===== 商品列表区 ===== */
.product-section {
  background: #fff;
  margin-top: 24rpx;
  padding: 36rpx 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.section-title-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.section-count {
  font-size: 24rpx;
  color: #aaa;
  font-weight: 400;
}

.clear-filter {
  font-size: 23rpx;
  color: #bbb;
  padding: 6rpx 16rpx;
}

/* ===== 骨架屏 ===== */
.product-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.skeleton-card {
  width: 47%;
  margin-bottom: 24rpx;
}

.skeleton-img {
  width: 100%;
  height: 340rpx;
  background: #f5f2ef;
  border-radius: 20rpx;
  animation: pulse 1.5s ease-in-out infinite;
}

.skeleton-line-long {
  width: 75%;
  height: 24rpx;
  background: #f5f2ef;
  border-radius: 8rpx;
  margin-top: 16rpx;
  animation: pulse 1.5s ease-in-out infinite;
}

.skeleton-line-short {
  width: 42%;
  height: 24rpx;
  background: #f5f2ef;
  border-radius: 8rpx;
  margin-top: 12rpx;
  animation: pulse 1.5s ease-in-out infinite;
  animation-delay: 0.2s;
}

@keyframes pulse {
  0% { opacity: 1; }
  50% { opacity: 0.45; }
  100% { opacity: 1; }
}

/* ===== 空状态 ===== */
.empty-state {
  text-align: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 90rpx;
  display: block;
  margin-bottom: 20rpx;
  filter: grayscale(1);
  opacity: 0.3;
}

.empty-text {
  font-size: 30rpx;
  color: #ccc;
  display: block;
  margin-bottom: 36rpx;
}

.empty-btn {
  display: inline-flex;
  align-items: center;
  padding: 22rpx 44rpx;
  background: linear-gradient(to right, #ff7a3d, #ff5722);
  color: #fff;
  font-size: 27rpx;
  font-weight: 700;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(255,87,34,0.25);
}

/* ===== 商品卡片 ===== */
.product-card {
  width: 47%;
  margin-bottom: 24rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background: #faf8f6;
}

.card-img-wrap {
  width: 100%;
  height: 340rpx;
  position: relative;
  overflow: hidden;
}

.card-img {
  width: 100%;
  height: 100%;
}

.card-img-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f0ede9;
}

.placeholder-text {
  font-size: 22rpx;
  color: #ccc;
}

.badge-hot {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  background: linear-gradient(135deg, #ff5722, #ff9800);
  color: #fff;
  font-size: 18rpx;
  font-weight: 700;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
}

.badge-new {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  background: linear-gradient(135deg, #e91e63, #c2185b);
  color: #fff;
  font-size: 18rpx;
  font-weight: 700;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
}

.card-info {
  padding: 18rpx 16rpx 20rpx;
}

.card-name {
  font-size: 25rpx;
  color: #333;
  font-weight: 500;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

.card-bottom {
  margin-top: 10rpx;
}

.card-price {
  font-size: 30rpx;
  color: #e91e63;
  font-weight: 800;
}

.card-btn {
  margin-top: 14rpx;
  text-align: center;
  padding: 12rpx 0;
  background: linear-gradient(to right, #ec4899, #ef4444);
  color: #fff;
  font-size: 23rpx;
  font-weight: 600;
  border-radius: 12rpx;
}

/* ===== 底部CTA ===== */
.bottom-cta {
  text-align: center;
  padding: 56rpx 32rpx 48rpx;
  background: transparent;
}

.cta-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #2d1b2e;
  letter-spacing: 2rpx;
}

.cta-subtitle {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
  letter-spacing: 4rpx;
  font-weight: 300;
}

.cta-buttons {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-top: 36rpx;
}

.cta-btn {
  padding: 20rpx 48rpx;
  border-radius: 16rpx;
  font-size: 27rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.cta-btn-primary {
  background: #fff;
  color: #333;
  box-shadow: 0 8rpx 28rpx rgba(0,0,0,0.08);
}

.cta-btn-outline {
  background: transparent;
  color: #fff;
  border: 2px solid rgba(255,255,255,0.5);
  /* 小程序不支持transparent背景上的边框，改用深色背景模拟 */
  background: rgba(45, 27, 46, 0.3);
}

.safe-bottom {
  height: 120rpx;
}
