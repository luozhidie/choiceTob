page { background: #faf8f6; color: #1a1a2e; font-family: -apple-system,BlinkMacSystemFont,'Segoe UI','PingFang SC','Hiragino Sans GB',sans-serif; }
/* 导航栏 */
.nav { display:flex; justify-content:space-between; align-items:center; padding:14rpx 28rpx; background:#fff; z-index:50; position:relative; }
.brand{display:flex;align-items:center;gap:14rpx;}
.bicon{width:62rpx;height:62rpx;background:linear-gradient(135deg,#2d1b2e,#4a3a4b);color:#fff;font-size:25rpx;font-weight:800;display:flex;align-items:center;justify-content:center;border-radius:16rpx;}
.bt{display:flex;flex-direction:column;}
.bn{font-size:28rpx;font-weight:700;color:#1a1a2e;line-height:1.25;}
.bs{font-size:17rpx;color:#aaa;letter-spacing:3rpx;}
.ham{width:54rpx;height:44rpx;display:flex;flex-direction:column;justify-content:center;gap:9rpx;padding:8rpx;}
.ham .l{width:32rpx;height:3rpx;background:#333;border-radius:3rpx;transition:all .3s;}
.ham.on .l:nth-child(1){transform:rotate(45deg) translate(7rpx,7rpx);}
.ham.on .l:nth-child(2){opacity:0;}
.ham.on .l:nth-child(3){transform:rotate(-45deg) translate(7rpx,-7rpx);}

/* Hero大图 */
.hero{position:relative;width:100%;height:calc(100vh - 96rpx);overflow:hidden;}
.sw{width:100%;height:100%;}
.si{width:100%;height:100%;}
.ph{width:100%;height:100%;background:radial-gradient(ellipse at 22% 42%, rgba(232,154,172,.18), transparent 55%), radial-gradient(ellipse at 78% 30%, rgba(184,148,90,.12), transparent 50%), linear-gradient(160deg,#1a1225,#2d1b2e 35%,#5a4055 72%,#7a6078);}
/* 叠加层 - 全部内容靠上 */
.ov{position:absolute;top:0;left:0;right:0;bottom:0;display:flex;flex-direction:column;padding:24rpx 28rpx;z-index:4;}

/* 上部：标题 - 靠顶部 */
.top-txt{margin-top:16rpx;}
.badge{display:inline-block;padding:6rpx 18rpx;border-radius:22rpx;background:rgba(255,255,255,.15);backdrop-filter:blur(10px);border:1rpx solid rgba(255,255,255,.2);font-size:19rpx;color:rgba(255,255,255,.75);font-weight:500;letter-spacing:3rpx;margin-bottom:14rpx;}
.mt{display:block;font-size:46rpx;font-weight:900;color:#fff;line-height:1.3;letter-spacing:2rpx;text-shadow:0 4rpx 20rpx rgba(0,0,0,.45);}
.ma{color:#f0a0c0;}
.st{display:block;font-size:26rpx;color:rgba(255,255,255,.72);margin-top:8rpx;letter-spacing:1rpx;}

/* 下部：标签白底条 */
.bot-area{}

/* 白底条 */
.tg-bar{}

/* 标签 - 直接浮在图上 */
.tg-row{display:flex;gap:14rpx;justify-content:flex-start;flex-wrap:nowrap;padding:0 4rpx;}
.tg{padding:12rpx 28rpx;border-radius:32rpx;font-size:24rpx;white-space:nowrap;color:rgba(255,255,255,.9);background:rgba(0,0,0,.25);backdrop-filter:blur(6px);border:1rpx solid rgba(255,255,255,.15);transition:all .2s;font-weight:500;}
.tg-on{color:#fff;background:#1a1a2e;border-color:#fff;font-weight:700;}

/* 搜索栏 */
.srch{display:flex;align-items:center;background:rgba(255,255,255,.92);backdrop-filter:blur(14px);border-radius:26rpx;padding:8rpx 8rpx 8rpx 24rpx;box-shadow:0 8rpx 36rpx rgba(0,0,0,.13);}
.sri{font-size:27rpx;margin-right:12rpx;}
.srp{flex:1;font-size:26rpx;color:#bbb;}
.srb{background:linear-gradient(135deg,#2d1b2e,#4a3a4b);color:#fff;font-size:24rpx;font-weight:600;padding:17rpx 30rpx;border-radius:20rpx;white-space:nowrap;}

/* 底部渐变 */
.fade{position:absolute;bottom:0;left:0;right:0;height:120rpx;background:linear-gradient(to top,#faf8f6 0%,transparent 100%);pointer-events:none;z-index:3;}

/* 菜单 */
.mk{position:fixed;top:0;left:0;right:0;bottom:0;background:transparent;z-index:99;opacity:0;visibility:hidden;transition:all .3s;}
.mk.show{background:rgba(0,0,0,.45);opacity:1;visibility:visible;}
.mp{position:absolute;top:0;right:0;width:70%;max-width:520rpx;height:100%;background:#fff;transform:translateX(100%);transition:transform .35s cubic-bezier(.4,0,.2,1);box-shadow:-8rpx 0 40rpx rgba(0,0,0,.15);display:flex;flex-direction:column;}
.mp.in{transform:translateX(0);}
.mph{display:flex;justify-content:space-between;align-items:center;padding:52rpx 32rpx 24rpx;border-bottom:1rpx solid #f0ede9;}
.mpb{font-size:31rpx;font-weight:800;color:#1a1a2e;}
.mpc{width:56rpx;height:56rpx;display:flex;align-items:center;justify-content:center;background:#f5f2ef;border-radius:50%;font-size:26rpx;color:#888;}
.mpb2{flex:1;overflow:hidden;padding:8rpx 0;}
.mi{display:flex;align-items:center;gap:16rpx;padding:26rpx 36rpx;font-size:29rpx;color:#333;font-weight:500;}
.mi:active{background:#f8f7f4;}
.mdv{height:1rpx;background:#f0ede9;margin:6rpx 32rpx;}
.mpf{padding:24rpx 32rpx;border-top:1rpx solid #f0ede9;}
.mu{font-size:25rpx;color:#999;display:block;margin-bottom:12rpx;}
.mlg{display:inline-block;padding:13rpx 34rpx;background:linear-gradient(to right,#2d1b2e,#4a3a4b);color:#fff;font-size:25rpx;font-weight:600;border-radius:20rpx;}

/* 商品区 */
.sec{background:#fff;padding:32rpx 24rpx;border-radius:28rpx 28rpx 0 0;margin-top:-20rpx;position:relative;z-index:6;}
.sh{display:flex;align-items:baseline;gap:10rpx;margin-bottom:24rpx;flex-wrap:wrap;}
.stt{font-size:32rpx;font-weight:700;color:#1a1a2e;}
.stc{font-size:23rpx;color:#bbb;}
.clr{font-size:23rpx;color:#bbb;padding:5rpx 14rpx;margin-left:auto;}
.gd{display:flex;flex-wrap:wrap;justify-content:space-between;}
/*骨架屏*/
.sc{width:47%;margin-bottom:22rpx;}
.sci{width:100%;height:320rpx;background:#f5f2ef;border-radius:18rpx;animation:pulse 1.5s infinite;}
.sl1{width:70%;height:22rpx;background:#f5f2ef;border-radius:8rpx;margin-top:14rpx;animation:pulse 1.5s infinite;}
.sl2{width:40%;height:20rpx;background:#f5f2ef;border-radius:8rpx;margin-top:10rpx;animation:pulse 1.5s infinite .15s;}
@keyframes pulse{0%{opacity:1}50%{opacity:.4}100%{opacity:1}}
/*空状态*/
.emp{text-align:center;padding:80rpx 0;}
.ei{font-size:88rpx;filter:grayscale(1);opacity:.25;display:block;margin-bottom:14rpx;}
.et{font-size:28rpx;color:#ccc;display:block;margin-bottom:30rpx;}
.eb{display:inline-block;padding:20rpx 44rpx;background:linear-gradient(to right,#ff7a3d,#ff5722);color:#fff;font-size:26rpx;font-weight:700;border-radius:20rpx;box-shadow:0 8rpx 22rpx rgba(255,87,34,.22);}
/*商品卡片*/
.cd{width:47%;margin-bottom:22rpx;border-radius:18rpx;overflow:hidden;background:#faf8f6;}
.cw{width:100%;height:320rpx;position:relative;overflow:hidden;}
.ci{width:100%;height:100%;}
.cp{width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:#f0ede9;}
.cpt{font-size:21rpx;color:#ccc;}
.bh{position:absolute;top:10rpx;left:10rpx;background:linear-gradient(135deg,#ff5722,#ff9800);color:#fff;font-size:17rpx;font-weight:700;padding:4rpx 13rpx;border-radius:8rpx;}
.bn{position:absolute;top:10rpx;left:10rpx;background:linear-gradient(135deg,#e91e63,#c2185b);color:#fff;font-size:17rpx;font-weight:700;padding:4px 13rpx;border-radius:8rpx;}
.cnf{padding:16rpx 14rpx 18rpx;}
.cnm{font-size:24rpx;color:#333;font-weight:500;line-height:1.38;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;}
.cnp{font-size:28rpx;color:#e91e63;font-weight:800;display:block;margin-top:8rpx;}
.cbn{margin-top:12rpx;text-align:center;padding:12rpx 0;background:linear-gradient(to right,#ec4899,#ef4444);color:#fff;font-size:23rpx;font-weight:600;border-radius:10rpx;}
/*CTA*/
.cta{padding:20rpx 0 0 0;}
.cbx{margin:0 24rpx;height:280rpx;border-radius:22rpx;position:relative;overflow:hidden;}
.cbg{position:absolute;top:0;left:0;right:0;bottom:0;background:radial-gradient(ellipse at 68% 38%, rgba(196,69,105,.07), transparent 58%),radial-gradient(ellipse at 22% 68%, rgba(184,148,90,.05), transparent 52%), linear-gradient(145deg,#faf5f0,#efe6dc);}
.cbg::before{content:'';position:absolute;top:-50rpx;right:-30rpx;width:220rpx;height:220rpx;border-radius:50%;background:rgba(232,154,172,.05);}
.cbg::after{content:'';position:absolute;bottom:-24rpx;left:-24rpx;width:140rpx;height:140rpx;border-radius:50%;background:rgba(184,148,90,.04);}
.cin{position:relative;z-index:2;text-align:center;padding-top:56rpx;}
.ctt{display:block;font-size:36rpx;font-weight:800;color:#2d1b2e;letter-spacing:2rpx;}
.cts{display:block;font-size:23rpx;color:#999;margin-top:6rpx;letter-spacing:4rpx;}
.cr{display:flex;justify-content:center;gap:18rpx;margin-top:28rpx;}
.c1{padding:18rpx 44rpx;border-radius:16rpx;font-size:26rpx;font-weight:700;background:#fff;color:#333;box-shadow:0 6rpx 22rpx rgba(0,0,0,.06);}
.c2{padding:18rpx 44rpx;border-radius:16rpx;font-size:26rpx;font-weight:700;background:rgba(45,27,46,.03);color:#333;border:2rpx solid rgba(45,27,46,.1);}
.sbtm{height:110rpx;}

/* ========== 动态模块样式 ========== */
.blk{min-height:1rpx;}

/* featured_banner 精选横幅(大图+3小图) */
.fb-wrap{padding:0 24rpx;}
.fb-main{width:100%;height:380rpx;border-radius:20rpx;overflow:hidden;position:relative;margin-bottom:12rpx;}
.fb-img{width:100%;height:100%;}
.fb-ov{position:absolute;bottom:16rpx;right:16rpx;background:rgba(0,0,0,.5);color:#fff;padding:8rpx 22rpx;border-radius:14rpx;font-size:21rpx;}
.fb-tap{font-weight:600;}
.fb-subs{display:flex;gap:10rpx;}
.fb-sub{flex:1;border-radius:14rpx;overflow:hidden;position:relative;}
.fb-si{width:100%;height:160rpx;}
.fb-st{position:absolute;bottom:6rpx;left:8rpx;right:8rpx;background:rgba(255,255,255,.92);border-radius:10rpx;padding:4rpx 10rpx;display:flex;justify-content:space-between;}
.fb-sn{font-size:19rpx;color:#333;font-weight:600;}
.fb-sp{font-size:18rpx;color:#e91e63;font-weight:700;}

/* banner_large 大横幅 */
.bl-wrap{margin:0 24rpx;border-radius:20rpx;overflow:hidden;}
.bl-img{width:100%;height:300rpx;}
.bl-bg{width:100%;height:240rpx;background:linear-gradient(135deg,#2d1b2e,#6b3f70);display:flex;flex-direction:column;align-items:center;justify-content:center;padding:30rpx;}
.bl-title{font-size:36rpx;font-weight:bold;color:#fff;text-align:center;line-height:1.4;}
.bl-sub{font-size:23rpx;color:rgba(255,255,255,.75);margin-top:8rpx;}

/* banner_small 小横幅 */
.bs-wrap{margin:0 24rpx;border-radius:14rpx;overflow:hidden;background:#fff9ed;border:1rpx solid #ffe082;}
.bs-img{width:100%;}
.bs-bar{padding:14rpx 20rpx;display:flex;align-items:center;gap:10rpx;}
.bs-title{font-size:25rpx;font-weight:700;color:#f57c00;}

/* category_nav 分类目录 */
.cn-wrap{padding:8rpx 0 4rpx;}
.cn-scroll{white-space:nowrap;}
.cn-row{display:inline-flex;gap:8rpx;padding:0 20rpx;}
.cn-tab{padding:14rpx 26rpx;border-radius:28rpx;font-size:24rpx;white-space:nowrap;background:#f5f2ef;color:#666;font-weight:500;transition:all .2s;}
.cn-on{background:#2d1b2e;color:#fff;font-weight:700;}

/* card_single 单格卡片 */
.cs-wrap{margin:0 24rpx;border-radius:20rpx;overflow:hidden;box-shadow:0 4rpx 20rpx rgba(0,0,0,.06);background:#fff;}
.cs-img{width:100%;height:260rpx;}
.cs-body{padding:22rpx 24rpx;}
.cs-title{font-size:29rpx;font-weight:bold;color:#333;display:block;margin-bottom:6rpx;}
.cs-sub{font-size:22rpx;color:#999;display:block;margin-bottom:14rpx;}
.cs-btn{display:inline-block;padding:12rpx 32rpx;background:linear-gradient(135deg,#2d1b2e,#4a3a4b);color:#fff;font-size:24rpx;font-weight:600;border-radius:14rpx;}

/* card_quad 四宫格 */
.cq-wrap{padding:0 24rpx;}
.cq-row{display:flex;gap:12rpx;}
.cq-card{flex:1;border-radius:16rpx;overflow:hidden;background:#fff;box-shadow:0 2rpx 12rpx rgba(0,0,0,.05);}
.cq-img{width:100%;height:140rpx;}
.cq-title{font-size:22rpx;font-weight:600;color:#333;display:block;padding:8rpx 10rpx 2rpx;text-align:center;}
.cq-sub{font-size:18rpx;color:#aaa;display:block;padding:0 10rpx 10rpx;text-align:center;}

/* circle_row 圆形卡片行 */
.cr-wrap{padding:16rpx 0 8rpx;}
.cr-scroll{white-space:nowrap;}
.cr-row{display:inline-flex;gap:24rpx;padding:0 20rpx 10rpx;}
.cr-item{display:flex;flex-direction:column;align-items:center;width:120rpx;flex-shrink:0;}
.cr-icon{width:90rpx;height:90rpx;border-radius:50%;background:#f5f2ef;}
.cr-label{font-size:21rpx;color:#555;margin-top:8rpx;font-weight:500;}

/* promotion 营销活动 */
.pm-wrap{margin:0 24rpx;border-radius:18rpx;overflow:hidden;background:linear-gradient(135deg,#fce4ec,#f8bbd0);}
.pm-img{width:100%;}
.pm-body{padding:24rpx;}
.pm-title{font-size:30rpx;font-weight:bold;color:#c2185b;display:block;margin-bottom:6rpx;}
.pm-desc{font-size:23rpx;color:#555;display:block;margin-bottom:16rpx;line-height:1.5;}
.pm-btn{display:inline-block;padding:14rpx 40rpx;background:#e91e63;color:#fff;font-size:26rpx;font-weight:700;border-radius:16rpx;}

/* group_buy 团购拼单 */
.gb-wrap{margin:0 24rpx;border-radius:18rpx;background:linear-gradient(135deg,#fff3e0,#ffe0b2);padding:24rpx;display:flex;align-items:center;gap:16rpx;}
.gb-tag{background:#ff9800;color:#fff;padding:6rpx 18rpx;border-radius:10rpx;font-size:21rpx;font-weight:700;}
.gb-desc{font-size:25rpx;color:#e65100;font-weight:600;}
.gb-info{margin-left:auto;font-size:22rpx;color:#ef6c00;}

/* flash_sale 秒杀 */
.fs-wrap{margin:0 24rpx;border-radius:18rpx;background:linear-gradient(135deg,#fce4ec,#ffcdd2);padding:24rpx;display:flex;align-items:center;gap:16rpx;}
.fs-tag{background:#e91e63;color:#fff;padding:6rpx 18rpx;border-radius:10rpx;font-size:21rpx;font-weight:700;}
.fs-desc{font-size:25rpx;color:#c2185b;font-weight:600;}
.fs-info{margin-left:auto;font-size:22rpx;color:#ad1457;}

/* 商品上方模块缩略版 */
.blk-pt{padding:12rpx 0 !important;}
.fbs-img{width:100%;height:200rpx;border-radius:16rpx;}
