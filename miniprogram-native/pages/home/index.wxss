page { background: #faf8f6; color: #1a1a2e; font-family: -apple-system,BlinkMacSystemFont,'Segoe UI','PingFang SC','Hiragino Sans GB',sans-serif; }

/* ===== 导航栏 ===== */
.nav-bar {
  display: flex; justify-content: space-between; align-items: center;
  padding: 16rpx 28rpx;
  background: #fff; position: sticky; top: 0; z-index: 50;
}
.brand { display: flex; align-items: center; gap: 14rpx; }
.brand-icon {
  width: 64rpx; height: 64rpx;
  background: linear-gradient(135deg, #2d1b2e, #4a3a4b);
  color: #fff; font-size: 26rpx; font-weight: 800;
  display: flex; align-items: center; justify-content: center;
  border-radius: 16rpx; letter-spacing: 1rpx;
}
.brand-texts { display: flex; flex-direction: column; }
.brand-name { font-size: 29rpx; font-weight: 700; color: #1a1a2e; line-height: 1.25; }
.brand-sub { font-size: 18rpx; color: #aaa; letter-spacing: 3rpx; }

.hamburger {
  width: 56rpx; height: 48rpx;
  display: flex; flex-direction: column; justify-content: center; gap: 9rpx;
  padding: 8rpx;
}
.hamburger .bar { width: 34rpx; height: 3rpx; background: #333; border-radius: 4rpx; transition: all 0.3s ease; }
.hamburger.open .bar:nth-child(1) { transform: rotate(45deg) translate(7rpx, 7rpx); }
.hamburger.open .bar:nth-child(2) { opacity: 0; }
.hamburger.open .bar:nth-child(3) { transform: rotate(-45deg) translate(7rpx, -7rpx); }

/* ===== 分类标签（顶部紧贴导航栏）===== */
.top-tags-scroll {
  background: #fff;
  white-space: nowrap;
  border-bottom: 1rpx solid #f0ede9;
}
.tag-row-top {
  display: inline-flex;
  gap: 12rpx;
  padding: 18rpx 24rpx;
}
.tag-item-top {
  display: inline-block;
  padding: 10rpx 26rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  white-space: nowrap;
  color: #666;
  background: #f5f2ef;
  transition: all 0.2s;
}
.tag-active {
  background: #2d1b2e;
  color: #fff;
  font-weight: 600;
}

/* ===== 搜索栏 ===== */
.search-wrap {
  padding: 20rpx 24rpx;
  background: #fff;
}
.search-bar {
  display: flex; align-items: center;
  background: #f5f2ef;
  border-radius: 24rpx;
  padding: 8rpx 8rpx 8rpx 24rpx;
}
.search-icon { font-size: 27rpx; margin-right: 12rpx; }
.search-placeholder { flex: 1; font-size: 26rpx; color: #bbb; }
.search-btn {
  background: linear-gradient(135deg, #2d1b2e, #4a3a4b);
  color: #fff; font-size: 24rpx; font-weight: 600;
  padding: 17rpx 30rpx; border-radius: 20rpx;
  white-space: nowrap;
}

/* ===== 大图Banner区域 ===== */
.banner-area {
  position: relative;
  width: 100%;
  /* 填满搜索栏以下剩余空间 */
  height: calc(100vh - 280rpx);
  overflow: hidden;
}

.banner-swiper { width: 100%; height: 100%; }
.banner-img { width: 100%; height: 100%; }

.banner-placeholder {
  width: 100%; height: 100%;
  background:
    radial-gradient(ellipse at 25% 45%, rgba(232,154,172,0.18), transparent 55%),
    radial-gradient(ellipse at 75% 35%, rgba(184,148,90,0.12), transparent 50%),
    linear-gradient(160deg, #1a1225, #2d1b2e 40%, #5a4055 80%, #7a6078);
}

/* 指示点 */
.dots-wrap {
  position: absolute; bottom: 180rpx; left: 50%;
  transform: translateX(-50%); display: flex; gap: 10rpx; z-index: 3;
}
.dot {
  width: 11rpx; height: 11rpx; border-radius: 50%;
  background: rgba(255,255,255,0.35); transition: all 0.3s;
}
.dot-active { width: 26rpx; border-radius: 6rpx; background: #fff; }

/* 文字覆盖层（在图上，偏上位置） */
.banner-overlay {
  position: absolute;
  top: 80rpx; left: 32rpx; right: 32rpx;
  z-index: 3;
}

.badge-pill {
  display: inline-block; padding: 6rpx 18rpx;
  border-radius: 22rpx;
  background: rgba(255,255,255,0.15);
  backdrop-filter: blur(10px);
  border: 1rpx solid rgba(255,255,255,0.2);
  font-size: 19rpx; color: rgba(255,255,255,0.75);
  font-weight: 500; letter-spacing: 3rpx;
  margin-bottom: 14rpx;
}

.overlay-title {
  display: block;
  font-size: 46rpx; font-weight: 900; color: #fff;
  line-height: 1.3; letter-spacing: 2rpx;
  text-shadow: 0 4rpx 20rpx rgba(0,0,0,0.45);
}
.title-accent { color: #f0a0c0; }
.overlay-sub {
  display: block; font-size: 26rpx;
  color: rgba(255,255,255,0.72); margin-top: 8rpx;
  letter-spacing: 1rpx;
}

/* 底部渐变衔接 */
.banner-bottom-fade {
  position: absolute; bottom: 0; left: 0; right: 0; height: 120rpx;
  background: linear-gradient(to top, #faf8f6 0%, transparent 100%);
  pointer-events: none; z-index: 2;
}

/* ===== 汉堡菜单面板 ===== */
.menu-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: transparent;
  z-index: 99; opacity: 0; visibility: hidden;
  transition: all 0.3s ease;
}
.menu-mask.show { background: rgba(0,0,0,0.4); opacity: 1; visibility: visible; }

.menu-panel {
  position: absolute; top: 0; right: 0;
  width: 70%; max-width: 520rpx; height: 100%;
  background: #fff;
  transform: translateX(100%);
  transition: transform 0.35s cubic-bezier(0.4,0,0.2,1);
  box-shadow: -8rpx 0 40rpx rgba(0,0,0,0.15);
  display: flex; flex-direction: column;
}
.menu-panel.in { transform: translateX(0); }

.panel-head {
  display: flex; justify-content: space-between; align-items: center;
  padding: 52rpx 32rpx 24rpx;
  border-bottom: 1rpx solid #f0ede9;
}
.panel-brand { font-size: 31rpx; font-weight: 800; color: #1a1a2e; }
.panel-close {
  width: 56rpx; height: 56rpx; display: flex;
  align-items: center; justify-content: center;
  background: #f5f2ef; border-radius: 50%;
  font-size: 26rpx; color: #888;
}
.panel-body { flex: 1; overflow: hidden; padding: 8rpx 0; }
.m-link {
  display: flex; align-items: center; gap: 16rpx;
  padding: 26rpx 36rpx; font-size: 29rpx; color: #333; font-weight: 500;
  transition: background 0.15s;
}
.m-link:active { background: #f8f7f4; }
.m-e { font-size: 32rpx; width: 42rpx; text-align: center; }
.m-line { height: 1rpx; background: #f0ede9; margin: 6rpx 32rpx; }

.panel-foot {
  padding: 24rpx 32rpx; border-top: 1rpx solid #f0ede9;
}
.p-user { font-size: 25rpx; color: #999; display: block; margin-bottom: 12rpx; }
.p-login {
  display: inline-block; padding: 13rpx 34rpx;
  background: linear-gradient(to right,#2d1b2e,#4a3a4b);
  color: #fff; font-size: 25rpx; font-weight: 600; border-radius: 20rpx;
}

/* ===== 商品区 ===== */
.product-section {
  background: #fff; padding: 32rpx 24rpx;
  border-radius: 28rpx 28rpx 0 0; margin-top: -20rpx;
  position: relative; z-index: 6;
}
.sec-head { display: flex; align-items: baseline; gap: 10rpx; margin-bottom: 24rpx; flex-wrap: wrap; }
.sec-title { font-size: 32rpx; font-weight: 700; color: #1a1a2e; }
.sec-count { font-size: 23rpx; color: #bbb; }
.sec-clear { font-size: 23rpx; color: #bbb; padding: 5rpx 14rpx; margin-left: auto; }

.grid { display: flex; flex-wrap: wrap; justify-content: space-between; }

/* 骨架屏 */
.sk-card { width: 47%; margin-bottom: 22rpx; }
.sk-img { width: 100%; height: 320rpx; background: #f5f2ef; border-radius: 18rpx; animation: pulse 1.5s infinite; }
.sk-l1 { width: 70%; height: 22rpx; background: #f5f2ef; border-radius: 8rpx; margin-top: 14rpx; animation: pulse 1.5s infinite; }
.sk-l2 { width: 40%; height: 20rpx; background: #f5f2ef; border-radius: 8rpx; margin-top: 10rpx; animation: pulse 1.5s infinite 0.15s; }
@keyframes pulse { 0%{opacity:1}50%{opacity:0.4}100%{opacity:1} }

/* 空状态 */
.empty-box { text-align: center; padding: 80rpx 0; }
.empty-icon { font-size: 88rpx; filter: grayscale(1); opacity: 0.25; display: block; margin-bottom: 14rpx; }
.empty-txt { font-size: 28rpx; color: #ccc; display: block; margin-bottom: 30rpx; }
.empty-btn {
  display: inline-block; padding: 20rpx 44rpx;
  background: linear-gradient(to right,#ff7a3d,#ff5722);
  color: #fff; font-size: 26rpx; font-weight: 700; border-radius: 20rpx;
  box-shadow: 0 8rpx 22rpx rgba(255,87,34,0.22);
}

/* 商品卡片 */
.card { width: 47%; margin-bottom: 22rpx; border-radius: 18rpx; overflow: hidden; background: #faf8f6; }
.c-img-w { width: 100%; height: 320rpx; position: relative; overflow: hidden; }
.c-img { width: 100%; height: 100%; }
.c-img-ph { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: #f0ede9; }
.ph-t { font-size: 21rpx; color: #ccc; }
.bd-hot { position: absolute; top: 10rpx; left: 10rpx; background: linear-gradient(135deg,#ff5722,#ff9800); color: #fff; font-size: 17rpx; font-weight: 700; padding: 4rpx 13rpx; border-radius: 8rpx; }
.bd-new { position: absolute; top: 10rpx; left: 10rpx; background: linear-gradient(135deg,#e91e63,#c2185b); color: #fff; font-size: 17rpx; font-weight: 700; padding: 4rpx 13rpx; border-radius: 8rpx; }
.c-info { padding: 16rpx 14rpx 18rpx; }
.c-name { font-size: 24rpx; color: #333; font-weight: 500; line-height: 1.38; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.c-price { font-size: 28rpx; color: #e91e63; font-weight: 800; display: block; margin-top: 8rpx; }
.c-btn { margin-top: 12rpx; text-align: center; padding: 12rpx 0; background: linear-gradient(to right,#ec4899,#ef4444); color: #fff; font-size: 23rpx; font-weight: 600; border-radius: 10rpx; }

/* ===== 底部CTA大图 ===== */
.cta-area { padding: 20rpx 0 0 0; }
.cta-box { margin: 0 24rpx; height: 280rpx; border-radius: 22rpx; position: relative; overflow: hidden; }
.cta-bg {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  background: radial-gradient(ellipse at 68% 38%, rgba(196,69,105,0.07), transparent 58%), radial-gradient(ellipse at 22% 68%, rgba(184,148,90,0.05), transparent 52%), linear-gradient(145deg, #faf5f0, #efe6dc);
}
.cta-bg::before { content:''; position:absolute; top:-50rpx; right:-30rpx; width:220rpx;height:220rpx;border-radius:50%;background:rgba(232,154,172,0.05); }
.cta-bg::after { content:''; position:absolute; bottom:-24rpx;left:-24rpx; width:140rpx;height:140rpx;border-radius:50%;background:rgba(184,148,90,0.04); }
.cta-inner { position:relative;z-index:2;text-align:center;padding-top:56rpx; }
.cta-t { display:block; font-size:36rpx;font-weight:800;color:#2d1b2e;letter-spacing:2rpx; }
.cta-s { display:block; font-size:23rpx;color:#999;margin-top:6rpx;letter-spacing:4rpx; }
.cta-row { display:flex;justify-content:center;gap:18rpx;margin-top:28rpx; }
.cta-b { padding:18rpx 44rpx;border-radius:16rpx;font-size:26rpx;font-weight:700; }
.cta-b1 { background:#fff;color:#333;box-shadow:0 6rpx 22rpx rgba(0,0,0,0.06); }
.cta-b2 { background:rgba(45,27,46,0.03);color:#333;border:2rpx solid rgba(45,27,46,0.1); }

.safe-bottom { height:110rpx; }
