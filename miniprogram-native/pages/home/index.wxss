/* ===== 全局变量 ===== */
page {
  background-color: #faf8f6;
  color: #1a1a2e;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', sans-serif;
}

/* ===== 大屏轮播Banner ===== */
.hero-swiper {
  width: 100%;
  height: 520rpx;
}

.banner-img {
  width: 100%;
  height: 100%;
}

/* 默认占位Banner背景（无图片时的渐变+图案） */
.banner-default {
  width: 100%;
  height: 100%;
  position: relative;
  overflow: hidden;
}

.default-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background:
    radial-gradient(ellipse at 20% 50%, rgba(232,154,172,0.15) 0%, transparent 60%),
    radial-gradient(ellipse at 80% 30%, rgba(184,148,90,0.12) 0%, transparent 55%),
    radial-gradient(ellipse at 50% 80%, rgba(196,69,105,0.08) 0%, transparent 50%),
    linear-gradient(135deg, #2d1b2e 0%, #3d2538 40%, #5a3f52 80%, #7a5870 100%);
}

.default-bg::before {
  content: '';
  position: absolute;
  bottom: 10%;
  right: 5%;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.04);
}

.default-bg::after {
  content: '';
  position: absolute;
  top: 15%;
  left: 8%;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(184,148,90,0.08);
}

/* Banner文字覆盖层 */
.banner-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 48rpx 36rpx;
  z-index: 2;
}

.banner-badge {
  display: inline-block;
  padding: 6rpx 18rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.12);
  backdrop-filter: blur(8px);
  border: 1rpx solid rgba(255,255,255,0.18);
  font-size: 19rpx;
  color: rgba(255,255,255,0.75);
  font-weight: 500;
  letter-spacing: 3rpx;
  margin-bottom: 14rpx;
  align-self: flex-start;
}

.banner-title {
  font-size: 46rpx;
  font-weight: 900;
  color: #fff;
  line-height: 1.3;
  letter-spacing: 2rpx;
  text-shadow: 0 4rpx 16rpx rgba(0,0,0,0.35);
}

.banner-accent {
  color: #e89aac;
}

.banner-subtitle {
  font-size: 27rpx;
  color: rgba(255,255,255,0.72);
  margin-top: 10rpx;
  letter-spacing: 1rpx;
}

/* ===== 搜索栏（悬浮） ===== */
.search-bar-wrap {
  padding: 0 28rpx;
  margin-top: -28rpx;
  position: relative;
  z-index: 10;
}

.search-bar {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(12px);
  border-radius: 24rpx;
  padding: 8rpx 8rpx 8rpx 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(45,27,46,0.12);
}

.search-icon { font-size: 28rpx; color: #bbb; margin-right: 12rpx; }
.search-placeholder { flex: 1; font-size: 27rpx; color: #aaa; }
.search-btn {
  background: linear-gradient(135deg, #2d1b2e, #4a3a4b);
  color: #fff;
  font-size: 25rpx;
  font-weight: 600;
  padding: 16rpx 30rpx;
  border-radius: 20rpx;
  white-space: nowrap;
}

/* ===== 分类标签 ===== */
.tag-scroll { background: transparent; white-space: nowrap; padding: 20rpx 0 4rpx; }
.tag-row {
  display: inline-flex;
  padding: 0 28rpx;
  gap: 14rpx;
}
.tag-item {
  display: inline-block;
  padding: 12rpx 26rpx;
  border-radius: 32rpx;
  font-size: 25rpx;
  white-space: nowrap;
  color: #666;
  transition: all 0.25s ease;
  background: #fff;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.04);
}
.tag-active {
  background: #2d1b2e;
  color: #fff;
  font-weight: 600;
  box-shadow: 0 6rpx 20rpx rgba(45,27,46,0.2);
}

/* ===== 功能入口卡片 ===== */
.func-card {
  display: flex;
  background: #fff;
  margin: 8rpx 24rpx 0 24rpx;
  border-radius: 24rpx;
  padding: 38rpx 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(45,27,46,0.05);
}

.func-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.func-icon {
  width: 92rpx;
  height: 92rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.func-icon-buyer { background: linear-gradient(135deg, #fff5f0, #ffe8dc); }
.func-icon-course { background: linear-gradient(135deg, #f0f5ff, #dce8ff); }
.func-icon-look   { background: linear-gradient(135deg, #fef5ff, #fce8ff); }
.func-icon-vip    { background: linear-gradient(135deg, #fff9ec, #fff0cc); }

.func-label {
  font-size: 23rpx;
  color: #666;
  margin-top: 14rpx;
  font-weight: 500;
}

/* ===== 商品列表区 ===== */
.product-section {
  background: #fff;
  margin-top: 24rpx;
  padding: 36rpx 24rpx;
  border-radius: 28rpx 28rpx 0 0;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.section-title-row { display: flex; align-items: baseline; gap: 8rpx; }
.section-title { font-size: 34rpx; font-weight: 700; color: #1a1a2e; }
.section-count { font-size: 24rpx; color: #aaa; }

.clear-filter {
  font-size: 23rpx;
  color: #bbb;
  padding: 6rpx 16rpx;
}

/* 骨架屏 */
.product-grid { display: flex; flex-wrap: wrap; justify-content: space-between; }

.skeleton-card { width: 47%; margin-bottom: 24rpx; }
.skeleton-img {
  width: 100%; height: 340rpx; background: #f5f2ef;
  border-radius: 20rpx; animation: pulse 1.5s infinite;
}
.skeleton-line-long {
  width: 75%; height: 24rpx; background: #f5f2ef;
  border-radius: 8rpx; margin-top: 16rpx; animation: pulse 1.5s infinite;
}
.skeleton-line-short {
  width: 42%; height: 22rpx; background: #f5f2ef;
  border-radius: 8rpx; margin-top: 12rpx; animation: pulse 1.5s infinite 0.15s;
}

@keyframes pulse { 0%{opacity:1} 50%{opacity:0.4} 100%{opacity:1} }

/* 空状态 */
.empty-state { text-align: center; padding: 80rpx 0; }
.empty-icon { font-size: 96rpx; display: block; filter: grayscale(1); opacity: 0.25; margin-bottom: 16rpx; }
.empty-text { font-size: 30rpx; color: #ccc; display: block; margin-bottom: 32rpx; }
.empty-btn {
  display: inline-flex; padding: 22rpx 48rpx;
  background: linear-gradient(to right, #ff7a3d, #ff5722);
  color: #fff; font-size: 27rpx; font-weight: 700;
  border-radius: 20rpx; box-shadow: 0 8rpx 24rpx rgba(255,87,34,0.25);
}

/* 商品卡片 */
.product-card { width: 47%; margin-bottom: 24rpx; border-radius: 20rpx; overflow: hidden; background: #faf8f6; }
.card-img-wrap { width: 100%; height: 340rpx; position: relative; overflow: hidden; }
.card-img { width: 100%; height: 100%; }
.card-img-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: #f0ede9; }
.placeholder-text { font-size: 22rpx; color: #ccc; }
.badge-hot { position: absolute; top: 12rpx; left: 12rpx; background: linear-gradient(135deg,#ff5722,#ff9800); color: #fff; font-size: 18rpx; font-weight: 700; padding: 4rpx 14rpx; border-radius: 8rpx; }
.badge-new { position: absolute; top: 12rpx; left: 12rpx; background: linear-gradient(135deg,#e91e63,#c2185b); color: #fff; font-size: 18rpx; font-weight: 700; padding: 4rpx 14rpx; border-radius: 8rpx; }

.card-info { padding: 18rpx 16rpx 20rpx; }
.card-name {
  font-size: 25rpx; color: #333; font-weight: 500;
  line-height: 1.4; display: -webkit-box;
  -webkit-line-clamp: 2; -webkit-box-orient: vertical;
  overflow: hidden;
}
.card-bottom { margin-top: 8rpx; }
.card-price { font-size: 30rpx; color: #e91e63; font-weight: 800; }
.card-btn {
  margin-top: 14rpx; text-align: center;
  padding: 13rpx 0; background: linear-gradient(to right, #ec4899, #ef4444);
  color: #fff; font-size: 24rpx; font-weight: 600; border-radius: 12rpx;
}

/* ===== 底部大图CTA区 ===== */
.bottom-banner-wrap { padding: 0 0 24rpx 0; }

.bottom-banner {
  margin: 0 24rpx;
  height: 320rpx;
  border-radius: 24rpx;
  position: relative;
  overflow: hidden;
}

.bottom-banner-bg {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  background:
    radial-gradient(ellipse at 70% 40%, rgba(196,69,105,0.1) 0%, transparent 60%),
    radial-gradient(ellipse at 20% 70%, rgba(184,148,90,0.08) 0%, transparent 55%),
    linear-gradient(145deg, #faf5f0 0%, #f5ebe3 40%, #ede4db 100%);
}

.bottom-banner-bg::before {
  content: ''; position: absolute;
  top: -60rpx; right: -40rpx;
  width: 260rpx; height: 260rpx;
  border-radius: 50%;
  background: rgba(232,154,172,0.06);
}

.bottom-banner-bg::after {
  content: ''; position: absolute;
  bottom: -30rpx; left: -30rpx;
  width: 160rpx; height: 160rpx;
  border-radius: 50%;
  background: rgba(184,148,90,0.06);
}

.bottom-banner-content {
  position: relative; z-index: 2;
  text-align: center;
  padding-top: 64rpx;
}

.cta-title {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: #2d1b2e;
  letter-spacing: 3rpx;
}

.cta-subtitle {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  letter-spacing: 5rpx;
  font-weight: 300;
}

.cta-buttons {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-top: 34rpx;
}

.cta-btn {
  padding: 20rpx 48rpx;
  border-radius: 18rpx;
  font-size: 27rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.cta-btn-primary { background: #fff; color: #333; box-shadow: 0 8rpx 28rpx rgba(0,0,0,0.07); }
.cta-btn-outline { background: rgba(45,27,46,0.04); color: #333; border: 2rpx solid rgba(45,27,46,0.15); }

.safe-bottom { height: 120rpx; }
