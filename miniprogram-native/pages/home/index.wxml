<view class="page">
  <!-- ===== 导航栏（白底，固定顶部） ===== -->
  <view class="nav-bar">
    <view class="brand">
      <text class="brand-icon">骆</text>
      <view class="brand-texts">
        <text class="brand-name">骆芷蝶智选</text>
        <text class="brand-sub">CHOICETOB</text>
      </view>
    </view>
    <view class="hamburger {{menuOpen ? 'open' : ''}}" bindtap="toggleMenu">
      <view class="bar"></view><view class="bar"></view><view class="bar"></view>
    </view>
  </view>

  <!-- ===== 大图Banner区（导航栏下方，填满剩余屏幕）===== -->
  <view class="hero-wrap">

    <!-- 轮播大图 -->
    <swiper class="hero-swiper" autoplay circular indicator-dots="{{false}}" interval="5000" duration="600" bindchange="onBannerChange">
      <swiper-item wx:for="{{banners}}" wx:key="id">
        <image class="hero-img" src="{{item.image}}" mode="aspectFill" />
      </swiper-item>
      <swiper-item wx:if="{{banners.length === 0}}">
        <view class="hero-placeholder"></view>
      </swiper-item>
    </swiper>

    <!-- 指示点 -->
    <view class="dots" wx:if="{{banners.length > 1}}">
      <view wx:for="{{banners}}" wx:key="*this" class="dot {{currentBanner===index?'dot-on':''}}"></view>
    </view>

    <!-- ===== 全部内容叠加在图片上 ===== -->
    <view class="hero-overlay">

      <!-- 上部：标题文字 -->
      <view class="title-area">
        <view class="badge">数据驱动 · 智选未来</view>
        <text class="main-title">骆芷蝶供应链<text class="t-accent">智选</text>平台</text>
        <text class="sub-title">服装门店一站式赋能平台</text>
      </view>

      <!-- 下部：标签 + 搜索（叠在图下半部分） -->
      <view class="bottom-area">

        <!-- 分类标签（居中，半透明底） -->
        <scroll-view scroll-x class="tag-scroll" show-scrollbar="{{false}}">
          <view class="tag-row-c">
            <view wx:for="{{categories}}" wx:key="*this"
              class="tg {{activeCategory === item ? 'tg-on' : ''}}"
              bindtap="switchCategory" data-cat="{{item}}">
              {{item}}
            </view>
          </view>
        </scroll-view>

        <!-- 搜索栏 -->
        <view class="search-bar" bindtap="goBuyer">
          <text class="si">🔍</text>
          <text class="sp">搜索商品名称、描述...</text>
          <view class="sb">浏览选品 →</view>
        </view>

      </view>

    </view>

    <!-- 底部渐变衔接商品区 -->
    <view class="fade-bottom"></view>
  </view>

  <!-- ===== 汉堡菜单 ===== -->
  <view class="menu-mask {{menuOpen ? 'show' : ''}}" bindtap="closeMenu">
    <view class="menu-panel {{menuOpen ? 'in' : ''}}" catchtap="stopProp">
      <view class="panel-head">
        <text class="panel-brand">骆芷蝶智选</text>
        <view class="panel-close" bindtap="closeMenu"><text>✕</text></view>
      </view>
      <scroll-view scroll-y class="panel-body">
        <view class="ml" bindtap="goBuyer"><text class="me">🛍</text><text>买手选品</text></view>
        <view class="ml" bindtap="goCourses"><text class="me">📚</text><text>线上课程</text></view>
        <view class="ml" bindtap="goLooks"><text class="me">🎨</text><text>每日搭配</text></view>
        <view class="ml" bindtap="goVipPage"><text class="me">👑</text><text>VIP会员中心</text></view>
        <view class="m-line"></view>
        <view class="ml" bindtap="goMy"><text class="me">📋</text><text>风格测试</text></view>
        <view class="ml" bindtap="goContact"><text class="me">💬</text><text>联系我们</text></view>
      </scroll-view>
      <view class="panel-foot">
        <text class="p-user">{{userName || '未登录'}}</text>
        <view class="p-login" wx:if="{{!loggedIn}}" bindtap="doLogin"><text>微信登录</text></view>
      </view>
    </view>
  </view>

  <!-- ===== 商品列表 ===== -->
  <view class="prod-section">
    <view class="sec-head">
      <text class="sec-title">{{activeCategory==='全部'?'穿搭':activeCategory}} · 精选</text>
      <text class="sec-count">({{products.length}}件)</text>
      <view class="sec-clear" wx:if="{{activeCategory!=='全部'}}" bindtap="switchCategory" data-cat="全部"><text>✕ 清除筛选</text></view>
    </view>

    <block wx:if="{{loading}}">
      <view class="grid">
        <view class="sk-card" wx:for="{{[1,2,3,4,5,6]}}" wx:key="*this">
          <view class="sk-img"></view><view class="sk-l1"></view><view class="sk-l2"></view>
        </view>
      </view>
    </block>

    <block wx:elif="{{products.length===0}}">
      <view class="empty-box">
        <text class="ei">📦</text><text class="et">暂无选品</text>
        <view class="eb" bindtap="goBuyer"><text>去拿货拼单 →</text></view>
      </view>
    </block>

    <block wx:else>
      <view class="grid">
        <view class="card" wx:for="{{products}}" wx:key="id" bindtap="goShop" data-id="{{item.id}}">
          <view class="ciw">
            <image wx:if="{{item.image_url || item.cover_image}}" src="{{item.image_url || item.cover_image}}" mode="aspectFill" class="cimg" lazy-load />
            <view wx:else class="cip"><text class="cpt">暂无图片</text></view>
            <view wx:if="{{item.is_hot}}" class="bh">HOT</view>
            <view wx:if="{{item.is_new}}" class="bn">NEW</view>
          </view>
          <view class="cin">
            <text class="cn">{{item.name || item.title || '商品'}}</text>
            <text class="cp">{{item.priceText}}</text>
            <view class="cb">下单</view>
          </view>
        </view>
      </view>
    </block>
  </view>

  <!-- 底部CTA -->
  <view class="cta-area">
    <view class="cta-box">
      <view class="cta-bg"></view>
      <view class="cta-inner">
        <text class="ctat">爆款选品 · 拿货精选</text>
        <text class="ctas">骆芷蝶智选 · 专业推荐</text>
        <view class="ctar">
          <view class="ctab ctab1" bindtap="goBuyer"><text>全部商品</text></view>
          <view class="ctab ctab2" bindtap="goBuyer"><text>爆款安利 →</text></view>
        </view>
      </view>
    </view>
  </view>

  <view class="sbottom"></view>
</view>
