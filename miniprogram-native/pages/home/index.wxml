<view class="page">
  <!-- ===== 顶部导航栏 ===== -->
  <view class="nav-bar">
    <view class="brand">
      <text class="brand-icon">骆</text>
      <view class="brand-texts">
        <text class="brand-name">骆芷蝶智选</text>
        <text class="brand-sub">CHOICETOB</text>
      </view>
    </view>
    <!-- 汉堡菜单 -->
    <view class="hamburger {{menuOpen ? 'open' : ''}}" bindtap="toggleMenu">
      <view class="bar"></view>
      <view class="bar"></view>
      <view class="bar"></view>
    </view>
  </view>

  <!-- ===== 分类标签（屏幕最上方，导航栏下方）===== -->
  <scroll-view scroll-x class="top-tags-scroll" show-scrollbar="{{false}}">
    <view class="tag-row-top">
      <view wx:for="{{categories}}" wx:key="*this"
        class="tag-item-top {{activeCategory === item ? 'tag-active' : ''}}"
        bindtap="switchCategory" data-cat="{{item}}">
        {{item}}
      </view>
    </view>
  </scroll-view>

  <!-- ===== 搜索栏 ===== -->
  <view class="search-wrap">
    <view class="search-bar" bindtap="goBuyer">
      <text class="search-icon">🔍</text>
      <text class="search-placeholder">搜索商品名称、描述...</text>
      <view class="search-btn">浏览选品 →</view>
    </view>
  </view>

  <!-- ===== 全屏大图Banner（搜索栏下方填满剩余空间） ===== -->
  <view class="banner-area">
    <swiper class="banner-swiper" autoplay circular indicator-dots="{{false}}" interval="5000" duration="600" bindchange="onBannerChange">
      <swiper-item wx:for="{{banners}}" wx:key="id">
        <image class="banner-img" src="{{item.image}}" mode="aspectFill" />
      </swiper-item>
      <swiper-item wx:if="{{banners.length === 0}}">
        <view class="banner-placeholder"></view>
      </swiper-item>
    </swiper>

    <!-- 自定义指示点 -->
    <view class="dots-wrap" wx:if="{{banners.length > 1}}">
      <view wx:for="{{banners}}" wx:key="*this"
        class="dot {{currentBanner === index ? 'dot-active' : ''}}"></view>
    </view>

    <!-- 文字覆盖层（在图片上） -->
    <view class="banner-overlay">
      <view class="badge-pill">数据驱动 · 智选未来</view>
      <text class="overlay-title">骆芷蝶供应链<text class="title-accent">智选</text>平台</text>
      <text class="overlay-sub">服装门店一站式赋能平台</text>
    </view>

    <!-- 底部渐变（衔接商品区） -->
    <view class="banner-bottom-fade"></view>
  </view>

  <!-- ===== 汉堡菜单面板 ===== -->
  <view class="menu-mask {{menuOpen ? 'show' : ''}}" bindtap="closeMenu">
    <view class="menu-panel {{menuOpen ? 'in' : ''}}" catchtap="stopProp">
      <view class="panel-head">
        <text class="panel-brand">骆芷蝶智选</text>
        <view class="panel-close" bindtap="closeMenu"><text>✕</text></view>
      </view>
      <scroll-view scroll-y class="panel-body">
        <view class="m-link" bindtap="goBuyer"><text class="m-e">🛍</text><text>买手选品</text></view>
        <view class="m-link" bindtap="goCourses"><text class="m-e">📚</text><text>线上课程</text></view>
        <view class="m-link" bindtap="goLooks"><text class="m-e">🎨</text><text>每日搭配</text></view>
        <view class="m-link" bindtap="goVipPage"><text class="m-e">👑</text><text>VIP会员中心</text></view>
        <view class="m-line"></view>
        <view class="m-link" bindtap="goMy"><text class="m-e">📋</text><text>风格测试</text></view>
        <view class="m-link" bindtap="goContact"><text class="m-e">💬</text><text>联系我们</text></view>
      </scroll-view>
      <view class="panel-foot">
        <text class="p-user">{{userName || '未登录'}}</text>
        <view class="p-login" wx:if="{{!loggedIn}}" bindtap="doLogin"><text>微信登录</text></view>
      </view>
    </view>
  </view>

  <!-- ===== 商品列表区 ===== -->
  <view class="product-section">
    <view class="sec-head">
      <text class="sec-title">{{activeCategory === '全部' ? '穿搭' : activeCategory}} · 精选</text>
      <text class="sec-count">({{products.length}}件)</text>
      <view class="sec-clear" wx:if="{{activeCategory !== '全部'}}" bindtap="switchCategory" data-cat="全部"><text>✕ 清除筛选</text></view>
    </view>

    <block wx:if="{{loading}}">
      <view class="grid">
        <view class="sk-card" wx:for="{{[1,2,3,4,5,6]}}" wx:key="*this">
          <view class="sk-img"></view><view class="sk-l1"></view><view class="sk-l2"></view>
        </view>
      </view>
    </block>

    <block wx:elif="{{products.length === 0}}">
      <view class="empty-box">
        <text class="empty-icon">📦</text>
        <text class="empty-txt">暂无选品</text>
        <view class="empty-btn" bindtap="goBuyer"><text>去拿货拼单 →</text></view>
      </view>
    </block>

    <block wx:else>
      <view class="grid">
        <view class="card" wx:for="{{products}}" wx:key="id" bindtap="goShop" data-id="{{item.id}}">
          <view class="c-img-w">
            <image wx:if="{{item.image_url || item.cover_image}}" src="{{item.image_url || item.cover_image}}" mode="aspectFill" class="c-img" lazy-load />
            <view wx:else class="c-img-ph"><text class="ph-t">暂无图片</text></view>
            <view wx:if="{{item.is_hot}}" class="bd-hot">HOT</view>
            <view wx:if="{{item.is_new}}" class="bd-new">NEW</view>
          </view>
          <view class="c-info">
            <text class="c-name">{{item.name || item.title || '商品'}}</text>
            <text class="c-price">{{item.priceText}}</text>
            <view class="c-btn">下单</view>
          </view>
        </view>
      </view>
    </block>
  </view>

  <!-- 底部CTA大图 -->
  <view class="cta-area">
    <view class="cta-box">
      <view class="cta-bg"></view>
      <view class="cta-inner">
        <text class="cta-t">爆款选品 · 拿货精选</text>
        <text class="cta-s">骆芷蝶智选 · 专业推荐</text>
        <view class="cta-row">
          <view class="cta-b cta-b1" bindtap="goBuyer"><text>全部商品</text></view>
          <view class="cta-b cta-b2" bindtap="goBuyer"><text>爆款安利 →</text></view>
        </view>
      </view>
    </view>
  </view>

  <view class="safe-bottom"></view>
</view>
