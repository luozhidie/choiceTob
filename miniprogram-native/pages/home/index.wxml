<view class="page">
  <!-- 大屏轮播Banner -->
  <swiper class="hero-swiper" autoplay circular indicator-dots indicator-color="rgba(255,255,255,0.4)" indicator-active-color="#fff" interval="4000">
    <swiper-item wx:for="{{banners}}" wx:key="id">
      <image class="banner-img" src="{{item.image}}" mode="aspectFill" bindtap="goBannerLink" data-url="{{item.url}}" />
      <!-- 文字覆盖层 -->
      <view class="banner-overlay">
        <view class="banner-badge">数据驱动 · 智选未来</view>
        <text class="banner-title">{{item.title || '骆芷蝶供应链智选平台'}}</text>
        <text class="banner-subtitle">{{item.subtitle || '服装门店一站式赋能平台'}}</text>
      </view>
    </swiper-item>

    <!-- 默认占位Banner（无数据时） -->
    <swiper-item wx:if="{{banners.length === 0}}">
      <view class="banner-default">
        <view class="default-bg"></view>
        <view class="banner-overlay">
          <view class="banner-badge">数据驱动 · 智选未来</view>
          <text class="banner-title">骆芷蝶供应链<text class="banner-accent">智选</text>平台</text>
          <text class="banner-subtitle">服装门店一站式赋能平台</text>
        </view>
      </view>
    </swiper-item>
  </swiper>

  <!-- 搜索栏（悬浮在banner底部） -->
  <view class="search-bar-wrap">
    <view class="search-bar" bindtap="goBuyer">
      <text class="search-icon">🔍</text>
      <text class="search-placeholder">搜索商品名称、描述...</text>
      <view class="search-btn">浏览选品 →</view>
    </view>
  </view>

  <!-- 分类标签栏 -->
  <scroll-view scroll-x class="tag-scroll" show-scrollbar="{{false}}">
    <view class="tag-row">
      <view wx:for="{{categories}}" wx:key="*this"
        class="tag-item {{activeCategory === item ? 'tag-active' : ''}}"
        bindtap="switchCategory"
        data-cat="{{item}}">
        {{item}}
      </view>
    </view>
  </scroll-view>

  <!-- 功能入口卡片 -->
  <view class="func-card">
    <view class="func-item" bindtap="goBuyer">
      <view class="func-icon func-icon-buyer"><text>🛍</text></view>
      <text class="func-label">买手选品</text>
    </view>
    <view class="func-item" bindtap="goCourses">
      <view class="func-icon func-icon-course"><text>📚</text></view>
      <text class="func-label">线上课程</text>
    </view>
    <view class="func-item" bindtap="goLooks">
      <view class="func-icon func-icon-look"><text>🎨</text></view>
      <text class="func-label">每日搭配</text>
    </view>
    <view class="func-item" bindtap="goMy">
      <view class="func-icon func-icon-vip"><text>👑</text></view>
      <text class="func-label">VIP会员</text>
    </view>
  </view>

  <!-- 商品列表区 -->
  <view class="product-section">
    <view class="section-header">
      <view class="section-title-row">
        <text class="section-title">{{activeCategory === '全部' ? '穿搭' : activeCategory}} · 精选</text>
        <text class="section-count">({{products.length}} 件)</text>
      </view>
      <view class="clear-filter" wx:if="{{activeCategory !== '全部'}}" bindtap="switchCategory" data-cat="全部">
        <text>✕ 清除筛选</text>
      </view>
    </view>

    <!-- 加载中骨架屏 -->
    <block wx:if="{{loading}}">
      <view class="product-grid">
        <view class="skeleton-card" wx:for="{{[1,2,3,4,5,6]}}" wx:key="*this">
          <view class="skeleton-img"></view>
          <view class="skeleton-line skeleton-line-long"></view>
          <view class="skeleton-line skeleton-line-short"></view>
        </view>
      </view>
    </block>

    <!-- 空状态 -->
    <block wx:elif="{{products.length === 0}}">
      <view class="empty-state">
        <text class="empty-icon">📦</text>
        <text class="empty-text">暂无选品</text>
        <view class="empty-btn" bindtap="goBuyer">
          <text>去拿货拼单 →</text>
        </view>
      </view>
    </block>

    <!-- 商品网格 -->
    <block wx:else>
      <view class="product-grid">
        <view class="product-card" wx:for="{{products}}" wx:key="id"
          bindtap="goShop" data-id="{{item.id}}">
          <view class="card-img-wrap">
            <image
              wx:if="{{item.image_url || item.cover_image}}"
              src="{{item.image_url || item.cover_image}}"
              mode="aspectFill"
              class="card-img"
              lazy-load />
            <view wx:else class="card-img-placeholder">
              <text class="placeholder-text">暂无图片</text>
            </view>
            <view wx:if="{{item.is_hot}}" class="badge-hot">HOT</view>
            <view wx:if="{{item.is_new}}" class="badge-new">NEW</view>
          </view>
          <view class="card-info">
            <text class="card-name">{{item.name || item.title || '商品'}}</text>
            <view class="card-bottom">
              <text class="card-price">{{item.priceText}}</text>
            </view>
            <view class="card-btn">下单</view>
          </view>
        </view>
      </view>
    </block>
  </view>

  <!-- 底部CTA大图区 -->
  <view class="bottom-banner-wrap">
    <view class="bottom-banner">
      <view class="bottom-banner-bg"></view>
      <view class="bottom-banner-content">
        <text class="cta-title">爆款选品 · 拿货精选</text>
        <text class="cta-subtitle">骆芷蝶智选 · 专业推荐</text>
        <view class="cta-buttons">
          <view class="cta-btn cta-btn-primary" bindtap="goBuyer"><text>全部商品</text></view>
          <view class="cta-btn cta-btn-outline" bindtap="goBuyer"><text>爆款安利 →</text></view>
        </view>
      </view>
    </view>
  </view>

  <view class="safe-bottom"></view>
</view>
