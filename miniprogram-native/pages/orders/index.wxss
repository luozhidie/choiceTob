page { background: #f5f2ef; min-height: 100vh; }

/* Tabs */
.tabs { display: flex; background: #fff; position: sticky; top: 0; z-index: 10; border-bottom: 1rpx solid #f0ede9; }
.tab { flex: 1; text-align: center; padding: 24rpx 0; font-size: 26rpx; color: #888; position: relative; font-weight: 500; }
.tab.on { color: #2d1b2e; font-weight: 700; }
.tab.on::after { content: ''; position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); width: 48rpx; height: 4rpx; background: #2d1b2e; border-radius: 2rpx; }

/* 列表 */
.list { padding: 16rpx 24rpx; }
.order-card { background: #fff; border-radius: 20rpx; margin-bottom: 20rpx; overflow: hidden; }
.oc-header { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 24rpx; border-bottom: 1rpx solid #f5f3f1; }
.oc-id { font-size: 24rpx; color: #999; }
.oc-status { font-size: 24rpx; font-weight: 600; }
.oc-status.pending { color: #eab308; }
.oc-status.paid { color: #22c55e; }
.oc-status.shipped { color: #3b82f6; }
.oc-status.completed { color: #6b7280; }
.oc-status.refund_pending { color: #f97316; }
.oc-status.refunded { color: #ef4444; }

.oc-product { display: flex; padding: 20rpx 24rpx; gap: 20rpx; }
.oc-img { width: 120rpx; height: 120rpx; border-radius: 12rpx; background: #f5f3f1; flex-shrink: 0; }
.oc-info { flex: 1; }
.oc-name { display: block; font-size: 26rpx; color: #333; font-weight: 500; line-height: 1.4; margin-bottom: 8rpx; }
.oc-qty { display: block; font-size: 22rpx; color: #999; margin-bottom: 8rpx; }
.oc-price { display: block; font-size: 30rpx; color: #e91e63; font-weight: 700; }

.oc-actions { display: flex; justify-content: flex-end; gap: 16rpx; padding: 16rpx 24rpx; border-top: 1rpx solid #f5f3f1; }
.oc-btn { padding: 14rpx 28rpx; border-radius: 24rpx; font-size: 24rpx; font-weight: 600; }
.oc-btn.outline { background: #fff; color: #2d1b2e; border: 2rpx solid #ddd; }
.oc-btn.red { background: #fff; color: #ef4444; border: 2rpx solid #fecaca; }

/* 空状态 */
.empty { text-align: center; padding: 120rpx 0; }
.ec { display: block; font-size: 80rpx; margin-bottom: 20rpx; }
.et { display: block; font-size: 28rpx; color: #ccc; margin-bottom: 32rpx; }
.eb { display: inline-block; padding: 18rpx 44rpx; background: linear-gradient(135deg, #2d1b2e, #4a3a4b); color: #fff; font-size: 26rpx; font-weight: 700; border-radius: 28rpx; }
