page { background: #faf8f6; }

/* Hero */
.hero { background: linear-gradient(135deg, #1a5f6b, #0e8a56); padding: 64rpx 32rpx 80rpx; text-align: center; }
.h-inner { display: flex; flex-direction: column; align-items: center; }
.h-icon { font-size: 72rpx; margin-bottom: 16rpx; }
.h-title { display: block; font-size: 38rpx; font-weight: 900; color: #fff; margin-bottom: 12rpx; }
.h-desc { display: block; font-size: 26rpx; color: rgba(255,255,255,0.8); }

/* 状态卡片 */
.status-card { margin: -40rpx 24rpx 0; background: #fff; border-radius: 20rpx; padding: 28rpx 32rpx; display: flex; justify-content: space-between; align-items: center; box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.06); position: relative; z-index: 10; }
.sc-left { }
.sc-type { display: block; font-size: 30rpx; font-weight: 700; color: #1a1a2e; }
.sc-exp { display: block; font-size: 22rpx; color: #22c55e; margin-top: 6rpx; font-weight: 500; }
.sc-badge { font-size: 22rpx; color: #22c55e; font-weight: 600; background: #f0fdf4; padding: 8rpx 20rpx; border-radius: 20rpx; }

/* Plans */
.plans { padding: 24rpx; }
.plan-card { background: #fff; border-radius: 24rpx; padding: 36rpx 32rpx; margin-bottom: 24rpx; position: relative; overflow: hidden; border: 2rpx solid #e5e7eb; }
.pc-hl { border-color: #10b981; box-shadow: 0 8rpx 32rpx rgba(16,185,129,0.12); }
.pc-tag { position: absolute; top: 0; right: 0; background: #10b981; color: #fff; font-size: 20rpx; font-weight: 700; padding: 8rpx 24rpx; border-bottom-left-radius: 16rpx; }
.pc-name { display: block; font-size: 30rpx; font-weight: 700; color: #1a1a2e; margin-bottom: 12rpx; }
.pc-price { display: block; font-size: 44rpx; font-weight: 900; color: #10b981; margin-bottom: 8rpx; }
.pc-desc { display: block; font-size: 24rpx; color: #6b7280; margin-bottom: 16rpx; font-weight: 500; }
.pc-features { margin-top: 20rpx; }
.pc-f { display: block; font-size: 24rpx; color: #555; margin-bottom: 10rpx; }
.pc-btn { margin-top: 28rpx; background: linear-gradient(135deg, #10b981, #059669); color: #fff; font-size: 28rpx; font-weight: 700; text-align: center; padding: 24rpx 0; border-radius: 16rpx; }

/* 支付弹窗 */
.modal-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center; z-index: 999; }
.modal { background: #fff; border-radius: 28rpx; padding: 48rpx 40rpx; width: 85%; max-width: 640rpx; position: relative; }
.modal-close { position: absolute; top: 24rpx; right: 24rpx; width: 48rpx; height: 48rpx; display: flex; align-items: center; justify-content: center; font-size: 32rpx; color: #999; }
.m-title { display: block; text-align: center; font-size: 28rpx; color: #6b7280; margin-bottom: 16rpx; }
.m-name { display: block; text-align: center; font-size: 36rpx; font-weight: 800; color: #1a1a2e; margin-bottom: 12rpx; }
.m-price { display: block; text-align: center; font-size: 48rpx; font-weight: 900; color: #10b981; margin-bottom: 20rpx; }
.m-tip { display: block; text-align: center; font-size: 24rpx; color: #9ca3af; margin-bottom: 36rpx; }
.m-btn { background: linear-gradient(135deg, #10b981, #059669); color: #fff; font-size: 30rpx; font-weight: 700; text-align: center; padding: 26rpx 0; border-radius: 16rpx; }
