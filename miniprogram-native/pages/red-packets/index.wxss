page{background:#f5f5f5;}
/* 标签 */
.tabs{display:flex;background:#fff;padding:0 20rpx;border-bottom:1rpx solid #eee;}
.tab{flex:1;text-align:center;padding:24rpx 0;font-size:26rpx;color:#888;position:relative;}
.tab-on{color:#e91e63;font-weight:700;}
.tab-on::after{content:'';position:absolute;bottom:0;left:50%;transform:translateX(-50%);width:60rpx;height:4rpx;background:#e91e63;border-radius:2rpx;}

/* 列表 */
.list{padding:20rpx;}
.rp-card{display:flex;align-items:center;background:#fff;border-radius:16rpx;margin-bottom:16rpx;overflow:hidden;position:relative;padding:24rpx 16rpx;}
.rp-card-used{opacity:0.5;}
.rp-left{width:180rpx;background:linear-gradient(135deg,#ff6090,#e91e63);color:#fff;padding:20rpx 0;text-align:center;flex-shrink:0;border-radius:12rpx;margin-right:16rpx;}
.rp-amount{font-size:40rpx;font-weight:800;display:block;}
.rp-type{font-size:20rpx;opacity:0.85;display:block;margin-top:4rpx;}
.rp-right{flex:1;}
.rp-title{font-size:26rpx;font-weight:600;color:#333;display:block;margin-bottom:6rpx;}
.rp-expire{font-size:20rpx;color:#bbb;display:block;}
.rp-btn{background:#e91e63;color:#fff;font-size:22rpx;padding:10rpx 24rpx;border-radius:20rpx;flex-shrink:0;}
.rp-status{font-size:22rpx;color:#ccc;flex-shrink:0;}
.rp-status-expired{color:#ccc;}

/* 空状态 */
.empty{text-align:center;padding:120rpx 0;color:#ccc;}
.empty-icon{font-size:80rpx;display:block;margin-bottom:20rpx;}
.empty-text{font-size:26rpx;}
.empty-btn{margin-top:30rpx;background:#e91e63;color:#fff;font-size:26rpx;padding:14rpx 56rpx;border-radius:40rpx;display:inline-block;}

/* loading */
.loading{text-align:center;padding:80rpx 0;}
.loading-spinner{width:48rpx;height:48rpx;border:3rpx solid #eee;border-top-color:#e91e63;border-radius:50%;display:inline-block;animation:spin 0.8s linear infinite;}
@keyframes spin{to{transform:rotate(360deg);}}
