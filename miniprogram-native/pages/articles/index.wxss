page{background: var(--bg);}

/* Hero */
.hero{background:linear-gradient(160deg,#2d1b2e 0%,#5c2a4e 40%,#8b4368 100%);padding:44rpx 28rpx 32rpx;}
.h-badge{display:inline-block;background:rgba(255,255,255,.15);color:rgba(255,255,255,.85);font-size:22rpx;padding:6rpx 22rpx;border-radius:20rpx;margin-bottom:16rpx;}
.ht{font-size:42rpx;font-weight:bold;color:#fff;display:block;letter-spacing:1rpx;}
.ht .h-pink{color:#f48fb1;}
.hs{font-size:25rpx;color:rgba(255,255,255,.75);display:block;margin-top:10rpx;line-height:1.5;}

/* 订阅按钮 */
.sub-btns{display:flex;gap:14rpx;margin-top:28rpx;}
.sbtn{flex:1;text-align:center;padding:18rpx 12rpx;border-radius:16rpx;font-size:24rpx;font-weight:600;}
.sbtn-month{background:rgba(255,255,255,.15);color:#fff;border:1rpx solid rgba(255,255,255,.3);}
.sbtn-year{background:rgba(255,255,255,.2);color:#fff;border:1rpx solid rgba(255,255,255,.35);}

/* Tabs */
.tabs{display:flex;padding:14rpx 24rpx;background:#fff;border-bottom:1rpx solid #eee;}
.tab{flex:1;display:flex;align-items:center;justify-content:center;gap:8rpx;padding:16rpx 0;font-size:27rpx;color:#666;background:#f5f3f0;margin-right:14rpx;border-radius:12rpx;}
.tab:last-child{margin-right:0;}
.tab-on{background:#2d1b2e;color:#fff;font-weight:700;}

/* 标签行 */
.tag-row{padding:14rpx 20rpx;white-space:nowrap;display:flex;gap:10rpx;background:#fff;border-bottom:1rpx solid #f0ece8;}
.tag{flex-shrink:0;padding:10rpx 28rpx;border-radius:26rpx;font-size:24rpx;color:#666;background:#f5f3f0;border:1rpx solid #eee;}
.tag-on{background:#2d1b2e;color:#fff;border-color:#2d1b2e;font-weight:600;}

/* 列表 */
.list{padding:14rpx 20rpx;}
.card{display:flex;background:#fff;border-radius:16rpx;overflow:hidden;margin-bottom:16rpx;box-shadow:0 2rpx 10rpx rgba(0,0,0,.04);}
.ci-wrap{position:relative;width:200rpx;height:160rpx;flex-shrink:0;background:#eee;}
.ci{width:200rpx;height:160rpx;display:block;}
.cwatermark{
  position:absolute;
  right:8rpx;
  bottom:8rpx;
  padding:4rpx 10rpx;
  font-size:18rpx;
  font-weight:600;
  color:rgba(255,255,255,.85);
  background:rgba(45,27,46,.45);
  border-radius:6rpx;
  pointer-events:none;
  z-index:2;
}
.vbadge{position:absolute;left:8rpx;bottom:8rpx;background:rgba(0,0,0,.6);color:#fff;font-size:20rpx;padding:4rpx 14rpx;border-radius:20rpx;line-height:1.2;}
.cb{flex:1;padding:18rpx 18rpx;display:flex;flex-direction:column;justify-content:space-between;min-width:0;}
.ct-row{display:flex;align-items:flex-start;justify-content:space-between;gap:10rpx;}
.ct{font-size:28rpx;font-weight:600;color:#1a1a2e;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;line-height:1.4;flex:1;}
.ctag{flex-shrink:0;font-size:19rpx;color:#fff;background:#8b4368;padding:4rpx 12rpx;border-radius:18rpx;margin-top:4rpx;}
.cd{font-size:23rpx;color:#888;margin-top:6rpx;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;line-height:1.4;}
.cm{display:flex;justify-content:space-between;margin-top:8pt;}
.cauth{font-size:21rpx;color:#2d1b2e;}
.cdate{font-size:20rpx;color:#bbb;}

/* 空状态 */
.emp{text-align:center;padding:100rpx 0;}
.ei-icon{font-size:80rpx;display:block;color:#ddd;margin-bottom:12rpx;}
.et{font-size:27rpx;color:#ccc;display:block;}

.ld{text-align:center;padding:80rpx 0;color:#999;font-size:26rpx;}

/* 底部订阅 */
.bottom-cta{background:linear-gradient(160deg,#2d1b2e 0%,#5c2a4e 40%,#8b4368 100%);padding:28rpx 24rpx 20rpx;}
.bottom-cta .sub-btns{margin-top:0;}

.sbtm{height:30rpx;}
