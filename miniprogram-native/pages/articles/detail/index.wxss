page { background: var(--bg); }

.topbar {
  position: sticky;
  top: 0;
  z-index: 10;
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 24rpx;
  background: #2d1b2e;
  color: #fff;
}
.back { font-size: 30rpx; color: #fff; padding-right: 20rpx; }
.tt { font-size: 30rpx; font-weight: 600; }

.ld { text-align: center; padding: 120rpx 0; color: #999; font-size: 26rpx; }
.emp { text-align: center; padding: 120rpx 0; color: #bbb; font-size: 28rpx; }

/* 头部 */
.head { padding: 28rpx 28rpx 16rpx; background: #fff; }
.htitle { font-size: 38rpx; font-weight: 700; color: #1a1a2e; line-height: 1.4; display: block; }
.meta { display: flex; align-items: center; gap: 16rpx; margin-top: 16rpx; }
.mauthor { font-size: 22rpx; color: #2d1b2e; }
.mdate { font-size: 22rpx; color: #bbb; }
.tag {
  display: inline-block;
  margin-top: 14rpx;
  padding: 6rpx 20rpx;
  border-radius: 22rpx;
  font-size: 21rpx;
  color: #fff;
  background: #8b4368;
}

/* 趋势图片画廊（横向滑动） */
.gallery {
  white-space: nowrap;
  background: #1a1a2e;
  padding: 16rpx 0;
}
.gitem-wrap {
  position: relative;
  display: inline-block;
  width: 460rpx;
  height: 560rpx;
  margin-left: 20rpx;
  vertical-align: middle;
}
.gitem-wrap:last-child { margin-right: 20rpx; }
.gitem {
  width: 100%;
  height: 100%;
  border-radius: 14rpx;
  background: #2d1b2e;
}
.gwatermark {
  position: absolute;
  right: 14rpx;
  bottom: 14rpx;
  padding: 8rpx 16rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.85);
  background: rgba(45, 27, 46, 0.45);
  border-radius: 8rpx;
  pointer-events: none;
  z-index: 2;
}

/* 图片 + 水印 */
.img-wrap { position: relative; margin: 16rpx 0; }
.img { width: 100%; display: block; border-radius: 12rpx; }
.watermark {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  padding: 8rpx 16rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.85);
  background: rgba(45, 27, 46, 0.45);
  border-radius: 8rpx;
  pointer-events: none;
  z-index: 2;
}
.link {
  display: inline-block;
  margin: 10rpx 0;
  font-size: 27rpx;
  color: #2d6cdf;
  background: #eef3ff;
  padding: 10rpx 20rpx;
  border-radius: 12rpx;
}

/* 视频卡片 */
.vcard {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin: 18rpx 0;
  padding: 22rpx;
  background: linear-gradient(135deg, #2d1b2e, #5c2a4e);
  border-radius: 16rpx;
}
.vicon {
  width: 64rpx;
  height: 64rpx;
  flex-shrink: 0;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  color: #fff;
  font-size: 30rpx;
  text-align: center;
  line-height: 64rpx;
}
.vinfo { flex: 1; min-width: 0; }
.vt { font-size: 27rpx; font-weight: 600; color: #fff; display: block; }
.vs { font-size: 21rpx; color: rgba(255, 255, 255, 0.7); display: block; margin-top: 6rpx; line-height: 1.4; }
.vbtn {
  flex-shrink: 0;
  padding: 14rpx 24rpx;
  background: #fff;
  color: #2d1b2e;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: 30rpx;
}

.sbtm { height: 30rpx; }
