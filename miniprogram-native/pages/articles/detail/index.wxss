page { background: #f5f3f0; }

.topbar {
  position: sticky;
  top: 0;
  z-index: 10;
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 24rpx;
  background: #2d1b2e;
  color: #fff;
}
.back { font-size: 30rpx; color: #fff; padding-right: 20rpx; }
.tt { font-size: 30rpx; font-weight: 600; }

.ld { text-align: center; padding: 120rpx 0; color: #999; font-size: 26rpx; }
.emp { text-align: center; padding: 120rpx 0; color: #bbb; font-size: 28rpx; }

/* 头部 */
.head { padding: 28rpx 28rpx 16rpx; background: #fff; }
.htitle { font-size: 38rpx; font-weight: 700; color: #1a1a2e; line-height: 1.4; display: block; }
.meta { display: flex; align-items: center; gap: 16rpx; margin-top: 16rpx; }
.mauthor { font-size: 22rpx; color: #e91e63; }
.mdate { font-size: 22rpx; color: #bbb; }
.tag {
  display: inline-block;
  margin-top: 14rpx;
  padding: 6rpx 20rpx;
  border-radius: 22rpx;
  font-size: 21rpx;
  color: #fff;
  background: #8b4368;
}

/* 封面：品牌/推广横幅（不放秀场图） */
.cover-banner {
  margin: 0;
  padding: 44rpx 32rpx 40rpx;
  background: linear-gradient(135deg, #2d1b2e 0%, #5c2a4e 55%, #8b4368 100%);
  color: #fff;
}
.cb-brand {
  font-size: 42rpx;
  font-weight: 800;
  letter-spacing: 3rpx;
  color: #fff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.25);
}
.cb-sub {
  margin-top: 14rpx;
  font-size: 25rpx;
  color: rgba(255, 255, 255, 0.88);
  letter-spacing: 1rpx;
}
.cb-tip {
  margin-top: 22rpx;
  display: inline-block;
  padding: 10rpx 22rpx;
  font-size: 22rpx;
  color: #2d1b2e;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 30rpx;
  font-weight: 600;
}

/* 趋势图片画廊（横向滑动） */
.gallery {
  white-space: nowrap;
  background: #1a1a2e;
  padding: 16rpx 0;
}
.gitem {
  display: inline-block;
  width: 460rpx;
  height: 560rpx;
  margin-left: 20rpx;
  border-radius: 14rpx;
  vertical-align: middle;
  background: #2d1b2e;
}
.gitem:last-child { margin-right: 20rpx; }

/* 正文 */
.body { padding: 24rpx 28rpx 40rpx; background: #fff; }
.h1 { font-size: 38rpx; font-weight: 700; color: #1a1a2e; margin: 24rpx 0 12rpx; line-height: 1.4; }
.h2 { font-size: 33rpx; font-weight: 700; color: #1a1a2e; margin: 22rpx 0 10rpx; line-height: 1.4; }
.h3 { font-size: 29rpx; font-weight: 700; color: #333; margin: 18rpx 0 8rpx; line-height: 1.4; }
.p { font-size: 28rpx; color: #444; line-height: 1.8; margin: 10rpx 0; }
.p .b, .h1 .b, .h2 .b, .h3 .b { font-weight: 700; color: #1a1a2e; }
.img { width: 100%; display: block; margin: 16rpx 0; border-radius: 12rpx; }
.link {
  display: inline-block;
  margin: 10rpx 0;
  font-size: 27rpx;
  color: #2d6cdf;
  background: #eef3ff;
  padding: 10rpx 20rpx;
  border-radius: 12rpx;
}

/* 视频卡片 */
.vcard {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin: 18rpx 0;
  padding: 22rpx;
  background: linear-gradient(135deg, #2d1b2e, #5c2a4e);
  border-radius: 16rpx;
}
.vicon {
  width: 64rpx;
  height: 64rpx;
  flex-shrink: 0;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  color: #fff;
  font-size: 30rpx;
  text-align: center;
  line-height: 64rpx;
}
.vinfo { flex: 1; min-width: 0; }
.vt { font-size: 27rpx; font-weight: 600; color: #fff; display: block; }
.vs { font-size: 21rpx; color: rgba(255, 255, 255, 0.7); display: block; margin-top: 6rpx; line-height: 1.4; }
.vbtn {
  flex-shrink: 0;
  padding: 14rpx 24rpx;
  background: #fff;
  color: #2d1b2e;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: 30rpx;
}

.sbtm { height: 30rpx; }
