<view class="page">
  <!-- Hero -->
  <view class="hero">
    <view class="h-badge"><text>📰 时尚资讯与趋势</text></view>
    <text class="ht">时尚博主与<text class="h-pink">趋势</text></text>
    <text class="hs">最新时尚趋势分析、行业动态、搭配技巧，一站式阅读体验</text>

    <!-- 订阅按钮 -->
    <view class="sub-btns">
      <view class="sbtn sbtn-month" bindtap="subMonthly"><text>月费会员 ¥138/月</text></view>
      <view class="sbtn sbtn-year" bindtap="subYearly"><text>订阅一年享优惠价格 ¥1,380/年</text></view>
    </view>
  </view>

  <!-- 双Tab -->
  <view class="tabs">
    <view class="tab {{activeTab==='blogger'?'tab-on':''}}" bindtap="swTab" data-t="blogger"><text>📖 时尚博主</text></view>
    <view class="tab {{activeTab==='trend'?'tab-on':''}}" bindtap="swTab" data-t="trend"><text>📈 时尚趋势</text></view>
  </view>

  <!-- 标签筛选 -->
  <scroll-view scroll-x class="tag-row" show-scrollbar="{{false}}">
    <text wx:for="{{tags}}" wx:key="*this" class="tag {{activeTag===item?'tag-on':''}}" bindtap="swTag" data-t="{{item}}">{{item}}</text>
  </scroll-view>

  <!-- 文章列表 -->
  <block wx:if="{{articles.length>0}}">
    <view class="list">
      <view wx:for="{{articles}}" wx:key="id" class="card" bindtap="goDetail" data-id="{{item.id}}">
        <image src="{{item.cover_image||item.image_url||''}}" mode="aspectFill" class="ci"/>
        <view class="cb">
          <text class="ct">{{item.title||'文章标题'}}</text>
          <text class="cd">{{item.summary||item.description||''}}</text>
          <view class="cm">
            <text class="cauth" wx:if="{{item.author}}">{{item.author}}</text>
            <text class="cdate">{{item.published_at||item.created_at||''}}</text>
          </view>
        </view>
      </view>
    </view>
  </block>

  <!-- 空状态 -->
  <view class="emp" wx:if="{{articles.length===0 && !loading}}">
    <view class="ei-icon">📄</view>
    <text class="et">暂无杂志文章，敬请期待</text>
  </view>

  <view class="ld" wx:if="{{loading}}"><text>加载中...</text></view>

  <!-- 底部CTA -->
  <view class="bottom-cta" wx:if="{{articles.length===0&&!loading}}">
    <text class="bt-title">订阅完整内容</text>
  </view>

  <view class="sbtm"></view>
</view>
