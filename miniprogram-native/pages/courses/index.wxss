page{background:#f5f3f0;}

/* Hero */
.hero{background:linear-gradient(160deg,#2d1b2e 0%,#4a3a5a 100%);padding:50rpx 28rpx 36rpx;text-align:center;}
.ht{font-size:40rpx;font-weight:bold;color:#fff;display:block;letter-spacing:2rpx;}
.hs{font-size:25rpx;color:rgba(255,255,255,.75);display:block;margin-top:10rpx;}

/* Hub */
.hub{margin:24rpx 24rpx 0;}
.hub-row{display:flex;gap:20rpx;margin-bottom:20rpx;}
.hub-card{flex:1;background:#fff;border-radius:20rpx;padding:28rpx 20rpx;display:flex;flex-direction:column;align-items:center;box-shadow:0 4rpx 16rpx rgba(0,0,0,.04);}
.hub-card-dark{background:linear-gradient(135deg,#2d1b2e,#4a3a5a);}
.hub-card-dark .hub-title{color:#fff;}
.hub-card-dark .hub-desc{color:rgba(255,255,255,.85);}
.hub-icon{font-size:48rpx;}
.hub-title{font-size:28rpx;font-weight:bold;color:#2d1b2e;margin-top:14rpx;}
.hub-desc{font-size:20rpx;color:#999;text-align:center;margin-top:6rpx;line-height:1.4;}

/* Section */
.section{margin:24rpx;background:#fff;border-radius:24rpx;padding:28rpx;box-shadow:0 4rpx 16rpx rgba(0,0,0,.04);}
.sec-title{font-size:32rpx;font-weight:bold;color:#2d1b2e;display:block;margin-bottom:20rpx;}

/* Activities */
.act-list{display:flex;flex-direction:column;gap:16rpx;}
.act-card{padding:28rpx;border-radius:18rpx;position:relative;overflow:hidden;}
.act-card::before{content:'';position:absolute;inset:0;background:linear-gradient(90deg,transparent,rgba(255,255,255,.15));}
.act-tag{position:absolute;top:16rpx;right:16rpx;font-size:20rpx;padding:4rpx 14rpx;border-radius:20rpx;background:rgba(255,255,255,.25);color:#fff;}
.act-title{font-size:30rpx;font-weight:bold;color:#fff;display:block;position:relative;z-index:2;}
.act-desc{font-size:22rpx;color:rgba(255,255,255,.85);display:block;margin-top:8rpx;position:relative;z-index:2;}
.act-free{background:linear-gradient(135deg,#2d1b2e,#4a3a4b);}
.act-tools{background:linear-gradient(135deg,#4caf50,#2e7d32);}
.act-camp{background:linear-gradient(135deg,#2d1b2e,#4a3a5a);}

/* Tabs */
.tabs{display:flex;padding:16rpx 24rpx;background:#fff;border-bottom:1rpx solid #eee;margin-top:24rpx;}
.tab{flex:1;display:flex;align-items:center;justify-content:center;gap:8rpx;padding:18rpx 0;border-radius:14rpx;font-size:27rpx;color:#666;background:#f5f3f0;margin-right:16rpx;}
.tab:last-child{margin-right:0;}
.tab-on{background:#2d1b2e;color:#fff;font-weight:700;}
.ticon{font-size:26rpx;}

/* 筛选 */
.filters{display:flex;gap:20rpx;padding:16rpx 24rpx;background:#fff;border-bottom:1rpx solid #f0ece8;}
.fil{display:flex;align-items:center;gap:6rpx;padding:10rpx 22rpx;border-radius:30rpx;border:1rpx solid #ddd;font-size:25rpx;color:#666;background:#fff;}
.fi{font-size:22rpx;color:#999;}
.ft{font-size:25rpx;}

/* 列表 */
.list{padding:16rpx 20rpx;}
.card{display:flex;background:#fff;border-radius:18rpx;margin-bottom:18rpx;overflow:hidden;box-shadow:0 2rpx 12rpx rgba(0,0,0,.04);}
.ci{width:220rpx;height:180rpx;flex-shrink:0;background:#eee;}
.cb{flex:1;padding:20rpx;display:flex;flex-direction:column;justify-content:space-between;}
.ct{font-size:29rpx;font-weight:600;color:#1a1a2e;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;line-height:1.4;}
.cd{font-size:23rpx;color:#888;margin-top:6rpx;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;line-height:1.4;}
.cm{display:flex;align-items:center;margin-top:10rpx;}
.ccat{font-size:20rpx;color:#2d1b2e;background:#fce4ec;padding:3rpx 14rpx;border-radius:12rpx;margin-right:10rpx;}
.cdur{font-size:21rpx;color:#aaa;margin-left:auto;margin-right:12rpx;}
.cprice{font-size:30rpx;color:#2d1b2e;font-weight:bold;}
.cfree{font-size:27rpx;color:#4caf50;font-weight:600;}
.cbuy{margin-left:auto;font-size:24rpx;color:#2d1b2e;font-weight:600;}

/* 空/加载 */
.emp{text-align:center;padding:120rpx 0;}
.et{font-size:28rpx;color:#ccc;display:block;}
.ld{text-align:center;padding:80rpx 0;color:#999;font-size:26rpx;}

/* CTA区 */
.cta-section{text-align:center;padding:40rpx 30rpx 60rpx;}
.cta-title{font-size:34rpx;font-weight:bold;color:#1a1a2e;display:block;margin-bottom:10rpx;}
.cta-sub{font-size:25rpx;color:#888;display:block;}

.sbtm{height:30rpx;}
