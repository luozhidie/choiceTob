<view class="page">
  <!-- Hero -->
  <view class="hero">
    <text class="ht">预约在线课程</text>
    <text class="hs">专业形象课程 + 搭配任务 + 美学工具</text>
  </view>

  <!-- Hub 入口 -->
  <view class="hub">
    <view class="hub-row">
      <view class="hub-card" bindtap="goCourseBooking">
        <text class="hub-icon">📚</text>
        <text class="hub-title">课程预约</text>
        <text class="hub-desc">AI赋能·服装精英销售特训营</text>
      </view>
      <view class="hub-card" bindtap="goStyling">
        <text class="hub-icon">🎨</text>
        <text class="hub-title">搭配任务</text>
        <text class="hub-desc">发布你的搭配需求</text>
      </view>
    </view>
    <view class="hub-row">
      <view class="hub-card" bindtap="goQuiz">
        <text class="hub-icon">📝</text>
        <text class="hub-title">试题练习</text>
        <text class="hub-desc">巩固形象专业知识</text>
      </view>
      <view class="hub-card" bindtap="goColor">
        <text class="hub-icon">🎨</text>
        <text class="hub-title">配色练习</text>
        <text class="hub-desc">提升色彩搭配能力</text>
      </view>
    </view>
  </view>

  <!-- 最新活动 -->
  <view class="section">
    <text class="sec-title">最新活动</text>
    <view class="act-list">
      <view class="act-card act-free" bindtap="goActivity" data-type="free">
        <text class="act-tag">免费</text>
        <text class="act-title">智能形象诊断</text>
        <text class="act-desc">AI+专业搭配师双重诊断</text>
      </view>
      <view class="act-card act-tools" bindtap="goActivity" data-type="tools">
        <text class="act-tag">工具</text>
        <text class="act-title">解锁美学工具</text>
        <text class="act-desc">色彩卡/风格尺一站购齐</text>
      </view>
      <view class="act-card act-camp" bindtap="goActivity" data-type="camp">
        <text class="act-tag">特训营</text>
        <text class="act-title">美学搭配精英特训营</text>
        <text class="act-desc">AI赋能·服装精英销售特训营</text>
      </view>
    </view>
  </view>

  <!-- 双Tab -->
  <view class="tabs">
    <view class="tab {{activeTab==='course'?'tab-on':''}}" bindtap="swTab" data-t="course">
      <text class="ticon">📖</text><text>线上课程</text>
    </view>
    <view class="tab {{activeTab==='tool'?'tab-on':''}}" bindtap="swTab" data-t="tool">
      <text class="ticon">🛒</text><text>工具商城</text>
    </view>
  </view>

  <!-- 筛选 -->
  <view class="filters" wx:if="{{activeTab==='course'}}">
    <view class="fil"><text class="fi">🔽</text><text class="ft">{{catLabel}} ▾</text></view>
    <view class="fil"><text class="ft">{{diffLabel}} ◆</text></view>
  </view>

  <!-- 课程列表 -->
  <block wx:if="{{activeTab==='course'}}">
    <view class="list" wx:if="{{courses.length>0}}">
      <view wx:for="{{courses}}" wx:key="id" class="card" bindtap="playCourse" data-id="{{item.id}}">
        <image src="{{item.cover||''}}" mode="aspectFill" class="ci"/>
        <view class="cb">
          <text class="ct">{{item.title}}</text>
          <text class="cd">{{item.description}}</text>
          <view class="cm">
            <text class="ccat" wx:if="{{item.category}}">{{item.category}}</text>
            <text class="cdur" wx:if="{{item.duration}}">{{item.duration}}</text>
            <text class="cprice" wx:if="{{item.price>0}}">¥{{item.price}}</text>
            <text class="cfree" wx:else>免费</text>
          </view>
        </view>
      </view>
    </view>
    <view class="emp" wx:if="{{courses.length===0 && !loading}}">
      <text class="et">暂无已发布的课程</text>
    </view>
  </block>

  <!-- 工具商城 -->
  <block wx:if="{{activeTab==='tool'}}">
    <view class="list" wx:if="{{tools.length>0}}">
      <view wx:for="{{tools}}" wx:key="id" class="card" bindtap="goTool" data-id="{{item.id}}">
        <image src="{{item.image||''}}" mode="aspectFill" class="ci"/>
        <view class="cb">
          <text class="ct">{{item.name||item.title}}</text>
          <text class="cd">{{item.desc||item.description}}</text>
          <view class="cm">
            <text class="cprice">¥{{item.price||0}}</text>
            <text class="cbuy">立即购买</text>
          </view>
        </view>
      </view>
    </view>
    <view class="emp" wx:if="{{tools.length===0&&!loading}}">
      <text class="et">暂无工具商品</text>
    </view>
  </block>

  <view class="ld" wx:if="{{loading}}"><text>加载中...</text></view>

  <!-- CTA -->
  <view class="cta-section" wx:if="{{!loading}}">
    <text class="cta-title">专业课程 · 一站式提升</text>
    <text class="cta-sub">形象课程 + 搭配任务 + 美学工具，系统提升你的审美力</text>
  </view>

  <view class="sbtm"></view>
</view>
