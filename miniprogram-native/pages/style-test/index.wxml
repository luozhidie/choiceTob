<view class="page">
  <!-- 标题 -->
  <view class="hd">
    <text class="ht">{{testTitle}}</text>
    <text class="hs">{{testDesc}}</text>
  </view>

  <!-- 女士测试表单 -->
  <scroll-view scroll-y class="form-scroll" wx:if="{{testMode==='female'}}">
    <view class="form">
      <view class="pay-info">
        <text class="pay-title">女士风格专业诊断</text>
        <text class="pay-desc">17道深度诊断题 + AI色彩匹配报告 + 专业搭配建议 + 微信结果通知</text>
      </view>
      <view class="q"><text class="ql">1. 你的名字 <text class="req">*</text></text><input class="qin" placeholder="请输入" value="{{fForm.name}}" bindinput="onFName"/></view>
      <view class="q"><text class="ql">2. 你的微信号 <text class="req">*</text></text><input class="qin" placeholder="请输入微信号（用于联系）" value="{{fForm.wechat}}" bindinput="onFWechat"/></view>
      <view class="q"><text class="ql">3. 年龄 <text class="req">*</text></text><input class="qin" type="number" placeholder="请输入" value="{{fForm.age}}" bindinput="onFAge"/></view>

      <view class="q"><text class="ql">4. 看上去会比同龄人（）？<text class="req">*</text></text></view>
      <view class="opts">
        <view wx:for="{{optAgeLook}}" wx:key="*this" class="opt {{fForm.q5===item?'opt-on':''}}" bindtap="pickFQ5" data-v="{{item}}">{{item}}</view>
      </view>

      <view class="q"><text class="ql">5. 身高：<text class="req">*</text></text><input class="qin" type="digit" placeholder="请输入" value="{{fForm.height}}" bindinput="onFHeight"/></view>

      <view class="q"><text class="ql">6. 你看起来身高和实际相比会：<text class="req">*</text></text></view>
      <view class="opts">
        <view wx:for="{{optHeightVisual}}" wx:key="*this" class="opt {{fForm.q7===item?'opt-on':''}}" bindtap="pickFQ7" data-v="{{item}}">{{item}}</view>
      </view>

      <view class="q"><text class="ql">7. 体型偏：<text class="req">*</text></text></view>
      <view class="opts">
        <view wx:for="{{optBodyType}}" wx:key="*this" class="opt {{fForm.q8===item?'opt-on':''}}" bindtap="pickFQ8" data-v="{{item}}">{{item}}</view>
      </view>

      <view class="q"><text class="ql">8. 脸型偏向：</text></view>
      <view class="opts">
        <view wx:for="{{optFaceType}}" wx:key="*this" class="opt {{fForm.q9===item?'opt-on':''}}" bindtap="pickFQ9" data-v="{{item}}">{{item}}</view>
      </view>

      <view class="q"><text class="ql">9. 肤色倾向：</text></view>
      <view class="opts">
        <view wx:for="{{optSkinColor}}" wx:key="*this" class="opt {{fForm.q10===item?'opt-on':''}}" bindtap="pickFQ10" data-v="{{item}}">{{item}}</view>
      </view>

      <view class="q"><text class="ql">10. 青春期发育相比同龄人：<text class="req">*</text></text></view>
      <view class="opts">
        <view wx:for="{{optDevlop}}" wx:key="*this" class="opt {{fForm.q11===item?'opt-on':''}}" bindtap="pickFQ11" data-v="{{item}}">{{item}}</view>
      </view>

      <view class="q"><text class="ql">11. 洗完脸后皮肤会不会白一些？<text class="req">*</text></text></view>
      <view class="opts">
        <view wx:for="{{optSkinAfterWash}}" wx:key="*this" class="opt {{fForm.q12===item?'opt-on':''}}" bindtap="pickFQ12" data-v="{{item}}">{{item}}</view>
      </view>

      <view class="q"><text class="ql">12. 平时会不会容易脸红？<text class="req">*</text></text></view>
      <view class="opts">
        <view wx:for="{{optBlush}}" wx:key="*this" class="opt {{fForm.q13===item?'opt-on':''}}" bindtap="pickFQ13" data-v="{{item}}">{{item}}</view>
      </view>

      <view class="q"><text class="ql">13. 风格偏好：</text></view>
      <view class="opts">
        <view wx:for="{{optStylePref}}" wx:key="*this" class="opt {{fForm.q14===item?'opt-on':''}}" bindtap="pickFQ14" data-v="{{item}}">{{item}}</view>
      </view>

      <view class="submit-btn {{canPay?'sb-ok':'sb-dis'}}" bindtap="submitFemale"><text>⊙ 提交</text></view>
    </view>
  </scroll-view>

  <!-- 男士测试表单 -->
  <scroll-view scroll-y class="form-scroll" wx:if="{{testMode==='male'}}">
    <view class="form">
      <view class="pay-info pay-blue">
        <text class="pay-title">男士风格专业诊断</text>
        <text class="pay-desc">14道深度诊断题 + AI色彩匹配报告 + 穿搭建议方案 + 微信结果通知</text>
      </view>
      <view class="q"><text class="ql">1. 你的名字 <text class="req">*</text></text><input class="qin" placeholder="请输入" value="{{mForm.name}}" bindinput="onMName"/></view>
      <view class="q"><text class="ql">2. 你的微信号 <text class="req">*</text></text><input class="qin" placeholder="请输入微信号（用于联系）" value="{{mForm.wechat}}" bindinput="onMWechat"/></view>
      <view class="q"><text class="ql">3. 年龄 <text class="req">*</text></text><input class="qin" type="number" placeholder="请输入" value="{{mForm.age}}" bindinput="onMAge"/></view>

      <view class="q"><text class="ql">4. 看上去会比同龄人（）？<text class="req">*</text></text></view>
      <view class="opts">
        <view wx:for="{{optAgeLook}}" wx:key="*this" class="opt {{mForm.q5===item?'opt-on':''}}" bindtap="pickMQ5" data-v="{{item}}">{{item}}</view>
      </view>

      <view class="q"><text class="ql">5. 身高：<text class="req">*</text></text><input class="qin" type="digit" placeholder="请输入" value="{{mForm.height}}" bindinput="onMHeight"/></view>

      <view class="q"><text class="ql">6. 体型偏：<text class="req">*</text></text></view>
      <view class="opts">
        <view wx:for="{{optBodyType}}" wx:key="*this" class="opt {{mForm.q8===item?'opt-on':''}}" bindtap="pickMQ8" data-v="{{item}}">{{item}}</view>
      </view>

      <view class="q"><text class="ql">7. 风格偏好：</text></view>
      <view class="opts">
        <view wx:for="{{optStylePrefMale}}" wx:key="*this" class="opt {{mForm.q9===item?'opt-on':''}}" bindtap="pickMQ9" data-v="{{item}}">{{item}}</view>
      </view>

      <view class="submit-btn {{canPay?'sb-ok':'sb-dis'}}" bindtap="submitMale"><text>⊙ 提交</text></view>
    </view>
  </scroll-view>

  <!-- 提示 -->
  <view class="tip"><text>{{tipText}}</text></view>
</view>
