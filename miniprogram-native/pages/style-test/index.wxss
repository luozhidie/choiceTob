page{background:#f8f6f4;}

/* 头 */
.hd{text-align:center;padding:36rpx 24rpx 20rpx;}
.ht{font-size:38rpx;font-weight:bold;color:#1a1a2e;display:block;letter-spacing:1rpx;}
.hs{font-size:24rpx;color:#888;display:block;margin-top:6rpx;}

/* 测试会员购买卡片 */
.member-card{display:flex;align-items:center;gap:16rpx;margin:0 28rpx 20rpx;padding:22rpx 24rpx;
  border-radius:20rpx;background:linear-gradient(135deg,#fff0f5,#fce4ec);border:2rpx solid #f8bbd0;box-shadow:0 6rpx 20rpx rgba(233,30,99,.12);}
.mc-blue{background:linear-gradient(135deg,#eaf4ff,#e3f2fd);border-color:#bbdefb;box-shadow:0 6rpx 20rpx rgba(25,118,210,.12);}
.mc-left{flex:1;display:flex;flex-direction:column;gap:4rpx;min-width:0;}
.mc-title{font-size:28rpx;font-weight:bold;color:#c2185b;}
.mc-blue .mc-title{color:#1565c0;}
.mc-desc{font-size:20rpx;color:#888;line-height:1.4;}
.mc-btn{flex-shrink:0;padding:18rpx 32rpx;border-radius:40rpx;background:linear-gradient(135deg,#e91e63,#d81b60);
  color:#fff;font-size:26rpx;font-weight:bold;box-shadow:0 4rpx 12rpx rgba(233,30,99,.3);}
.mc-blue .mc-btn{background:linear-gradient(135deg,#1976d2,#1565c0);box-shadow:0 4rpx 12rpx rgba(25,118,210,.3);}
.mc-done{background:#bbb;color:#fff;box-shadow:none;}

/* 表单滚动区 */
.form-scroll{height:calc(100vh - 280rpx);}
.form{padding:0 28rpx 40rpx;}

/* 付费提示卡片 */
.pay-info{background:linear-gradient(135deg,#fce4ec,#f8bbd0);border-radius:20rpx;padding:24rpx 28rpx;margin-bottom:24rpx;}
.pay-blue{background:linear-gradient(135deg,#e3f2fd,#bbdefb);}
.pay-title{font-size:30rpx;font-weight:bold;color:#c2185b;display:block;margin-bottom:6rpx;}
.pay-blue .pay-title{color:#1565c0;}
.pay-desc{font-size:22rpx;color:#666;display:block;line-height:1.5;}

/* 题目 */
.q{margin-bottom:18rpx;}
.ql{font-size:27rpx;color:#333;font-weight:500;display:block;margin-bottom:10rpx;line-height:1.5;}
.req{color:#e91e63;}
.qin{width:100%;height:80rpx;background:#fff;border:2rpx solid #e0ddd8;border-radius:14rpx;padding:0 22rpx;font-size:27rpx;color:#333;box-sizing:border-box;}

/* 选项 */
.opts{display:flex;flex-wrap:wrap;gap:12rpx;}
.opt{
  flex:1;min-width:140rpx;
  padding:18rpx 16rpx;
  border-radius:14rpx;
  border:2rpx solid #e0ddd8;
  font-size:26rpx;color:#555;
  text-align:center;
  background:#fff;
  box-sizing:border-box;
}
.opt-on{border-color:#2d1b2e;color:#2d1b2e;background:#f5f0eb;font-weight:600;}

/* 提交按钮 */
.submit-btn{text-align:center;margin:36rpx 0 20rpx;}
.sb-ok,.sb-dis{display:inline-block;padding:22rpx 120rpx;border-radius:40rpx;font-size:30rpx;font-weight:bold;}
.sb-ok{background:#2d1b2e;color:#fff;}
.sb-dis{background:#ccc;color:#999;}

/* 底部提示 */
.tip{text-align:center;padding:10rpx 40rpx 24rpx;font-size:22rpx;color:#bbb;line-height:1.5;}
