.page { min-height: 100vh; background: var(--bg); }

.header {
  display: flex; align-items: center; gap: 20rpx;
  padding: 16rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background: #fff;
  position: sticky; top: 0; z-index: 100;
}
.back, .home {
  width: 56rpx; height: 56rpx;
  display: flex; align-items: center; justify-content: center;
  color: #666; font-size: 40rpx;
}
.title {
  flex: 1; text-align: center; font-size: 28rpx; font-weight: 500; color: #333;
  padding-right: 132rpx;
}

.hero {
  padding: 40rpx 30rpx 30rpx;
  background: linear-gradient(135deg, #2d1b2e, #4a2c4d);
  color: #fff;
}
.hero-title { display: block; font-size: 36rpx; font-weight: 700; }
.hero-sub { display: block; margin-top: 10rpx; font-size: 24rpx; opacity: 0.8; }

.sub-entry {
  margin: 24rpx;
  padding: 24rpx 28rpx;
  background: #fff;
  border-radius: 16rpx;
  display: flex; align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}
.se-icon { font-size: 36rpx; }
.se-text { flex: 1; margin-left: 16rpx; font-size: 28rpx; color: #333; font-weight: 500; }
.se-go { color: #bbb; font-size: 32rpx; }

.loading { text-align: center; padding: 80rpx 0; color: #999; font-size: 26rpx; }
.empty { text-align: center; padding: 100rpx 0; color: #999; }
.empty-icon { display: block; font-size: 80rpx; margin-bottom: 16rpx; }
.empty-text { font-size: 26rpx; }

.market-grid {
  display: flex; flex-wrap: wrap;
  padding: 8rpx 16rpx 40rpx;
}
.market-item {
  width: 25%;
  display: flex; flex-direction: column; align-items: center;
  padding: 20rpx 0;
}
.market-avatar {
  width: 110rpx; height: 110rpx;
  border-radius: 50%;
  background: #eee;
}
.market-ph {
  display: flex; align-items: center; justify-content: center;
  color: #fff; font-size: 40rpx; font-weight: 700;
  background: linear-gradient(135deg, #c9a36a, #b07d3e);
}
.market-name {
  margin-top: 14rpx;
  font-size: 24rpx; color: #333;
  max-width: 140rpx;
  overflow: hidden; white-space: nowrap; text-overflow: ellipsis;
}
.market-loc {
  font-size: 20rpx; color: #999;
  max-width: 140rpx;
  overflow: hidden; white-space: nowrap; text-overflow: ellipsis;
}
