<view class="page">
  <!-- 空状态 -->
  <block wx:if="{{cartItems.length === 0 && !loading}}">
    <view class="empty-state">
      <text class="empty-icon">📦</text>
      <text class="empty-text">购物车空空如也</text>
      <view class="empty-btn" bindtap="goBuyer">
        <text>去选品 →</text>
      </view>
    </view>
  </block>

  <!-- 购物车列表 -->
  <block wx:else>
    <!-- 头部 -->
    <view class="cart-header">
      <text class="cart-title">购物车 ({{totalCount}}件)</text>
      <text class="cart-clear" bindtap="clearCart">清空</text>
    </view>

    <!-- 商品列表 -->
    <view class="cart-list">
      <view class="cart-item" wx:for="{{cartItems}}" wx:key="id">
        <!-- 选择框 -->
        <view
          class="check-box {{item.checked ? 'checked' : ''}}"
          bindtap="toggleCheck"
          data-id="{{item.id}}">
          {{item.checked ? '✓' : ''}}
        </view>

        <!-- 图片 -->
        <image
          src="{{item.image || '/assets/placeholder.png'}}"
          mode="aspectFill"
          class="item-img"
          lazy-load />

        <!-- 信息 -->
        <view class="item-info">
          <text class="item-name">{{item.name}}</text>
          <text class="item-price">{{item.price}}</text>
        </view>

        <!-- 数量控制 -->
        <view class="qty-control">
          <view class="qty-btn" bindtap="decreaseQty" data-id="{{item.id}}">−</view>
          <text class="qty-num">{{item.quantity}}</text>
          <view class="qty-btn" bindtap="increaseQty" data-id="{{item.id}}">+</view>
        </view>

        <!-- 删除 -->
        <view class="delete-btn" bindtap="removeItem" data-id="{{item.id}}">删除</view>
      </view>
    </view>

    <!-- 底部结算栏 -->
    <view class="checkout-bar">
      <view class="select-all" bindtap="toggleAllCheck">
        <view class="check-box-small {{allChecked ? 'checked' : ''}}">{{allChecked ? '✓' : ''}}</view>
        <text>全选</text>
      </view>
      <view class="total-area">
        <text class="total-label">合计：</text>
        <text class="total-price">{{totalPrice}}</text>
      </view>
      <view class="checkout-btn {{selectedCount === 0 ? 'disabled' : ''}}" bindtap="goCheckout">
        结算({{selectedCount}})
      </view>
    </view>
  </block>

  <view class="safe-bottom"></view>
</view>
