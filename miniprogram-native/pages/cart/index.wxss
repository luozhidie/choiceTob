/* ===== 购物车页 ===== */
page { background: #f5f2ef; }

/* 空状态 */
.empty-state { text-align: center; padding: 160rpx 0; }
.empty-icon { font-size: 100rpx; display: block; filter: grayscale(1); opacity: 0.25; margin-bottom: 20rpx; }
.empty-text { font-size: 30rpx; color: #ccc; display: block; margin-bottom: 36rpx; }
.empty-btn { display: inline-flex; padding: 22rpx 48rpx; background: linear-gradient(to right,#ff7a3d,#ff5722); color: #fff; font-size: 27rpx; font-weight: 700; border-radius: 20rpx; }

/* 头部 */
.cart-header { display: flex; justify-content: space-between; align-items: center; padding: 28rpx 28rpx 16rpx; }
.cart-title { font-size: 34rpx; font-weight: 700; color: #1a1a2e; }
.cart-clear { font-size: 25rpx; color: #2d1b2e; padding: 8rpx 16rpx; }

/* 列表 */
.cart-list { padding: 0 24rpx; }

.cart-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 18rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 16rpx;
  position: relative;
}

/* 选择框 */
.check-box {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  border: 3rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #fff;
  margin-right: 18rpx;
  flex-shrink: 0;
}
.check-box.checked { background: #2d1b2e; border-color: #2d1b2e; }

/* 图片 */
.item-img {
  width: 150rpx;
  height: 150rpx;
  border-radius: 12rpx;
  background: #f5f2ef;
  margin-right: 18rpx;
  flex-shrink: 0;
}

/* 信息 */
.item-info { flex: 1; min-width: 0; overflow: hidden; }
.item-name { font-size: 26rpx; color: #333; font-weight: 500; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.35; }
.item-price { font-size: 30rpx; color: #2d1b2e; font-weight: 800; display: block; margin-top: 10rpx; }

/* 数量控制 */
.qty-control { display: flex; align-items: center; gap: 6rpx; margin-top: 14rpx; }
.qty-btn {
  width: 46rpx;
  height: 46rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f2ef;
  border-radius: 10rpx;
  font-size: 28rpx;
  color: #666;
}
.qty-num { width: 56rpx; text-align: center; font-size: 27rpx; font-weight: 600; color: #333; }

/* 删除按钮 */
.delete-btn { position: absolute; top: 24rpx; right: 20rpx; font-size: 23rpx; color: #bbb; padding: 4rpx 12rpx; }

/* 底部结算栏 */
.checkout-bar {
  display: flex;
  align-items: center;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 110rpx;
  background: #fff;
  padding: 0 24rpx;
  box-shadow: 0 -4rpx 24rpx rgba(0,0,0,0.06);
  z-index: 100;
}

.select-all { display: flex; align-items: center; gap: 10rpx; font-size: 26rpx; color: #666; }

.check-box-small {
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  border: 3rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #fff;
}
.check-box-small.checked { background: #2d1b2e; border-color: #2d1b2e; }

.total-area { flex: 1; text-align: right; margin-right: 24rpx; }
.total-label { font-size: 26rpx; color: #666; }
.total-price { font-size: 36rpx; color: #2d1b2e; font-weight: 900; }

.checkout-btn {
  background: linear-gradient(to right,#ec4899,#ef4444);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  padding: 20rpx 44rpx;
  border-radius: 40rpx;
}
.checkout-btn.disabled { opacity: 0.4; }

.safe-bottom { height: 130rpx; }
