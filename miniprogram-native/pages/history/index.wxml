<view class="page">
  <view class="hd">
    <text class="ht">👁 浏览记录</text>
    <text class="hs">最近看过的商品（{{list.length}}条）</text>
  </view>

  <!-- 清空 -->
  <view class="clr-bar" wx:if="{{list.length>0}}" bindtap="clearAll">
    <text>清空全部</text>
  </view>

  <!-- 列表 -->
  <view class="list" wx:if="{{list.length>0}}">
    <view class="card" wx:for="{{list}}" wx:key="id" bindtap="goShop" data-id="{{item.id}}">
      <image src="{{item.image||''}}" mode="aspectFill" class="ci"/>
      <view class="cb">
        <text class="ct">{{item.name||'商品'}}</text>
        <text class="cd">{{item.timeStr}}</text>
      </view>
      <text class="del" catchtap="delOne" data-idx="{{index}}">✕</text>
    </view>
  </view>

  <!-- 空 -->
  <view class="emp" wx:if="{{!loading && list.length===0}}">
    <text class="ei">📭</text>
    <text class="et">暂无浏览记录</text>
    <view class="eb" bindtap="goHome">去逛逛 →</view>
  </view>

  <view class="ld" wx:if="{{loading}}"><text>加载中...</text></view>
</view>
