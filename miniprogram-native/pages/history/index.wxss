page{background: var(--bg);min-height:100vh;}
.hd{padding:30rpx 24rpx 16rpx;}
.ht{font-size:38rpx;font-weight:bold;color:#1a1a2e;display:block;margin-bottom:6rpx;}
.hs{font-size:24rpx;color:#999;}

.clr-bar{text-align:right;padding:10rpx 28rpx;}
.clr-bar text{font-size:25rpx;color:#2d1b2e;padding:8rpx 0;}

.list{padding:0 20rpx;}
.card{display:flex;align-items:center;background:#fff;border-radius:14rpx;margin-bottom:14rpx;overflow:hidden;position:relative;padding:16rpx;}
.ci{width:120rpx;height:120rpx;border-radius:10rpx;flex-shrink:0;background:#eee;margin-right:20rpx;}
.cb{flex:1;min-width:0;}
.ct{font-size:27rpx;font-weight:500;color:#1a1a2e;display:block;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:360rpx;}
.cd{font-size:22rpx;color:#bbb;display:block;margin-top:6rpx;}
.del{position:absolute;top:12rpx;right:12rpx;font-size:26rpx;color:#ccc;width:44rpx;height:44rpx;line-height:44rpx;text-align:center;}

.emp{text-align:center;padding:120rpx 0;}
.ei{font-size:80rpx;display:block;margin-bottom:16rpx;color:#ccc;}
.et{color:#999;font-size:26rpx;display:block;margin-bottom:24rpx;}
.eb{display:inline-block;background:#1a1a2e;color:#fff;padding:18rpx 48rpx;border-radius:36rpx;font-size:27rpx;}

.ld{text-align:center;padding:80rpx 0;color:#999;font-size:26rpx;}
