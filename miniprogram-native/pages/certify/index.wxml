<view class="page">
  <!-- ═══ Step 1: 开场（暗色+金色） ═══ -->
  <block wx:if="{{step==='intro'}}">
    <view class="hero-section">
      <view class="hero-badge">认证店主 · 开通批发价</view>
      <text class="hero-title">填写店铺信息，即刻开通批发价查看权</text>
      <view class="hero-line"></view>
      <text class="hero-sub">信息将同步至后台店铺管理，便于后续为您推荐款式、开展服务</text>
    </view>

    <view class="intro-card">
      <view class="ic-header"><text class="ic-gold">认证后可享 4 大权益</text></view>
      <view class="ic-grid">
        <view class="ic-item"><text class="ic-icon">👁️</text><view class="ic-body"><text class="ic-name">批发价查看权</text><text class="ic-desc">认证即可查看所有商品批发价</text></view></view>
        <view class="ic-item"><text class="ic-icon">🎁</text><view class="ic-body"><text class="ic-name">退换额度</text><text class="ic-desc">充值后享阶梯退换额度</text></view></view>
        <view class="ic-item"><text class="ic-icon">✨</text><view class="ic-body"><text class="ic-name">新款抢先看</text><text class="ic-desc">当季新品提前浏览推荐</text></view></view>
        <view class="ic-item"><text class="ic-icon">📈</text><view class="ic-body"><text class="ic-name">精准推荐</text><text class="ic-desc">基于店铺画像匹配款式</text></view></view>
      </view>
    </view>

    <button class="btn-hero" bindtap="goForm">填写店铺信息，开通认证 →</button>
  </block>

  <!-- ═══ Step 2: 基本信息 ═══ -->
  <block wx:if="{{step==='base'}}">
    <view class="nav-bar">
      <text bindtap="goBackStep" class="back-btn">← 上一步</text>
      <text class="nav-title">店铺基本信息</text><text></text>
    </view>
    <view class="form-wrap">
      <view class="field"><text class="label req">店铺名称</text><input class="input" value="{{name}}" placeholder="如：巴黎春天女装店" bindinput="onName"/></view>
      <view class="field"><text class="label">联系人</text><input class="input" value="{{contact}}" placeholder="如：张小姐" bindinput="onContact"/></view>
      <view class="field"><text class="label">联系电话</text><input class="input" type="number" value="{{phone}}" placeholder="如：13800138000" bindinput="onPhone"/></view>
      <view class="field"><text class="label">微信号</text><input class="input" value="{{wechat}}" placeholder="如：luozhidie" bindinput="onWechat"/></view>
      <view class="field"><text class="label">所在城市</text><input class="input" value="{{city}}" placeholder="如：杭州" bindinput="onCity"/></view>
      <view class="field"><text class="label">商圈/地段</text><input class="input" value="{{district}}" placeholder="如：武林银泰" bindinput="onDistrict"/></view>

      <view class="field"><text class="label">店铺面积</text>
        <picker mode="selector" range="{{shopSizeOptions}}" value="{{shopSizeIndex}}" bindchange="onShopSize">
          <view class="picker">{{shopSizeOptions[shopSizeIndex]}}</view>
        </picker>
      </view>
      <view class="field"><text class="label">风格定位</text>
        <picker mode="selector" range="{{styleOptions}}" value="{{styleIndex}}" bindchange="onStyle">
          <view class="picker">{{styleOptions[styleIndex]}}</view>
        </picker>
      </view>
      <view class="field"><text class="label">目标年龄层</text>
        <picker mode="selector" range="{{ageOptions}}" value="{{ageIndex}}" bindchange="onAge">
          <view class="picker">{{ageOptions[ageIndex]}}</view>
        </picker>
      </view>
      <view class="field"><text class="label">价格带</text>
        <picker mode="selector" range="{{priceOptions}}" value="{{priceIndex}}" bindchange="onPrice">
          <view class="picker">{{priceOptions[priceIndex]}}</view>
        </picker>
      </view>

      <button class="btn-primary" bindtap="goBiz">下一步：填写经营数据 →</button>
    </view>
  </block>

  <!-- ═══ Step 3: 经营数据 ═══ -->
  <block wx:if="{{step==='biz'}}">
    <view class="nav-bar">
      <text bindtap="goBackStep" class="back-btn">← 上一步</text>
      <text class="nav-title">店铺经营数据</text><text></text>
    </view>
    <view class="form-wrap">
      <view class="field"><text class="label">月租金（元）</text><input class="input" type="digit" value="{{rent}}" placeholder="选填" bindinput="onRent"/></view>
      <view class="field"><text class="label">保本点（元/月）</text><input class="input" type="digit" value="{{breakeven}}" placeholder="选填" bindinput="onBreakeven"/></view>
      <view class="field"><text class="label">毛利率（如 0.55）</text><input class="input" type="digit" value="{{grossMargin}}" placeholder="选填" bindinput="onGross"/></view>
      <view class="field"><text class="label">净利率（如 0.2）</text><input class="input" type="digit" value="{{netMargin}}" placeholder="选填" bindinput="onNet"/></view>
      <view class="field"><text class="label">月营业额（元）</text><input class="input" type="digit" value="{{turnover}}" placeholder="选填" bindinput="onTurnover"/></view>
      <view class="field"><text class="label">流量渠道</text><input class="input" value="{{channels}}" placeholder="选填，逗号分隔，如：小红书，抖音，线下" bindinput="onChannels"/></view>
      <view class="field"><text class="label">当前流行趋势</text><input class="input" value="{{trends}}" placeholder="选填，逗号分隔，如：新中式，莫兰迪色" bindinput="onTrends"/></view>
      <view class="field"><text class="label">备注</text><textarea class="textarea" value="{{notes}}" placeholder="选填" bindinput="onNotes"/></view>

      <button class="btn-primary btn-lg {{submitting?'submitting':''}}" bindtap="submitCertify" disabled="{{submitting}}">
        {{submitting?'提交中...':'提交认证，开通批发价 🛡'}}
      </button>
      <text wx:if="{{submitError}}" class="err-text">{{submitError}}</text>
    </view>
  </block>

  <!-- ═══ Step 4: 成功 ═══ -->
  <block wx:if="{{step==='done'}}">
    <view class="done-section">
      <view class="done-icon">👑</view>
      <text class="done-title">认证成功！🎉</text>
      <text class="done-sub">店铺信息已同步至后台，批发价已开通</text>
      <view class="done-benefits">
        <view class="done-item done-ok"><text>✅ 批发价已解锁</text></view>
        <view class="done-item"><text>🎁 退换额度（充值后生效）</text></view>
        <view class="done-item"><text>✨ 新款抢先看</text></view>
        <view class="done-item"><text>📈 精准款式推荐</text></view>
      </view>
      <button class="btn-accent" bindtap="goBuyer">去看款拿货</button>
      <button class="btn-outline" bindtap="goMy">前往个人中心</button>
    </view>
  </block>
</view>

<!-- 未登录引导层 -->
<view wx:if="{{needLogin}}" class="login-mask">
  <view class="login-card">
    <text class="login-title">请先登录</text>
    <text class="login-desc">认证店主需先登录账号</text>
    <button class="btn-primary login-btn" bindtap="goLogin">去登录</button>
    <text class="login-cancel" bindtap="goHome">返回首页</text>
  </view>
</view>
