<view class="page">
  <!-- 顶部导航 -->
  <view class="nav-bar" wx:if="{{step!=='intro'&&step!=='done'}}">
    <text bindtap="goBackStep" class="back-btn">← 上一步</text>
    <text class="nav-title">认证店主</text>
    <text></text>
  </view>

  <!-- ═══ Step 1: 开场（暗色+金色设计） ═══ -->
  <block wx:if="{{step==='intro'}}">
    <!-- 暗色 Hero 区域 -->
    <view class="hero-section">
      <view class="hero-badge">为了维护店主权益</view>
      <text class="hero-title">所有店主均需通过认证后才能看款/拿货！</text>
      <view class="hero-line"></view>
    </view>

    <!-- 权益卡片区 -->
    <view class="benefits-card">
      <view class="bc-header">
        <text class="bc-gold">通过认证 尊享4大权益</text>
      </view>
      <view class="bc-grid">
        <view class="bc-item">
          <text class="bc-icon">🏷️</text>
          <view class="bc-body"><text class="bc-name">每日上新不停</text><text class="bc-desc">3000家档口每日上新5千款</text></view>
        </view>
        <view class="bc-item">
          <text class="bc-icon">📦</text>
          <view class="bc-body"><text class="bc-name">一件起批不囤货</text><text class="bc-desc">接近源头价</text></view>
        </view>
        <view class="bc-item">
          <text class="bc-icon">🛡️</text>
          <view class="bc-body"><text class="bc-name">退货无忧</text><text class="bc-desc">支持退货卡+库存回购</text></view>
        </view>
        <view class="bc-item">
          <text class="bc-icon">💁</text>
          <view class="bc-body"><text class="bc-name">360°拿货服务</text><text class="bc-desc">爆款推荐+1V1顾问+线下沙龙</text></view>
        </view>
      </view>
    </view>

    <!-- 答题规则 -->
    <view class="rules-card">
      <text class="rules-title">答题规则：</text>
      <text class="rules-line">1. 累计需答6道题，每道题15秒</text>
      <text class="rules-line">2. 满足对率即可通过认证</text>
      <text class="rules-line">3. 未通过可参与其他认证方式</text>
      <text class="rules-line">4. 若发现作弊现象，则取消认证资格</text>
    </view>

    <button class="btn-hero" bindtap="goQuiz">开始认证答题 →</button>
  </block>

  <!-- ═══ Step 2: 答题（扁平字段） ═══ -->
  <block wx:if="{{step==='quiz'}}">
    <view class="quiz-section">
      <view class="progress-bar">
        <text class="progress-text">题目 {{quizIdx+1}}/6</text>
        <view class="progress-track"><view class="progress-fill" style="width:{{(quizIdx+1)/6*100}}%"></view></view>
      </view>

      <view class="question-card">
        <text class="q-badge">第 {{quizIdx+1}} 题</text>
        <text class="q-text">{{qText}}</text>

        <view class="options">
          <view class="option {{optACls}}" bindtap="pickA" data-idx="0">
            <text class="opt-letter">A</text><text>{{optAText}}</text>
          </view>
          <view class="option {{optBCls}}" bindtap="pickB" data-idx="1">
            <text class="opt-letter">B</text><text>{{optBText}}</text>
          </view>
          <view class="option {{optCCls}}" wx:if="{{optCText}}" bindtap="pickC" data-idx="2">
            <text class="opt-letter">C</text><text>{{optCText}}</text>
          </view>
        </view>

        <view wx:if="{{showResult}}" class="{{isCorrect?'result-ok':'result-fail'}}">
          <text>{{resultText}}</text>
        </view>
      </view>

      <button wx:if="{{!showResult}}" class="btn-primary {{btnDisabled?'btn-disabled':''}}" bindtap="confirmAnswer" disabled="{{btnDisabled}}">{{btnText}}</button>
      <button wx:else class="btn-accent" bindtap="nextQuestion">{{btnText}}</button>
    </view>
  </block>

  <!-- ═══ Step 3: 通过 ═══ -->
  <block wx:if="{{step==='passed'}}">
    <view class="pass-section">
      <view class="pass-icon">✅</view>
      <text class="pass-title">恭喜通过！</text>
      <text class="pass-sub">您已具备服装批发行业基础知识</text>
      <text class="pass-highlight">开启您的拿货之旅吧！</text>
      <button class="btn-primary" bindtap="goStyle">下一步：填写经营风格 →</button>
    </view>
  </block>

  <!-- ═══ Step 4: 风格 ═══ -->
  <block wx:if="{{step==='style'}}">
    <view class="form-section">
      <text class="form-title">您常拿什么风格的货？</text>
      <text class="form-desc">帮助我们为您推荐更精准的商品</text>
      <view class="tag-group">
        <view class="tag {{tag0Cls}}" data-idx="0" bindtap="toggleStyle">淑女风</view>
        <view class="tag {{tag1Cls}}" data-idx="1" bindtap="toggleStyle">知性风</view>
        <view class="tag {{tag2Cls}}" data-idx="2" bindtap="toggleStyle">名媛风</view>
        <view class="tag {{tag3Cls}}" data-idx="3" bindtap="toggleStyle">中性风</view>
        <view class="tag {{tag4Cls}}" data-idx="4" bindtap="toggleStyle">潮牌风</view>
        <view class="tag {{tag5Cls}}" data-idx="5" bindtap="toggleStyle">职业风</view>
        <view class="tag {{tag6Cls}}" data-idx="6" bindtap="toggleStyle">休闲风</view>
        <view class="tag {{tag7Cls}}" data-idx="7" bindtap="toggleStyle">大牌风</view>
      </view>
      <input class="form-input" value="{{styleInput}}" placeholder="如：韩系女装、日系休闲..." bindinput="onStyleInput"/>
      <button class="btn-primary" bindtap="goRecommend">下一步：获取推荐 →</button>
    </view>
  </block>

  <!-- ═══ Step 5: 推荐 ═══ -->
  <block wx:if="{{step==='recommend'}}">
    <view class="form-section">
      <text class="form-title">为您推荐当季市场的畅销风格</text>
      <text class="form-desc">基于您选择的风格偏好</text>
      <view class="rec-grid">
        <view class="rec-item" wx:for="{{recStyles}}" wx:key="*this">
          <text class="rec-sparkle">✨</text>
          <text class="rec-name">{{item}}</text>
          <text class="rec-sub">{{STYLE_MAP[item]||'当季热销'}}</text>
        </view>
      </view>
      <button class="btn-primary" bindtap="goSales">下一步：填写月销售额 →</button>
    </view>
  </block>

  <!-- ═══ Step 6: 月销售额 ═══ -->
  <block wx:if="{{step==='sales'}}">
    <view class="form-section">
      <text class="form-title">输入您上月销售额</text>
      <text class="form-desc">看看自己在全国的销售排名</text>
      <input class="form-input form-input-lg" type="digit" value="{{salesInput}}" placeholder="如：50000" bindinput="onSalesInput"/>
      <text class="tip-text">仅用于排名估算，不会公开</text>
      <button class="btn-primary" bindtap="goRank">查看我的排名 →</button>
    </view>
  </block>

  <!-- ═══ Step 7: 排名 ═══ -->
  <block wx:if="{{step==='rank'}}">
    <view class="rank-section">
      <view class="rank-trophy"><text class="rank-tri">🏆</text></view>
      <text class="rank-title">您上月超过了全国 <text class="rank-pct">{{rankPercent}}%</text> 的店主</text>
      <text class="rank-sales" wx:if="{{salesInput}}">月销 ¥{{salesInput}} · {{salesRankText}}</text>
      <view class="rank-hint-box"><text class="rank-hint">💡 排名基于当前平台数据估算，随着用户积累将越来越准确。</text></view>
      <button class="btn-primary btn-lg {{submitting?'submitting':''}}" bindtap="submitCertify" disabled="{{submitting}}">
        {{submitting?'提交中...':'完成认证，开启批发价 🛡'}}
      </button>
      <text wx:if="{{submitError}}" class="err-text">{{submitError}}</text>
    </view>
  </block>

  <!-- ═══ Step 8: 权益完成卡 ═══ -->
  <block wx:if="{{step==='benefits'}}">
    <view class="benefits-done-section">
      <view class="bd-crown"><text class="bd-ci">👑</text></view>
      <text class="bd-title">认证成功！🎉</text>
      <text class="bd-sub">您已获得以下店主权益</text>
      <view class="bd-card bd-green">
        <text class="bd-ci-sm">👁️</text>
        <view class="bd-body"><text class="bd-name">✅ 批发价已解锁</text><text class="bd-desc">所有商品批发价立即可见，免费使用</text></view>
      </view>
      <view class="bd-card">
        <text class="bd-ci-sm">🎁</text>
        <view class="bd-body">
          <text class="bd-name">退换额度（充值后生效）</text>
          <view class="tier-grid">
            <view class="tier-cell tc-blue"><text class="tc-amt">充5万</text><text class="tc-rate">退换5%</text></view>
            <view class="tier-cell tc-amber"><text class="tc-amt">充10万</text><text class="tc-rate">退换10%</text></view>
            <view class="tier-cell tc-purple"><text class="tc-amt">充30万</text><text class="tc-rate">退换20%</text></view>
          </view>
        </view>
      </view>
      <view class="bd-card">
        <text class="bd-ci-sm">✨</text>
        <view class="bd-body"><text class="bd-name">新款抢先看</text><text class="bd-desc">当季新品提前浏览，热门款式优先推送</text></view>
      </view>
      <view class="bd-card">
        <text class="bd-ci-sm">📈</text>
        <view class="bd-body"><text class="bd-name">全国销售排名</text><text class="bd-desc">您上月超过了全国 <text class="rank-pct-sm">{{rankPercent}}%</text> 的店主</text></view>
      </view>
      <button class="btn-accent btn-lg" bindtap="goBuyer">去看款拿货</button>
      <button class="btn-outline" bindtap="goMy">前往个人中心</button>
    </view>
  </block>

  <!-- ═══ Step 9: 完成 ═══ -->
  <block wx:if="{{step==='done'}}">
    <view class="done-section">
      <view class="done-icon">👑</view>
      <text class="done-title">认证成功！</text>
      <view class="done-benefits">
        <view class="done-item done-ok"><text>✅ 批发价已解锁</text></view>
        <view class="done-item"><text>💰 退换额度</text></view>
        <view class="done-item"><text>🌟 新款抢先看</text></view>
        <view class="done-item"><text>📈 全国排名</text></view>
      </view>
      <button class="btn-accent" bindtap="goBuyer">去看款拿货</button>
      <button class="btn-outline" bindtap="goHome">返回首页</button>
    </view>
  </block>
</view>

<!-- 未登录引导层 -->
<view wx:if="{{needLogin}}" class="login-mask">
  <view class="login-card">
    <text class="login-title">请先登录</text>
    <text class="login-desc">认证店主需先登录账号</text>
    <button class="btn-primary login-btn" bindtap="goLogin">去登录</button>
    <text class="login-cancel" bindtap="goHome">返回首页</text>
  </view>
</view>
