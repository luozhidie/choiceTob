<view class="page">
  <!-- 顶部导航 -->
  <view class="nav-bar">
    <text wx:if="{{step!=='intro'&&step!=='done'}}" bindtap="goBackStep" class="back-btn">← 上一步</text>
    <text class="nav-title">认证店主</text>
    <text></text>
  </view>

  <!-- Step 1: 开场 -->
  <block wx:if="{{step==='intro'}}">
    <view class="intro-section">
      <view class="intro-icon"><text class="icon-shield">🛡️</text></view>
      <text class="intro-title">认证店主</text>
      <text class="intro-desc">为了让您更好的拿货，\n所有店主均需通过认证后才能看款/拿货！</text>

      <view class="benefit-list">
        <view class="benefit-item" wx:for="{{benefits}}" wx:key="idx">
          <text class="benefit-icon">{{item.icon}}</text>
          <view><text class="benefit-name">{{item.name}}</text><text class="benefit-desc">{{item.desc}}</text></view>
        </view>
      </view>

      <button class="btn-primary" bindtap="goQuiz">开始认证答题 →</button>
      <text class="tip-text">共 6 道行业知识题 · 不限次数可重答</text>
    </view>
  </block>

  <!-- Step 2: 答题 -->
  <block wx:if="{{step==='quiz'}}">
    <view class="quiz-section">
      <!-- 进度 -->
      <view class="progress-bar">
        <text class="progress-text">题目 {{quizIdx+1}}/{{QUIZ.length}}</text>
        <view class="progress-track">
          <view class="progress-fill" style="width:{{(quizIdx+1)/QUIZ.length*100}}%"></view>
        </view>
      </view>

      <!-- 当前题 -->
      <view class="question-card">
        <text class="q-badge">第 {{quizIdx+1}} 题</text>
        <text class="q-text">{{QUIZ[quizIdx].q}}</text>

        <!-- 选项 -->
        <view class="options">
          <block wx:for="{{QUIZ[quizIdx].a}}" wx:key="index">
            <view
              class="option {{showResult && index===QUIZ[quizIdx].c?'option-correct':''}} {{showResult&&selectedAnswer===index&&index!==QUIZ[quizIdx].c?'option-wrong':''}} {{selectedAnswer===index&&!showResult?'option-selected':''}}"
              data-idx="{{index}}"
              bindtap="pickAnswer"
            >
              <text class="option-letter">{{index===0?'A':index===1?'B':'C'}}</text>
              <text>{{item}}</text>
              <text wx:if="{{showResult && index===QUIZ[quizIdx].c}}" class="result-icon">✅</text>
              <text wx:if="{{showResult && selectedAnswer===index && index !== QUIZ[quizIdx].c}}" class="result-icon wrong">❌</text>
            </view>
          </block>
        </view>

        <!-- 结果提示 -->
        <view wx:if="{{showResult}}" class="{{isCorrect?'result-ok':'result-fail'}}">
          <text>{{isCorrect?'✅ 回答正确！':'❌ 回答错误，正确答案是「'+QUIZ[quizIdx].a[QUIZ[quizIdx].c]+'」'}}</text>
        </view>
      </view>

      <!-- 按钮 -->
      <button wx:if="{{!showResult}}" class="btn-primary {{selectedAnswer===null?'btn-disabled':''}}" bindtap="confirmAnswer" disabled="{{selectedAnswer===null}}">确认选择</button>
      <button wx:else class="btn-accent" bindtap="nextQuestion">{{quizIdx<QUIZ.length-1?'下一题':'查看结果'}}</button>
    </view>
  </block>

  <!-- Step 3: 通过 -->
  <block wx:if="{{step==='passed'}}">
    <view class="pass-section">
      <view class="pass-icon">✅</view>
      <text class="pass-title">恭喜通过！</text>
      <text class="pass-sub">您已具备服装批发行业基础知识</text>
      <text class="pass-highlight">开启您的拿货之旅吧！</text>
      <button class="btn-primary" bindtap="goStyle">下一步：填写经营风格 →</button>
    </view>
  </block>

  <!-- Step 4: 风格 -->
  <block wx:if="{{step==='style'}}">
    <view class="form-section">
      <text class="form-title">您常拿什么风格的货？</text>
      <text class="form-desc">帮助我们为您推荐更精准的商品</text>

      <!-- 快捷标签 -->
      <view class="tag-group">
        <block wx:for="{{STYLES}}" wx:key="*this">
          <view
            class="tag {{selectedStyles.indexOf(item)>=0?'tag-active':''}}"
            data-val="{{item}}"
            bindtap="toggleStyle"
          >{{item}}</view>
        </block>
      </view>

      <!-- 自定义输入 -->
      <input
        class="form-input"
        value="{{styleInput}}"
        placeholder="如：韩系女装、日系休闲..."
        bindinput="onStyleInput"
      />

      <button class="btn-primary" bindtap="goSales">下一步：填写月销售额 →</button>
    </view>
  </block>

  <!-- Step 5: 销售额 -->
  <block wx:if="{{step==='sales'}}">
    <view class="form-section">
      <text class="form-title">输入您上月销售额</text>
      <text class="form-desc">看看自己在全国的销售排名</text>

      <input
        class="form-input form-input-lg"
        type="digit"
        value="{{salesInput}}"
        placeholder="如：50000"
        bindinput="onSalesInput"
      />
      <text class="tip-text">仅用于排名估算，不会公开</text>

      <button class="btn-primary btn-lg {{submitting?'submitting':''}}" bindtap="submitCertify" disabled="{{submitting}}">
        {{submitting?'提交中...':'完成认证，开启批发价 🎉'}}
      </button>
    </view>
  </block>

  <!-- Step 6: 完成 -->
  <block wx:if="{{step==='done'}}">
    <view class="done-section">
      <view class="done-icon">👑</view>
      <text class="done-title">认证成功！</text>
      <text class="done-desc">您已获得以下店主权益</text>

      <view class="done-benefits">
        <view class="done-item done-ok"><text>✅ 批发价已解锁（免费）</text></view>
        <view class="done-item"><text>💰 退换额度（充值后生效）</text></view>
        <view class="done-item"><text>🌟 新款抢先看</text></view>
        <view class="done-item"><text>📈 全国销售排名</text></view>
      </view>

      <button class="btn-accent" bindtap="goBuyer">去看款拿货</button>
      <button class="btn-outline" bindtap="goHome">返回首页</button>
    </view>
  </block>
</view>

<!-- 未登录引导层 -->
<view wx:if="{{needLogin}}" class="login-mask">
  <view class="login-card">
    <text class="login-title">请先登录</text>
    <text class="login-desc">认证店主需先登录账号</text>
    <button class="btn-primary login-btn" bindtap="goLogin">去登录</button>
    <text class="login-cancel" bindtap="goHome">返回首页</text>
  </view>
</view>

<!-- 数据（开场权益列表）在 JS 中定义，此处仅作占位 -->
<wxs module="utils"/>
