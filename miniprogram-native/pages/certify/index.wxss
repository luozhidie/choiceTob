/* ═══════ 认证店主页面（暗色+金色设计 · 表单版） ═══════ */
page{background:#f5f2ef;min-height:100vh;}

/* ── 导航栏 ── */
.nav-bar{display:flex;align-items:center;justify-content:space-between;padding:16rpx 30rpx;background:#fff;position:sticky;top:0;z-index:100;border-bottom:1rpx solid #ede8e4;}
.nav-title{font-size:34rpx;font-weight:bold;color:#2d1b2e;}
.back-btn{font-size:28rpx;color:#8a7e7b;}

/* ═══ Step 1: 开场 ═══ */
.hero-section{
  background:linear-gradient(160deg,#1a1025 0%,#2d1b3d 35%,#3d2540 70%,#4a3050 100%);
  padding:80rpx 40rpx 64rpx;text-align:center;
}
.hero-badge{
  display:inline-block;border:1rpx solid rgba(184,148,90,0.45);
  color:#b8945a;font-size:22rpx;padding:6rpx 24rpx;
  border-radius:30rpx;margin-bottom:28rpx;letter-spacing:2rpx;
}
.hero-title{display:block;font-size:38rpx;font-weight:bold;color:#b8945a;line-height:1.55;margin-bottom:16rpx;}
.hero-line{width:60rpx;height:4rpx;background:linear-gradient(90deg,#b8945a,transparent);margin:0 auto 24rpx;border-radius:2rpx;}
.hero-sub{display:block;font-size:24rpx;color:#c9b8cf;line-height:1.6;}

.intro-card{
  margin:-30rpx 28rpx 0;background:#fff;border-radius:24rpx;
  padding:36rpx 28rpx 28rpx;box-shadow:0 12rpx 40rpx rgba(0,0,0,0.08);position:relative;z-index:2;
}
.ic-header{text-align:center;margin-bottom:24rpx;}
.ic-gold{font-size:30rpx;font-weight:bold;color:#b8945a;}
.ic-grid{display:flex;flex-wrap:wrap;}
.ic-item{width:48%;display:flex;align-items:center;gap:14rpx;padding:20rpx 12rpx;box-sizing:border-box;}
.ic-icon{font-size:36rpx;width:52rpx;text-align:center;}
.ic-name{display:block;font-size:25rpx;font-weight:600;color:#333;}
.ic-desc{display:block;font-size:19rpx;color:#aaa;margin-top:2rpx;}

.btn-hero{
  display:block;width:calc(100% - 56rpx);margin:32rpx 28rpx 48rpx;
  padding:32rpx 0;background:linear-gradient(135deg,#c44569,#d65a78);
  color:#fff;font-size:32rpx;font-weight:bold;border-radius:24rpx;
  text-align:center;border:none;box-shadow:0 10rpx 36rpx rgba(196,69,105,0.35);
}
.btn-hero::after{border:none;}

/* ═══ Step 2-3: 表单 ═══ */
.form-wrap{padding:32rpx 32rpx 60rpx;}
.field{margin-bottom:28rpx;}
.label{display:block;font-size:26rpx;color:#555;margin-bottom:12rpx;font-weight:500;}
.label.req::before{content:'* ';color:#c44569;}
.input{
  width:100%;padding:24rpx 24rpx;background:#fff;border:2rpx solid #ede8e4;
  border-radius:16rpx;font-size:28rpx;color:#333;box-sizing:border-box;
}
.textarea{
  width:100%;height:140rpx;padding:24rpx;background:#fff;border:2rpx solid #ede8e4;
  border-radius:16rpx;font-size:28rpx;color:#333;box-sizing:border-box;
}
.picker{
  padding:24rpx;background:#fff;border:2rpx solid #ede8e4;
  border-radius:16rpx;font-size:28rpx;color:#333;
}

/* 按钮 */
.btn-primary{
  display:block;width:100%;padding:30rpx 0;
  background:linear-gradient(135deg,#c44569,#e85d75);color:#fff;
  font-size:32rpx;font-weight:bold;border-radius:22rpx;text-align:center;border:none;
  box-shadow:0 8rpx 30rpx rgba(196,69,105,0.28);margin-top:12rpx;
}
.btn-primary::after{border:none;}
.btn-primary.btn-lg{padding:34rpx 0;font-size:34rpx;border-radius:26rpx;}
.btn-primary.submitting{opacity:0.72;}

.btn-accent{
  display:block;width:100%;padding:30rpx 0;
  background:linear-gradient(135deg,#2d1b2e,#4a3a4b);color:#fff;
  font-size:32rpx;font-weight:bold;border-radius:22rpx;text-align:center;border:none;margin-top:24rpx;
}
.btn-accent::after{border:none;}
.btn-outline{
  display:block;width:100%;padding:26rpx 0;background:#fff;color:#8a7e7b;
  font-size:28rpx;border:2rpx solid #ede8e4;border-radius:22rpx;text-align:center;margin-top:16rpx;
}

/* ═══ Step 4: 成功 ═══ */
.done-section{text-align:center;padding:80rpx 40rpx;}
.done-icon{font-size:90rpx;margin-bottom:20rpx;}
.done-title{display:block;font-size:40rpx;font-weight:bold;color:#2d1b2e;margin-bottom:8rpx;}
.done-sub{display:block;font-size:26rpx;color:#8a7e7b;margin-bottom:32rpx;}
.done-benefits{background:#fff;border-radius:20rpx;padding:24rpx;text-align:left;margin-bottom:36rpx;box-shadow:0 4rpx 20rpx rgba(0,0,0,0.04);}
.done-item{padding:18rpx 20rpx;font-size:26rpx;color:#555;border-bottom:1rpx solid #f5f2ef;}
.done-item:last-child{border:none;}
.done-ok{color:#16a34a;font-weight:500;}

/* ── 未登录引导层 ── */
.login-mask{position:fixed;inset:0;background:rgba(0,0,0,0.45);display:flex;align-items:center;justify-content:center;z-index:999;}
.login-card{width:560rpx;background:#fff;border-radius:24rpx;padding:56rpx 40rpx;text-align:center;}
.login-title{display:block;font-size:36rpx;font-weight:bold;color:#2d1b2e;margin-bottom:16rpx;}
.login-desc{display:block;font-size:26rpx;color:#999;margin-bottom:40rpx;}
.login-btn{margin-bottom:24rpx;}
.login-cancel{display:block;font-size:26rpx;color:#999;}

.err-text{display:block;font-size:24rpx;color:#ef4444;text-align:center;margin-top:16rpx;}
