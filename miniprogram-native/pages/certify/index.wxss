/* ═══════ 认证店主页面（暗色+金色设计） ═══════ */
page{background:#f5f2ef;min-height:100vh;}

/* ── 导航栏 ── */
.nav-bar{display:flex;align-items:center;justify-content:space-between;padding:16rpx 30rpx;background:rgba(255,255,255,0.95);position:sticky;top:0;z-index:100;border-bottom:1rpx solid #ede8e4;}
.nav-title{font-size:34rpx;font-weight:bold;color:#2d1b2e;}
.back-btn{font-size:28rpx;color:#8a7e7b;}

/* ═══ Step 1: 开场（暗色Hero） ═══ */
.hero-section{
  background:linear-gradient(160deg,#1a1025 0%,#2d1b3d 35%,#3d2540 70%,#4a3050 100%);
  padding:80rpx 40rpx 60rpx;text-align:center;
  position:relative;
}
.hero-section::before{
  content:'';position:absolute;top:0;left:0;right:0;bottom:0;
  background:url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200"><circle cx="180" cy="20" r="80" fill="rgba(184,148,90,0.04)"/><circle cx="20" cy="180" r="60" fill="rgba(184,148,90,0.03)"/></svg>');
  background-size:100% 100%;pointer-events:none;
}
.hero-badge{
  display:inline-block;border:1rpx solid rgba(184,148,90,0.45);
  color:#b8945a;font-size:22rpx;padding:6rpx 24rpx;
  border-radius:30rpx;margin-bottom:28rpx;letter-spacing:2rpx;
}
.hero-title{
  display:block;font-size:40rpx;font-weight:bold;color:#b8945a;
  line-height:1.55;margin-bottom:16rpx;
}
.hero-line{
  width:60rpx;height:4rpx;background:linear-gradient(90deg,#b8945a,transparent);
  margin:0 auto;border-radius:2rpx;
}

/* 权益卡片 */
.benefits-card{
  margin:-30rpx 28rpx 0;background:#fff;border-radius:24rpx;
  padding:36rpx 28rpx 28rpx;box-shadow:0 12rpx 40rpx rgba(0,0,0,0.08);
  position:relative;z-index:2;
}
.bc-header{text-align:center;margin-bottom:24rpx;}
.bc-gold{font-size:32rpx;font-weight:bold;color:#b8945a;}
.bc-grid{display:flex;flex-wrap:wrap;}
.bc-item{
  width:48%;display:flex;align-items:center;gap:14rpx;
  padding:22rpx 14rpx;background:#faf8f6;border-radius:16rpx;margin-bottom:14rpx;
  box-sizing:border-box;
}
.bc-icon{font-size:38rpx;shrink:0;width:56rpx;text-align:center;}
.bc-name{display:block;font-size:26rpx;font-weight:600;color:#333;}
.bc-desc{display:block;font-size:20rpx;color:#aaa;margin-top:2rpx;}

/* 答题规则 */
.rules-card{
  margin:24rpx 28rpx;background:#fffdf9;border-radius:18rpx;
  padding:28rpx 30rpx;border:1rpx solid #f0e6d8;
}
.rules-title{display:block;font-size:28rpx;font-weight:bold;color:#2d1b2e;margin-bottom:12rpx;}
.rules-line{display:block;font-size:24rpx;color:#8a7e7b;line-height:2;}

/* 主按钮（开场） */
.btn-hero{
  display:block;width:calc(100% - 56rpx);margin:32rpx 28rpx 48rpx;
  padding:32rpx 0;background:linear-gradient(135deg,#c44569,#d65a78);
  color:#fff;font-size:33rpx;font-weight:bold;border-radius:24rpx;
  text-align:center;border:none;box-shadow:0 10rpx 36rpx rgba(196,69,105,0.35);
}
.btn-hero::after{border:none;}

/* ═══ Step 2: 答题 ═══ */
.quiz-section{padding:30rpx 28rpx 40rpx;}
.progress-bar{display:flex;align-items:center;gap:16rpx;margin-bottom:32rpx;}
.progress-text{font-size:24rpx;color:#8a7e7b;shrink:0;}
.progress-track{flex:1;height:8rpx;background:#ede8e4;border-radius:4rpx;overflow:hidden;}
.progress-fill{height:100%;background:linear-gradient(90deg,#c44569,#e85d75);border-radius:4rpx;}

.question-card{background:#fff;border-radius:24rpx;padding:36rpx 30rpx;box-shadow:0 4rpx 20rpx rgba(0,0,0,0.05);}
.q-badge{display:inline-block;background:rgba(196,69,105,0.08);color:#c44569;font-size:22rpx;font-weight:bold;padding:6rpx 18rpx;border-radius:20rpx;margin-bottom:20rpx;}
.q-text{font-size:32rpx;font-weight:bold;color:#2d1b2e;line-height:1.55;display:block;margin-bottom:32rpx;}

.options{display:flex;flex-direction:column;gap:16rpx;margin-bottom:24rpx;}
.option{
  display:flex;align-items:center;gap:16rpx;padding:28rpx 24rpx;
  border:2rpx solid #ede8e4;border-radius:18rpx;font-size:29rpx;color:#444;
  transition:all 0.15s;
}
.option-selected{border-color:#c44569;background:rgba(196,69,105,0.04);color:#c44569;}
.option-correct{border-color:#22c55e;background:rgba(34,197,94,0.06);color:#166534;}
.option-wrong{border-color:#ef4444;background:rgba(239,68,68,0.05);color:#991b1b;}
.opt-letter{
  width:52rpx;height:52rpx;border:2rpx solid currentColor;border-radius:12rpx;
  display:flex;align-items:center;justify-content:center;
  font-size:24rpx;font-weight:bold;shrink:0;
}

.result-ok,.result-fail{
  padding:22rpx 24rpx;border-radius:14rpx;font-size:26rpx;text-align:center;margin-top:16rpx;
}
.result-ok{background:rgba(34,197,94,0.07);color:#166534;}
.result-fail{background:rgba(239,68,68,0.06);color:#991b1b;}

/* 按钮通用 */
.btn-primary{
  display:block;width:100%;padding:30rpx 0;
  background:linear-gradient(135deg,#c44569,#e85d75);color:#fff;
  font-size:32rpx;font-weight:bold;border-radius:22rpx;text-align:center;border:none;
  box-shadow:0 8rpx 30rpx rgba(196,69,105,0.28);
}
.btn-primary::after{border:none;}
.btn-primary.btn-disabled{opacity:0.42;}
.btn-primary.submitting{opacity:0.72;}
.btn-accent{
  display:block;width:100%;padding:30rpx 0;
  background:linear-gradient(135deg,#2d1b2e,#4a3a4b);color:#fff;
  font-size:32rpx;font-weight:bold;border-radius:22rpx;text-align:center;border:none;
  margin-top:24rpx;
}
.btn-accent::after{border:none;}
.btn-outline{
  display:block;width:100%;padding:26rpx 0;background:#fff;color:#8a7e7b;
  font-size:28rpx;border:2rpx solid #ede8e4;border-radius:22rpx;text-align:center;margin-top:16rpx;
}
.btn-lg{padding:34rpx 0;font-size:34rpx;border-radius:26rpx;}

/* ═══ Step 3: 通过 ═══ */
.pass-section{text-align:center;padding:80rpx 40rpx;}
.pass-icon{
  width:140rpx;height:140rpx;border-radius:50%;
  background:linear-gradient(135deg,#22c55e,#16a34a);margin:0 auto 32rpx;
  display:flex;align-items:center;justify-content:center;font-size:72rpx;
}
.pass-title{display:block;font-size:42rpx;font-weight:bold;color:#2d1b2e;margin-bottom:12rpx;}
.pass-sub{display:block;font-size:28rpx;color:#8a7e7b;margin-bottom:12rpx;}
.pass-highlight{display:block;font-size:32rpx;font-weight:bold;color:#c44569;margin-bottom:48rpx;}

/* ═══ Step 4-6: 表单 ═══ */
.form-section{padding:40rpx 32rpx;}
.form-title{display:block;font-size:34rpx;font-weight:bold;color:#2d1b2e;text-align:center;margin-bottom:8rpx;}
.form-desc{display:block;font-size:24rpx;color:#999;text-align:center;margin-bottom:36rpx;}
.tag-group{display:flex;flex-wrap:wrap;gap:14rpx;margin-bottom:28rpx;}
.tag{
  padding:14rpx 26rpx;border:2rpx solid #ede8e4;border-radius:40rpx;
  font-size:24rpx;color:#666;transition:all 0.15s;
}
.tag-active{border-color:#c44569;background:rgba(196,69,105,0.06);color:#c44569;font-weight:500;}
.form-input{width:100%;padding:24rpx;border:2rpx solid #ede8e4;border-radius:16rpx;font-size:28rpx;color:#333;margin-bottom:8rpx;box-sizing:border-box;}
.form-input-lg{font-size:36rpx;font-weight:bold;text-align:center;}
.tip-text{font-size:22rpx;color:#bbb;text-align:center;display:block;}

/* ═══ Step 5: 推荐 ═══ */
.rec-grid{display:grid;grid-template-columns:1fr 1fr;gap:20rpx;margin-bottom:36rpx;}
.rec-item{background:#fff;border-radius:18rpx;padding:28rpx 20rpx;text-align:center;box-shadow:0 2rpx 12rpx rgba(0,0,0,0.04);}
.rec-sparkle{font-size:44rpx;display:block;margin-bottom:8rpx;}
.rec-name{display:block;font-size:28rpx;font-weight:bold;color:#333;margin-bottom:4rpx;}
.rec-sub{font-size:22rpx;color:#bbb;}

/* ═══ Step 7: 排名 ═══ */
.rank-section{text-align:center;padding:60rpx 32rpx 40rpx;}
.rank-trophy{width:140rpx;height:140rpx;border-radius:50%;background:linear-gradient(135deg,#b8945a,#d4a85a);margin:0 auto 24rpx;display:flex;align-items:center;justify-content:center;}
.rank-tri{font-size:64rpx;}
.rank-title{display:block;font-size:34rpx;font-weight:bold;color:#2d1b2e;margin-bottom:8rpx;}
.rank-sales{display:block;font-size:26rpx;color:#8a7e7b;margin-bottom:8rpx;}
.rank-pct{color:#c44569;font-weight:800;font-size:38rpx;}
.rank-hint-box{background:linear-gradient(135deg,#fef8ec,#fde8c4);border-radius:14rpx;padding:20rpx 24rpx;margin:28rpx 0;}
.rank-hint{font-size:24rpx;color:#8a6d2e;line-height:1.5;}

/* ═══ Step 8: 权益完成卡 ═══ */
.benefits-done-section{padding:48rpx 32rpx 60rpx;}
.bd-crown{width:120rpx;height:120rpx;border-radius:30rpx;background:linear-gradient(135deg,#22c55e,#16a34a);margin:0 auto 24rpx;display:flex;align-items:center;justify-content:center;box-shadow:0 8rpx 30rpx rgba(34,197,94,0.3);}
.bd-ci{font-size:56rpx;}
.bd-title{display:block;font-size:38rpx;font-weight:bold;color:#2d1b2e;text-align:center;margin-bottom:6rpx;}
.bd-sub{display:block;font-size:24rpx;color:#999;text-align:center;margin-bottom:36rpx;}
.bd-card{background:#fff;border-radius:18rpx;padding:24rpx;display:flex;gap:16rpx;margin-bottom:16rpx;box-shadow:0 2rpx 12rpx rgba(0,0,0,0.03);}
.bd-card.bd-green{background:linear-gradient(135deg,#ecfdf5,#d1fae5);border:1rpx solid #bbf7d0;}
.bd-ci-sm{font-size:36rpx;shrink:0;margin-top:2rpx;}
.bd-body{flex:1;min-width:0;}
.bd-name{display:block;font-size:27rpx;font-weight:600;color:#333;}
.bd-desc{display:block;font-size:22rpx;color:#999;margin-top:2p;}
.rank-pct-sm{color:#c44569;font-weight:700;}
.tier-grid{display:flex;gap:10rpx;margin-top:10rpx;}
.tier-cell{flex:1;background:#faf8f6;border-radius:10rpx;padding:12rpx 8rpx;text-align:center;}
.tc-blue{border:1rpx solid #bfdbfe !important;}
.tc-amber{border:1rpx solid #fed7aa !important;}
.tc-purple{border:1rpx solid #ddd6fe !important;}
.tc-amt{display:block;font-size:22rpx;font-weight:bold;color:#374151;}
.tc-rate{display:block;font-size:20rpx;color:#6b7280;margin-top:2rpx;}

/* ═══ Step 9: 完成 ═══ */
.done-section{text-align:center;padding:60rpx 40rpx;}
.done-icon{font-size:88rpx;margin-bottom:20rpx;}
.done-title{display:block;font-size:40rpx;font-weight:bold;color:#2d1b2e;margin-bottom:8rpx;}
.done-benefits{background:#fff;border-radius:20rpx;padding:24rpx;text-align:left;margin-bottom:36rpx;}
.done-item{padding:18rpx 20rpx;font-size:26rpx;color:#555;border-bottom:1rpx solid #f5f2ef;}
.done-item:last-child{border:none;}
.done-ok{color:#16a34a;font-weight:500;}

/* ── 未登录引导层 ── */
.login-mask{position:fixed;inset:0;background:rgba(0,0,0,0.45);display:flex;align-items:center;justify-content:center;z-index:999;}
.login-card{width:560rpx;background:#fff;border-radius:24rpx;padding:56rpx 40rpx;text-align:center;}
.login-title{display:block;font-size:36rpx;font-weight:bold;color:#2d1b2e;margin-bottom:16rpx;}
.login-desc{display:block;font-size:26rpx;color:#999;margin-bottom:40rpx;}
.login-btn{margin-bottom:24rpx;}
.login-cancel{display:block;font-size:26rpx;color:#999;}

/* 工具 */
.err-text{display:block;font-size:24rpx;color:#ef4444;text-align:center;margin-top:12rpx;}
