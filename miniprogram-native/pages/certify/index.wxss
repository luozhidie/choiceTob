/* 认证店主页面样式 */
page{background:linear-gradient(180deg,#f8f9ff 0%,#fff 100%);min-height:100vh;}

/* 导航栏 */
.nav-bar{display:flex;align-items:center;justify-content:space-between;padding:12rpx 30rpx;background:rgba(255,255,255,0.92);backdrop-filter:blur(10px);position:sticky;top:0;z-index:100;border-bottom:1rpx solid #f0f0f0;}
.nav-title{font-size:34rpx;font-weight:bold;color:#1a1a2e;}
.back-btn{font-size:28rpx;color:#666;}

/* ── 开场 ── */
.intro-section{padding:60rpx 40rpx;text-align:center;}
.intro-icon{width:140rpx;height:140rpx;border-radius:40rpx;background:linear-gradient(135deg,#4a6cf7,#6366f1);margin:0 auto 40rpx;display:flex;align-items:center;justify-content:center;box-shadow:0 12rpx 40rpx rgba(74,108,247,0.3);}
.icon-shield{font-size:64rpx;}
.intro-title{display:block;font-size:44rpx;font-weight:bold;color:#1a1a2e;margin-bottom:16rpx;}
.intro-desc{display:block;font-size:28rpx;color:#666;line-height:1.6;margin-bottom:48rpx;}

.benefit-list{background:#fff;border-radius:24rpx;padding:32rpx 24rpx;box-shadow:0 4rpx 20rpx rgba(0,0,0,0.04);text-align:left;margin-bottom:40rpx;}
.benefit-item{display:flex;align-items:flex-start;gap:20rpx;padding:20rpx 0;border-bottom:1rpx solid #f5f5f5;}
.benefit-item:last-child{border:none;}
.benefit-icon{font-size:36rpx;shrink:0;}
.benefit-name{display:block;font-size:28rpx;font-weight:600;color:#333;}
.benefit-desc{display:block;font-size:22rpx;color:#999;margin-top:4rpx;}

.btn-primary{display:block;width:100%;padding:28rpx 0;background:linear-gradient(135deg,#e85d5d,#e74c3c);color:#fff;font-size:32rpx;font-weight:bold;border-radius:20rpx;text-align:center;border:none;margin-bottom:16rpx;box-shadow:0 8rpx 30rpx rgba(232,93,93,0.3);}
.btn-primary.btn-disabled{opacity:0.45;}
.btn-primary.submitting{opacity:0.75;}
.btn-accent{display:block;width:100%;padding:28rpx 0;background:linear-gradient(135deg,#4a6cf7,#6366f1);color:#fff;font-size:32rpx;font-weight:bold;border-radius:20rpx;text-align:center;border:none;margin-top:24rpx;}
.btn-outline{display:block;width:100%;padding:24rpx 0;background:#fff;color:#666;font-size:28rpx;border:2rpx solid #eee;border-radius:20rpx;text-align:center;margin-top:16rpx;}
.tip-text{font-size:22rpx;color:#bbb;text-align:center;display:block;}

/* ── 答题 ── */
.quiz-section{padding:30rpx 30rpx 40rpx;}
.progress-bar{display:flex;align-items:center;gap:16rpx;margin-bottom:32rpx;}
.progress-text{font-size:24rpx;color:#888;shrink:0;}
.progress-track{flex:1;height:8rpx;background:#eee;border-radius:4rpx;overflow:hidden;}
.progress-fill{height:100%;background:linear-gradient(90deg,#e85d5d,#e74c3c);border-radius:4rpx;transition:width 0.3s ease;}

.question-card{background:#fff;border-radius:24rpx;padding:36rpx 32rpx;box-shadow:0 4rpx 20rpx rgba(0,0,0,0.04);}
.q-badge{display:inline-block;background:rgba(232,93,93,0.1);color:#e85d5d;font-size:22rpx;font-weight:bold;padding:6rpx 18rpx;border-radius:20rpx;margin-bottom:20rpx;}
.q-text{font-size:32rpx;font-weight:bold;color:#1a1a2e;line-height:1.5;display:block;margin-bottom:32rpx;}

.options{display:flex;flex-direction:column;gap:16rpx;margin-bottom:24rpx;}
.option{display:flex;align-items:center;gap:16rpx;padding:26rpx 24rpx;border:2rpx solid #e8e8e8;border-radius:16rpx;font-size:28rpx;color:#444;transition:all 0.15s;}
.option-selected{border-color:#4a6cf7;background:rgba(74,108,247,0.05);color:#4a6cf7;}
.option-correct{border-color:#22c55e;background:rgba(34,197,94,0.08);color:#166534;}
.option-wrong{border-color:#ef4444;background:rgba(239,68,68,0.06);color:#991b1b;}
.option-letter{width:52rpx;height:52rpx;border:2rpx solid currentColor;border-radius:12rpx;display:flex;align-items:center;justify-content:center;font-size:24rpx;font-weight:bold;shrink:0;}
.result-icon{margin-left:auto;font-size:28rpx;}

.result-ok,.result-fail{padding:20rpx 24rpx;border-radius:14rpx;font-size:26rpx;text-align:center;margin-top:16rpx;}
.result-ok{background:rgba(34,197,94,0.08);color:#166534;}
.result-fail{background:rgba(239,68,68,0.06);color:#991b1b;}

/* ── 通过 ── */
.pass-section{text-align:center;padding:80rpx 40rpx;}
.pass-icon{width:140rpx;height:140rpx;border-radius:50%;background:linear-gradient(135deg,#22c55e,#16a34a);margin:0 auto 32rpx;display:flex;align-items:center;justify-content:center;font-size:72rpx;animation:bounceIn 0.5s ease;}
.pass-title{display:block;font-size:42rpx;font-weight:bold;color:#1a1a2e;margin-bottom:12rpx;}
.pass-sub{display:block;font-size:28rpx;color:#666;margin-bottom:12rpx;}
.pass-highlight{display:block;font-size:32rpx;font-weight:bold;color:#e85d5d;margin-bottom:48rpx;}

@keyframes bounceIn{
  0%{transform:scale(0);}80%{transform:scale(1.1);}100%{transform:scale(1);}
}

/* ── 表单（风格/销售额） ── */
.form-section{padding:40rpx 32rpx;}
.form-title{display:block;font-size:34rpx;font-weight:bold;color:#1a1a2e;text-align:center;margin-bottom:8rpx;}
.form-desc{display:block;font-size:24rpx;color:#999;text-align:center;margin-bottom:36rpx;}

.tag-group{display:flex;flex-wrap:wrap;gap:14rpx;margin-bottom:28rpx;}
.tag{padding:14rpx 26rpx;border:2rpx solid #e8e8e8;border-radius:40rpx;font-size:24rpx;color:#666;transition:all 0.15s;}
.tag-active{border-color:#e85d5d;background:rgba(232,93,93,0.08);color:#e85d5d;font-weight:500;}

.form-input{width:100%;padding:24rpx;border:2rpx solid #e8e8e8;border-radius:16rpx;font-size:28rpx;color:#333;margin-bottom:8rpx;box-sizing:border-box;}
.form-input-lg{font-size:36rpx;font-weight:bold;text-align:center;}

/* ── 完成 ── */
.done-section{text-align:center;padding:60rpx 40rpx;}
.done-icon{font-size:88rpx;margin-bottom:20rpx;}
.done-title{display:block;font-size:40rpx;font-weight:bold;color:#1a1a2e;margin-bottom:8rpx;}
.done-desc{display:block;font-size:26rpx;color:#888;margin-bottom:32rpx;}

.done-benefits{background:#fff;border-radius:20rpx;padding:24rpx;text-align:left;margin-bottom:36rpx;overflow:hidden;}
.done-item{padding:18rpx 20rpx;font-size:26rpx;color:#555;border-bottom:1rpx solid #f5f5f5;}
.done-item:last-child{border:none;}
.done-ok{color:#16a34a;font-weight:500;}
