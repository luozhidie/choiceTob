.page{background:#f5f3f0;min-height:100vh;padding-bottom:calc(160rpx + env(safe-area-inset-bottom));box-sizing:border-box;}

/* Hero */
.hero{width:100%;height:560rpx;background:linear-gradient(135deg,#2d1b2e,#4a2a3e);display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;}
.hero::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at 30% 30%,rgba(201,162,75,.15),transparent 50%);z-index:1;}
.hero-bg{position:absolute;inset:0;width:100%;height:100%;opacity:.3;}
.hero-overlay{display:flex;flex-direction:column;align-items:center;position:relative;z-index:2;}
.hero-title{font-size:54rpx;font-weight:bold;color:#fff;letter-spacing:6rpx;}
.hero-sub{font-size:32rpx;color:#C9A24B;margin-top:20rpx;letter-spacing:4rpx;background:rgba(255,255,255,.12);padding:10rpx 28rpx;border-radius:40rpx;}
.hero-desc{font-size:24rpx;color:rgba(255,255,255,.75);margin-top:16rpx;}

/* 通用区块 */
.block{margin:24rpx;background:#fff;border-radius:24rpx;padding:28rpx;box-shadow:0 4rpx 16rpx rgba(0,0,0,.04);}
.block-clean{padding:20rpx;background:#fff;}
.block-list{display:flex;flex-direction:column;gap:20rpx;}
.full-img{width:100%;border-radius:16rpx;display:block;}
.block-head{display:flex;flex-direction:column;margin-bottom:20rpx;}
.block-title{font-size:32rpx;font-weight:bold;color:#2d1b2e;display:block;}
.block-title-hl{font-size:32rpx;font-weight:bold;color:#C9A24B;display:block;margin-top:4rpx;}
.block-intro{font-size:24rpx;color:#666;display:block;margin-top:10rpx;}
.block-intro2{font-size:22rpx;color:#999;display:block;margin-top:12rpx;line-height:1.7;}

/* 痛点 */
.pain-list{display:flex;flex-direction:column;gap:14rpx;}
.pain-row{display:flex;align-items:flex-start;gap:14rpx;}
.pain-num{flex-shrink:0;width:40rpx;height:40rpx;border-radius:50%;background:#f5f3f0;color:#C9A24B;font-size:24rpx;font-weight:bold;display:flex;align-items:center;justify-content:center;}
.pain-txt{flex:1;font-size:26rpx;color:#555;line-height:1.55;}

/* 流程 */
.flow-list{display:flex;justify-content:space-between;gap:16rpx;margin-top:10rpx;}
.flow-card{flex:1;background:#f8f6f4;border-radius:18rpx;padding:24rpx 12rpx;display:flex;flex-direction:column;align-items:center;}
.flow-num{width:48rpx;height:48rpx;border-radius:50%;background:#2d1b2e;color:#fff;font-size:26rpx;font-weight:bold;display:flex;align-items:center;justify-content:center;margin-bottom:12rpx;}
.flow-t{font-size:25rpx;font-weight:600;color:#2d1b2e;text-align:center;}
.flow-d{font-size:20rpx;color:#999;text-align:center;margin-top:6rpx;line-height:1.4;}

/* 报告 */
.report-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16rpx;margin-top:24rpx;}
.report-card{background:linear-gradient(135deg,#faf8f6,#f5f3f0);border-radius:16rpx;padding:24rpx;border:1rpx solid #eee5df;}
.report-t{font-size:28rpx;font-weight:bold;color:#2d1b2e;display:block;}
.report-d{font-size:20rpx;color:#777;margin-top:8rpx;display:block;line-height:1.5;}

/* 仓库 */
.warehouse-img{width:100%;height:280rpx;border-radius:18rpx;background:#e8e4e0;margin-top:20rpx;overflow:hidden;display:flex;align-items:center;justify-content:center;}
.warehouse-placeholder{font-size:120rpx;opacity:.3;}

.bottom-space{height:40rpx;}

/* 底部固定栏 */
.bottom-bar{position:fixed;left:0;right:0;bottom:0;background:#fff;display:flex;gap:20rpx;padding:20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));box-shadow:0 -4rpx 20rpx rgba(0,0,0,.08);z-index:100;}
.bottom-btn{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;border-radius:40rpx;padding:20rpx 0;}
.bottom-btn:active{opacity:.9;}
.paid{background:#2d1b2e;}
.free{background:#C9A24B;}
.btn-title{font-size:28rpx;font-weight:bold;color:#fff;}
.btn-price{font-size:24rpx;color:rgba(255,255,255,.9);margin-top:4rpx;}
