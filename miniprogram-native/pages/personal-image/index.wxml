<view class="page">
  <!-- Hero -->
  <view class="hero">
    <image wx:if="{{heroImage}}" src="{{heroImage}}" mode="aspectFill" class="hero-bg" />
    <view class="hero-overlay">
      <text class="hero-title">个人形象诊断</text>
      <text class="hero-sub">一次诊断 终身受益</text>
      <text class="hero-desc">让你找到气质提升的本源</text>
    </view>
  </view>

  <!-- 痛点 -->
  <view class="block">
    <view class="block-head">
      <text class="block-title">遇到以下问题</text>
      <text class="block-title-hl">就急需做诊断</text>
    </view>
    <view class="pain-list">
      <view wx:for="{{pains}}" wx:key="*this" class="pain-row">
        <text class="pain-num">{{index+1}}</text>
        <text class="pain-txt">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 服务流程 -->
  <view class="block">
    <text class="block-title">形象诊断服务流程</text>
    <view class="flow-list">
      <view wx:for="{{flow}}" wx:key="t" class="flow-card">
        <view class="flow-num">{{index+1}}</view>
        <view class="flow-body">
          <text class="flow-t">{{item.t}}</text>
          <text class="flow-d">{{item.d}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 报告内容 -->
  <view class="block">
    <text class="block-title">形象报告内容</text>
    <text class="block-intro">一份专业全面的形象报告</text>
    <text class="block-intro2">通过诊断，找准显白本命色，锁定高级风格，越穿越显贵。搭配师每日精准推荐，不用动脑也能一直美。</text>
    <view class="report-grid">
      <view wx:for="{{reports}}" wx:key="t" class="report-card">
        <text class="report-t">{{item.t}}</text>
        <text class="report-d">{{item.d}}</text>
      </view>
    </view>
  </view>

  <!-- 仓库/预约 -->
  <view class="block">
    <text class="block-title">1000+平米南油大仓库</text>
    <text class="block-intro">现场检验诊断结果</text>
    <view class="warehouse-img">
      <view class="warehouse-placeholder">🏭</view>
    </view>
  </view>

  <!-- 底部间距 -->
  <view class="bottom-space"></view>
</view>

<!-- 底部固定三按钮 -->
<view class="bottom-bar">
  <view class="bottom-btn upload" bindtap="goUpload">
    <text class="btn-title-u">资料上传</text>
    <text class="btn-price-u">色彩风格问卷</text>
  </view>
  <view class="bottom-btn free" bindtap="goTest">
    <text class="btn-title">智能形象诊断</text>
    <text class="btn-price">¥99 风格测试</text>
  </view>
  <view class="bottom-btn paid" bindtap="goPaid">
    <text class="btn-title">整体形象诊断</text>
    <text class="btn-price">¥190 预约</text>
  </view>
</view>
