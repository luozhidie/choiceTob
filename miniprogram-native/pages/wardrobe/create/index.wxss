.page{padding:24rpx;background:#f5f3f0;min-height:100vh;box-sizing:border-box;padding-bottom:160rpx;}
.card{background:#fff;border-radius:20rpx;padding:28rpx 28rpx;margin-bottom:22rpx;box-shadow:0 2rpx 10rpx rgba(0,0,0,.04);}
.label{font-size:26rpx;color:#888;display:block;margin-bottom:18rpx;}
.input{width:100%;background:#f5f3f0;border-radius:12rpx;padding:22rpx 24rpx;font-size:28rpx;box-sizing:border-box;}

.scene-row{display:flex;flex-wrap:wrap;gap:16rpx;}
.scene-chip{font-size:26rpx;padding:14rpx 28rpx;border-radius:12rpx;background:#f5f3f0;color:#555;}
.scene-chip.on{background:#2d1b2e;color:#fff;font-weight:600;}

.img-grid{display:flex;flex-wrap:wrap;gap:16rpx;}
.img-cell{width:200rpx;height:200rpx;border-radius:14rpx;overflow:hidden;background:#f0ede9;position:relative;}
.img{width:100%;height:100%;display:block;}
.img-del{position:absolute;top:6rpx;right:6rpx;width:40rpx;height:40rpx;border-radius:50%;background:rgba(0,0,0,.45);color:#fff;display:flex;align-items:center;justify-content:center;font-size:28rpx;}
.img-cell.add{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8rpx;border:2rpx dashed #ccc;background:#faf8f5;box-sizing:border-box;}
.add-icon{font-size:52rpx;color:#bbb;}
.add-txt{font-size:22rpx;color:#999;}

.save-btn{background:#C9A24B;color:#2d1b2e;text-align:center;padding:26rpx 0;border-radius:16rpx;font-size:32rpx;font-weight:600;margin-top:12rpx;}
