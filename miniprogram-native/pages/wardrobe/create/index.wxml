<view class="page">
  <view class="card">
    <text class="label">搭配名称</text>
    <input class="input" placeholder="如：通勤气质西装套装" value="{{form.name}}" bindinput="onName"/>
  </view>

  <view class="card">
    <text class="label">适用场景</text>
    <view class="scene-row">
      <view wx:for="{{scenes}}" wx:key="*this" class="scene-chip {{form.scene===item?'on':''}}" bindtap="setScene" data-scene="{{item}}">{{item}}</view>
    </view>
  </view>

  <view class="card">
    <text class="label">单品照片（最多 9 张）</text>
    <view class="img-grid">
      <view wx:for="{{form.images}}" wx:key="*this" class="img-cell">
        <image class="img" src="{{item}}" mode="aspectFill"/>
        <view class="img-del" bindtap="delImg" data-idx="{{index}}">×</view>
      </view>
      <view wx:if="{{form.images.length<9}}" class="img-cell add" bindtap="chooseImg">
        <text class="add-icon">{{uploading?'...':'＋'}}</text>
        <text class="add-txt">添加</text>
      </view>
    </view>
  </view>

  <view class="save-btn" bindtap="save">保存搭配</view>
</view>
