.page{min-height:100vh;background: var(--bg);padding:24rpx;box-sizing:border-box;padding-bottom:160rpx;}
.card{background:#fff;border-radius:20rpx;padding:28rpx;margin-bottom:20rpx;box-shadow:0 2rpx 10rpx rgba(0,0,0,.04);}
.section-title{font-size:30rpx;color:#333;display:flex;align-items:center;justify-content:space-between;margin-bottom:20rpx;}
.section-title.red{color:#d44949;}
.arrow{font-size:36rpx;color:#ccc;}

.img-row{display:flex;flex-wrap:wrap;gap:16rpx;}
.img-cell{width:160rpx;height:160rpx;border-radius:14rpx;overflow:hidden;background:#f0ede9;position:relative;}
.img{width:100%;height:100%;display:block;}
.img-del{position:absolute;top:6rpx;right:6rpx;width:40rpx;height:40rpx;border-radius:50%;background:rgba(0,0,0,.45);color:#fff;display:flex;align-items:center;justify-content:center;font-size:28rpx;}
.img-cell.add{display:flex;align-items:center;justify-content:center;border:2rpx dashed #ccc;box-sizing:border-box;background:#faf8f5;}
.add-icon{font-size:52rpx;color:#bbb;}

.textarea{width:100%;height:300rpx;background:#f5f3f0;border-radius:12rpx;padding:20rpx 24rpx;font-size:28rpx;box-sizing:border-box;}
.count{text-align:right;font-size:24rpx;color:#999;margin-top:12rpx;display:block;}

.submit-btn{position:fixed;left:24rpx;right:24rpx;bottom:40rpx;background:#000;color:#fff;text-align:center;padding:26rpx 0;border-radius:40rpx;font-size:32rpx;font-weight:600;}
