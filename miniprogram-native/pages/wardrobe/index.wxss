.page{padding:24rpx;background:#f5f3f0;min-height:100vh;box-sizing:border-box;padding-bottom:160rpx;}

/* 分类按钮 */
.cate-row{display:flex;justify-content:space-between;margin-bottom:24rpx;}
.cate-item{display:flex;flex-direction:column;align-items:center;gap:10rpx;flex:1;}
.cate-icon{width:120rpx;height:120rpx;border-radius:24rpx;background:#fff;border:2rpx solid #f0ede9;display:flex;align-items:center;justify-content:center;font-size:56rpx;}
.cate-item.cate-on .cate-icon{border-color:#C9A24B;background:#fffbf3;}
.cate-label{font-size:22rpx;color:#555;}
.cate-item.cate-on .cate-label{color:#2d1b2e;font-weight:600;}

/* 图片网格 */
.grid{display:flex;flex-wrap:wrap;justify-content:space-between;}
.card{width:48%;background:#fff;border-radius:16rpx;overflow:hidden;margin-bottom:20rpx;box-shadow:0 2rpx 10rpx rgba(0,0,0,.04);position:relative;}
.card-img{width:100%;height:320rpx;background:#eee;display:block;}
.card-img.placeholder{display:flex;flex-direction:column;align-items:center;justify-content:center;background:#f0ede9;}
.ph-icon{font-size:56rpx;margin-bottom:8rpx;}
.ph-txt{font-size:22rpx;color:#999;}
.card-info{padding:16rpx;}
.card-title{font-size:26rpx;color:#333;display:block;}
.card-date{font-size:20rpx;color:#999;display:block;margin-top:6rpx;}
.del{position:absolute;top:8rpx;right:8rpx;width:40rpx;height:40rpx;border-radius:50%;background:rgba(0,0,0,.35);color:#fff;display:flex;align-items:center;justify-content:center;font-size:28rpx;}

.empty{padding:80rpx 40rpx;text-align:center;color:#999;font-size:26rpx;}

/* 添加按钮 */
.fab{position:fixed;right:40rpx;bottom:120rpx;width:96rpx;height:96rpx;border-radius:50%;background:#2d1b2e;color:#fff;font-size:48rpx;display:flex;align-items:center;justify-content:center;box-shadow:0 8rpx 24rpx rgba(45,27,46,.35);z-index:10;}

/* 弹窗 */
.modal{position:fixed;inset:0;z-index:20;display:flex;align-items:center;justify-content:center;}
.modal-mask{position:absolute;inset:0;background:rgba(0,0,0,.5);}
.modal-body{position:relative;width:86%;background:#fff;border-radius:24rpx;padding:32rpx;z-index:21;}
.modal-title{font-size:32rpx;font-weight:bold;color:#2d1b2e;display:block;margin-bottom:24rpx;text-align:center;}
.modal-cates{display:flex;flex-wrap:wrap;gap:12rpx;margin-bottom:20rpx;}
.mc{font-size:22rpx;padding:12rpx 20rpx;border-radius:10rpx;background:#f5f3f0;color:#555;}
.mc-on{background:#2d1b2e;color:#fff;}
.mi{width:100%;background:#f5f3f0;border-radius:12rpx;padding:22rpx 24rpx;font-size:28rpx;box-sizing:border-box;margin-bottom:20rpx;}
.upload-box{width:100%;height:240rpx;background:#f5f3f0;border-radius:12rpx;display:flex;align-items:center;justify-content:center;margin-bottom:24rpx;overflow:hidden;}
.up-img{width:100%;height:100%;}
.up-txt{font-size:26rpx;color:#999;}
.modal-btn{background:#C9A24B;color:#2d1b2e;text-align:center;padding:24rpx 0;border-radius:14rpx;font-size:30rpx;font-weight:600;}
