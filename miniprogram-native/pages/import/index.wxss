page {
  padding: 20rpx;
  background: #f5f3f0;
  min-height: 100vh;
}

/* Tab */
.tabs {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}
.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 26rpx;
  color: #888;
  position: relative;
}
.tab-on {
  color: #e91e63;
  font-weight: 700;
}
.tab-on::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #e91e63;
  border-radius: 2rpx;
}

/* 输入区 */
.input-area {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}
.input-single {
  width: 100%;
  padding: 16rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: 12rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}
.input-box {
  width: 100%;
  padding: 16rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: 12rpx;
  font-size: 24rpx;
  min-height: 200rpx;
  box-sizing: border-box;
}

/* 导入按钮 */
.btn-import {
  margin-top: 20rpx;
  background: linear-gradient(135deg, #e91e63, #c2185b);
  color: #fff;
  padding: 22rpx 0;
  text-align: center;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
}
.btn-import-disabled {
  opacity: 0.5;
}

/* 提示 */
.tip {
  margin-top: 20rpx;
  background: #fff7ed;
  border: 1rpx solid #fde68a;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 22rpx;
  color: #92400e;
  line-height: 1.6;
}

/* 结果列表 */
.results {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}
.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0ece8;
}
.rh-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a2e;
}
.rh-view {
  font-size: 24rpx;
  color: #e91e63;
}

/* 结果项 */
.result-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f2ef;
}
.result-item:last-child {
  border-bottom: none;
}
.ri-success {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}
.ri-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}
.ri-info {
  flex: 1;
  min-width: 0;
}
.ri-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1a1a2e;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.ri-detail {
  font-size: 22rpx;
  color: #888;
  margin-top: 4rpx;
  display: inline-block;
  margin-right: 12rpx;
}
.ri-tags {
  margin-top: 6rpx;
}
.ri-cat {
  display: inline-block;
  font-size: 20rpx;
  color: #b06;
  background: #fce4ec;
  border-radius: 6rpx;
  padding: 2rpx 10rpx;
  margin-right: 12rpx;
}
.ri-btn {
  font-size: 22rpx;
  color: #e91e63;
  margin-top: 8rpx;
}
.ri-skipped {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.ri-error {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

/* Toast */
.toast {
  position: fixed;
  bottom: 60rpx;
  left: 50%;
  transform: translateX(-50%);
  padding: 16rpx 32rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #fff;
  z-index: 100;
  animation: toastIn 0.3s ease;
}
.toast-success {
  background: #4caf50;
}
.toast-error {
  background: #f44336;
}

@keyframes toastIn {
  from { opacity: 0; transform: translateX(-50%) translateY(20rpx); }
  to { opacity: 1; transform: translateX(-50%) translateY(0); }
}
