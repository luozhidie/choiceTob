<view class="page">
  <!-- 视频 -->
  <video wx:if="{{videoUrl}}" src="{{videoUrl}}" controls play-btn-center class="vid"></video>

  <!-- 实拍图轮播 -->
  <swiper class="swiper" indicator-dots="{{images.length>1}}" autoplay circular>
    <swiper-item wx:for="{{images}}" wx:key="*this">
      <image src="{{item}}" mode="aspectFill" class="slide-img" />
    </swiper-item>
    <swiper-item wx:if="{{!images || images.length===0}}">
      <view class="ph">暂无图片</view>
    </swiper-item>
  </swiper>

  <!-- 收藏按钮 -->
  <view class="fav-btn {{isFav?'fav-on':''}}" bindtap="toggleFav">♥</view>

  <!-- 模特图横滑 -->
  <scroll-view wx:if="{{modelImages.length>0}}" scroll-x class="model-scroll">
    <text class="model-label">模特图</text>
    <image wx:for="{{modelImages}}" wx:key="*this" src="{{item}}" mode="aspectFill" class="model-img"/>
  </scroll-view>

  <!-- 价格区 -->
  <view class="price-sec">
    <view class="pr-row">
      <text class="price">{{priceText}}</text>
      <text class="ori" wx:if="{{originalPriceText}}">{{originalPriceText}}</text>
      <text class="disc" wx:if="{{discountText}}">{{discountText}}</text>
    </view>
    <text class="sales" wx:if="{{product.sales_count}}">已售 {{product.sales_count}}</text>
    <view class="wp-row" wx:if="{{wholesalePriceText}}">
      <text class="wp-label">批发价</text>
      <text class="wp-val {{isPriceMember?'wp-show':'wp-blur'}}">{{wholesalePriceText}}</text>
      <text class="wp-hint" wx:if="{{!isPriceMember}}" bindtap="goVip">开通会员查看</text>
    </view>
  </view>

  <!-- 商品名 -->
  <view class="name-sec">
    <text class="name">{{product.title || product.name || '商品名称'}}</text>
    <text class="desc">{{product.description || ''}}</text>
  </view>

  <!-- 会员权益 -->
  <view class="member-sec">
    <block wx:if="{{memberTier}}">
      <view class="member-card">
        <view class="member-head"><text class="member-icon">{{memberTier.icon}}</text><text class="member-title">您的会员权益</text></view>
        <view class="member-sub">当前等级：{{memberTier.label}}</view>
        <view class="member-desc">{{memberTier.desc}}</view>
        <view class="member-link" bindtap="goVip">查看全部会员权益 ›</view>
      </view>
    </block>
    <block wx:else>
      <view class="member-card upsell">
        <view class="member-head"><text class="member-icon">👑</text><text class="member-title">开通会员 · 享专属折扣</text></view>
        <view class="member-link" bindtap="goVip">查看全部会员权益 ›</view>
      </view>
    </block>
  </view>

  <!-- 优惠券领券 -->
  <view class="coupon-sec" wx:if="{{couponTpls.length>0}}">
    <text class="sec-title">🎟️ 领券中心</text>
    <scroll-view scroll-x class="coupon-scroll">
      <view class="coupon" wx:for="{{couponTpls}}" wx:key="id">
        <view class="coupon-amt">¥{{item.discountLabel}}</view>
        <view class="coupon-cond">{{item.discount_desc}}</view>
        <view class="coupon-min">{{item.minLabel}}</view>
        <button class="coupon-btn {{item.claimed?'claimed':''}}" bindtap="claimCoupon" data-id="{{item.id}}" disabled="{{item.claimed}}">{{item.claimed?'已领取':'领取'}}</button>
      </view>
    </scroll-view>
  </view>

  <!-- 尺码表 -->
  <view class="size-sec" wx:if="{{sizeChartImage}}">
    <text class="sec-title">📏 尺码</text>
    <image src="{{sizeChartImage}}" mode="widthFix" class="size-img"/>
  </view>

  <!-- 商品参数 -->
  <view class="block-sec" wx:if="{{specList.length>0}}">
    <text class="sec-title">📋 商品参数</text>
    <view class="spec-table">
      <view class="spec-row" wx:for="{{specList}}" wx:key="label">
        <text class="spec-label">{{item.label}}</text>
        <text class="spec-value">{{item.value}}</text>
      </view>
    </view>
  </view>

  <!-- 商品详情 -->
  <view class="block-sec" wx:if="{{product.detail_images && product.detail_images.length>0}}">
    <text class="sec-title">🖼️ 商品详情</text>
    <image wx:for="{{product.detail_images}}" wx:key="*this" src="{{item}}" mode="widthFix" class="detail-img"/>
  </view>

  <!-- 拿货指南 -->
  <view class="block-sec">
    <text class="sec-title">📖 拿货指南</text>
    <view class="guide-item" wx:for="{{wholesaleGuide}}" wx:key="title">
      <text class="guide-t">{{item.title}}</text>
      <text class="guide-d">{{item.desc}}</text>
    </view>
  </view>

  <!-- 拿货技巧 -->
  <view class="block-sec">
    <text class="sec-title">💡 拿货技巧</text>
    <view class="guide-item" wx:for="{{wholesaleTips}}" wx:key="title">
      <text class="guide-t">{{item.title}}</text>
      <text class="guide-d">{{item.desc}}</text>
    </view>
  </view>

  <!-- 用户评价 -->
  <view class="block-sec" wx:if="{{reviews.length>0}}">
    <text class="sec-title">💬 用户评价</text>
    <view class="review" wx:for="{{reviews}}" wx:key="id">
      <view class="rv-header">
        <text class="rv-name">{{item.nickname||'匿名'}}</text>
        <text class="rv-date">{{item.created_at||''}}</text>
      </view>
      <text class="rv-content">{{item.content||''}}</text>
    </view>
  </view>

  <!-- 数量选择 -->
  <view class="qty-sec">
    <text class="ql">数量</text>
    <view class="qb">
      <view class="qbtn" bindtap="dec">-</view>
      <text class="qnum">{{quantity}}</text>
      <view class="qbtn" bindtap="inc">+</view>
    </view>
  </view>

  <!-- 推荐商品 -->
  <view class="rec-sec" wx:if="{{recList.length>0}}">
    <text class="rec-title">搭配推荐</text>
    <scroll-view scroll-x class="rec-scroll">
      <view class="rec-item" wx:for="{{recList}}" wx:key="id" bindtap="goShop" data-id="{{item.id}}">
        <image src="{{item.image_url||item.cover_image||''}}" mode="aspectFill" class="rec-img"/>
        <text class="rec-name">{{item.title||item.name||'商品'}}</text>
        <text class="rec-price">¥{{item.price>100?Math.round(item.price/100):item.price}}</text>
      </view>
    </scroll-view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bar">
    <view class="bar-left">
      <view class="bar-icon" bindtap="goCart">
        <text class="ic">🛒</text>
        <text class="badge" wx:if="{{cartCount>0}}">{{cartCount}}</text>
        <text class="lab">购物车</text>
      </view>
      <view class="bar-icon" bindtap="toggleFav">
        <text class="ic">{{isFav?'♥':'♡'}}</text>
        <text class="lab">{{isFav?'已收藏':'收藏'}}</text>
      </view>
    </view>
    <view class="bar-right">
      <view class="btn-tryon" bindtap="onTryon">{{tryonLoading?'试穿中...':'试穿'}}</view>
      <view class="btn-cart" bindtap="addCart">加入购物车</view>
      <view class="btn-buy" bindtap="buyNow">立即购买</view>
    </view>
  </view>

  <!-- 试穿结果弹层 -->
  <view class="tryon-mask" wx:if="{{showTryon}}" bindtap="closeTryon">
    <view class="tryon-panel" catchtap="stopProp">
      <image src="{{tryonResult}}" mode="widthFix" class="tryon-img"/>
      <view class="tryon-tip" wx:if="{{tryonIsDemo}}">演示效果（示意合成），接入真实引擎后变为真人试穿</view>
      <view class="tryon-close" bindtap="closeTryon">关闭</view>
    </view>
  </view>
</view>
