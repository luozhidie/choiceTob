<view class="page">
  <!-- 自定义顶部导航（透明浮层，覆盖在媒体区上方） -->
  <view class="custom-nav" style="padding-top:{{statusBarHeight}}px;">
    <view class="nav-bar">
      <view class="nav-back" bindtap="goBack">‹</view>
      <view class="nav-fav {{isFav?'fav-on':''}}" bindtap="toggleFav">♥</view>
    </view>
  </view>

  <!-- 媒体轮播：视频 → 模特图 → 实拍图 → 尺码 平铺为统一 swiper，左右滑动切换（对标一手） -->
  <view class="media-area">
    <swiper class="media-swiper" current="{{mediaIndex}}" bindchange="onMediaSwiperChange" indicator-dots="{{false}}" autoplay="{{false}}" wx:if="{{mediaList.length>0}}">
      <swiper-item wx:for="{{mediaList}}" wx:key="*this">
        <block wx:if="{{item.type==='video'}}">
          <video class="media-video" src="{{item.src}}" controls play-btn-center object-fit="cover"></video>
        </block>
        <block wx:elif="{{item.type==='size'}}">
          <scroll-view scroll-y class="media-scroll">
            <image src="{{item.src}}" mode="widthFix" class="media-item-img"/>
          </scroll-view>
        </block>
        <block wx:else>
          <view class="media-item">
            <image src="{{item.src}}" mode="aspectFill" class="media-fit-img"/>
          </view>
        </block>
      </swiper-item>
    </swiper>
    <view wx:else class="ph">暂无图片</view>

    <!-- 媒体切换 Tab：叠在媒体区下方（半透明胶囊） -->
    <view class="media-tab-wrap">
      <scroll-view scroll-x class="media-tab-scroll" scroll-with-animation>
        <view class="media-tab {{mediaTabIndex===index?'active':''}}" wx:for="{{mediaTabs}}" wx:key="key" data-index="{{index}}" bindtap="switchMediaTab">
          {{item.label}}
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 价格区 -->
  <view class="price-sec">
    <view class="pr-row">
      <text class="price">{{priceText}}</text>
      <text class="ori" wx:if="{{originalPriceText}}">{{originalPriceText}}</text>
      <text class="disc" wx:if="{{discountText}}">{{discountText}}</text>
    </view>
    <view class="est-row" wx:if="{{estPriceText}}">
      <text class="est-label">动力预估价</text>
      <text class="est-val">{{estPriceText}}</text>
    </view>
    <text class="sales" wx:if="{{product.sales_count}}">今日已拼 {{product.sales_count}} 件</text>
    <view class="wp-row" wx:if="{{wholesalePriceText}}">
      <text class="wp-label">批发价</text>
      <text class="wp-val {{isPriceMember?'wp-show':'wp-blur'}}">{{wholesalePriceText}}</text>
      <text class="wp-hint" wx:if="{{!isPriceMember}}" bindtap="goVip">开通会员查看</text>
    </view>
  </view>

  <!-- 商品名 -->
  <view class="name-sec">
    <text class="name">{{product.title || product.name || '商品名称'}}</text>
    <text class="desc">{{product.description || ''}}</text>
  </view>

  <!-- 商品标签（会员 / 货源 / 新品 / 自定义） -->
  <view class="tag-row" wx:if="{{tagList.length>0}}">
    <text class="tag" wx:for="{{tagList}}" wx:key="*this">{{item}}</text>
  </view>

  <!-- 选择：尺码 / 颜色 -->
  <view class="block-sec" wx:if="{{sizeOptions.length>0 || colorOptions.length>0}}">
    <text class="sec-title">📐 选择</text>
    <view class="sel-block" wx:if="{{sizeOptions.length>0}}">
      <text class="sel-label">尺码</text>
      <view class="chips">
        <text class="chip {{selectedSize===item?'chip-on':''}}" wx:for="{{sizeOptions}}" wx:key="*this" data-v="{{item}}" bindtap="selectSize">{{item}}</text>
      </view>
    </view>
    <view class="sel-block" wx:if="{{colorOptions.length>0}}">
      <text class="sel-label">颜色</text>
      <view class="chips">
        <text class="chip {{selectedColor===item?'chip-on':''}}" wx:for="{{colorOptions}}" wx:key="*this" data-v="{{item}}" bindtap="selectColor">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 店铺入口卡（进店逛逛→货架） -->
  <view bindtap="goShelf" style="display:flex; align-items:center; background:#fff; margin:8px; padding:12px; border-radius:12px; box-shadow:0 1px 4px rgba(0,0,0,0.04);">
    <view style="width:40px; height:40px; border-radius:50%; background:#fff0f0; display:flex; align-items:center; justify-content:center; font-size:20px; margin-right:10px;">🏪</view>
    <view style="flex:1;">
      <text style="display:block; font-size:15px; font-weight:600; color:#1f1f1f;">{{shopName}}</text>
      <text style="display:block; font-size:12px; color:#999; margin-top:2px;">{{shopIntro || '一手货源 · 一件起批 · 支持退换'}}</text>
    </view>
    <text style="font-size:13px; color:#e4393c;">进店逛逛 ›</text>
  </view>

  <!-- 发货信息条 -->
  <view wx:if="{{shippingNote}}" style="display:flex; align-items:center; background:#f7f8fa; margin:0 8px 8px; padding:10px 12px; border-radius:10px;">
    <text style="font-size:14px; margin-right:6px;">🚚</text>
    <text style="font-size:12px; color:#666; flex:1;">{{shippingNote}}</text>
  </view>

  <!-- 会员权益 -->
  <view class="member-sec">
    <block wx:if="{{memberTier}}">
      <view class="member-card">
        <view class="member-head"><text class="member-icon">{{memberTier.icon}}</text><text class="member-title">您的会员权益</text></view>
        <view class="member-sub">当前等级：{{memberTier.label}}</view>
        <view class="member-desc">{{memberTier.desc}}</view>
        <view class="member-link" bindtap="goVip">查看全部会员权益 ›</view>
      </view>
    </block>
    <block wx:else>
      <view class="member-card upsell">
        <view class="member-head"><text class="member-icon">👑</text><text class="member-title">开通会员 · 享专属折扣</text></view>
        <view class="member-link" bindtap="goVip">查看全部会员权益 ›</view>
      </view>
    </block>
  </view>

  <!-- 优惠券领券 -->
  <view class="coupon-sec" wx:if="{{couponTpls.length>0}}">
    <text class="sec-title">🎟️ 领券中心</text>
    <scroll-view scroll-x class="coupon-scroll">
      <view class="coupon" wx:for="{{couponTpls}}" wx:key="id">
        <view class="coupon-amt">¥{{item.discountLabel}}</view>
        <view class="coupon-cond">{{item.discount_desc}}</view>
        <view class="coupon-min">{{item.minLabel}}</view>
        <button class="coupon-btn {{item.claimed?'claimed':''}}" bindtap="claimCoupon" data-id="{{item.id}}" disabled="{{item.claimed}}">{{item.claimed?'已领取':'领取'}}</button>
      </view>
    </scroll-view>
  </view>

  <!-- 尺码表 -->
  <view class="size-sec" wx:if="{{sizeChartImage}}">
    <text class="sec-title">📏 尺码</text>
    <image src="{{sizeChartImage}}" mode="widthFix" class="size-img"/>
  </view>

  <!-- 商品参数 -->
  <view class="block-sec" wx:if="{{specList.length>0}}">
    <text class="sec-title">📋 商品参数</text>
    <view class="spec-table">
      <view class="spec-row" wx:for="{{specList}}" wx:key="label">
        <text class="spec-label">{{item.label}}</text>
        <text class="spec-value">{{item.value}}</text>
      </view>
    </view>
  </view>

  <!-- 商品详情 -->
  <view class="block-sec" wx:if="{{product.detail_images && product.detail_images.length>0}}">
    <text class="sec-title">🖼️ 商品详情</text>
    <image wx:for="{{product.detail_images}}" wx:key="*this" src="{{item}}" mode="widthFix" class="detail-img"/>
  </view>

  <!-- 拿货指南 -->
  <view class="block-sec">
    <text class="sec-title">📖 拿货指南</text>
    <view class="guide-item" wx:for="{{wholesaleGuide}}" wx:key="title">
      <text class="guide-t">{{item.title}}</text>
      <text class="guide-d">{{item.desc}}</text>
    </view>
  </view>

  <!-- 拿货技巧 -->
  <view class="block-sec">
    <text class="sec-title">💡 拿货技巧</text>
    <view class="guide-item" wx:for="{{wholesaleTips}}" wx:key="title">
      <text class="guide-t">{{item.title}}</text>
      <text class="guide-d">{{item.desc}}</text>
    </view>
  </view>

  <!-- 面料洗护 -->
  <view class="block-sec" wx:if="{{fabricCare}}">
    <text class="sec-title">🧺 面料洗护</text>
    <text class="guide-d">{{fabricCare}}</text>
  </view>

  <!-- 用户评价 -->
  <view class="block-sec" wx:if="{{reviews.length>0}}">
    <text class="sec-title">💬 用户评价</text>
    <view class="review" wx:for="{{reviews}}" wx:key="id">
      <view class="rv-header">
        <text class="rv-name">{{item.nickname||'匿名'}}</text>
        <text class="rv-date">{{item.created_at||''}}</text>
      </view>
      <text class="rv-content">{{item.content||''}}</text>
    </view>
  </view>

  <!-- 数量选择 -->
  <view class="qty-sec">
    <text class="ql">数量</text>
    <view class="qb">
      <view class="qbtn" bindtap="dec">-</view>
      <text class="qnum">{{quantity}}</text>
      <view class="qbtn" bindtap="inc">+</view>
    </view>
  </view>

  <!-- 店铺推荐：档口最新款 -->
  <view class="rec-sec" wx:if="{{shopRecLatest.length>0}}">
    <text class="rec-title">🆕 档口最新款</text>
    <scroll-view scroll-x class="rec-scroll">
      <view class="rec-item" wx:for="{{shopRecLatest}}" wx:key="id" bindtap="goShop" data-id="{{item.id}}">
        <image src="{{item.image_url||item.cover_image||''}}" mode="aspectFill" class="rec-img"/>
        <text class="rec-name">{{item.title||item.name||'商品'}}</text>
        <text class="rec-price">{{item.priceLabel}}</text>
      </view>
    </scroll-view>
  </view>

  <!-- 店铺推荐：档口大爆款 -->
  <view class="rec-sec" wx:if="{{shopRecHot.length>0}}">
    <text class="rec-title">🔥 档口大爆款</text>
    <scroll-view scroll-x class="rec-scroll">
      <view class="rec-item" wx:for="{{shopRecHot}}" wx:key="id" bindtap="goShop" data-id="{{item.id}}">
        <image src="{{item.image_url||item.cover_image||''}}" mode="aspectFill" class="rec-img"/>
        <text class="rec-name">{{item.title||item.name||'商品'}}</text>
        <text class="rec-price">{{item.priceLabel}}</text>
      </view>
    </scroll-view>
  </view>

  <!-- 店铺推荐：新人推荐 -->
  <view class="rec-sec" wx:if="{{shopRecNewbie.length>0}}">
    <text class="rec-title">👤 新人推荐</text>
    <scroll-view scroll-x class="rec-scroll">
      <view class="rec-item" wx:for="{{shopRecNewbie}}" wx:key="id" bindtap="goShop" data-id="{{item.id}}">
        <image src="{{item.image_url||item.cover_image||''}}" mode="aspectFill" class="rec-img"/>
        <text class="rec-name">{{item.title||item.name||'商品'}}</text>
        <text class="rec-price">{{item.priceLabel}}</text>
      </view>
    </scroll-view>
  </view>

  <!-- 相似推荐 -->
  <view class="rec-sec" wx:if="{{recList.length>0}}">
    <text class="rec-title">同款相似推荐</text>
    <scroll-view scroll-x class="rec-scroll">
      <view class="rec-item" wx:for="{{recList}}" wx:key="id" bindtap="goShop" data-id="{{item.id}}">
        <image src="{{item.image_url||item.cover_image||''}}" mode="aspectFill" class="rec-img"/>
        <text class="rec-name">{{item.title||item.name||'商品'}}</text>
        <text class="rec-price">¥{{item.price>100?Math.round(item.price/100):item.price}}</text>
      </view>
    </scroll-view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bar">
    <view class="bar-left">
      <view class="bar-icon" bindtap="toggleFav">
        <text class="ic">{{isFav?'♥':'♡'}}</text>
        <text class="lab">{{isFav?'已收藏':'收藏'}}</text>
      </view>
      <view class="bar-icon" bindtap="goShelf">
        <text class="ic">🏪</text>
        <text class="lab">进店</text>
      </view>
      <view class="bar-icon" bindtap="goCart">
        <text class="ic">🛒</text>
        <text class="badge" wx:if="{{cartCount>0}}">{{cartCount}}</text>
        <text class="lab">进货车</text>
      </view>
    </view>
    <view class="bar-right">
      <view class="btn-cart" bindtap="addCart">加入进货车</view>
      <view class="btn-buy" bindtap="buyNow">立即购买</view>
    </view>
  </view>

  <!-- 试穿结果弹层 -->
  <view class="tryon-mask" wx:if="{{showTryon}}" bindtap="closeTryon">
    <view class="tryon-panel" catchtap="stopProp">
      <image src="{{tryonResult}}" mode="widthFix" class="tryon-img"/>
      <view class="tryon-tip" wx:if="{{tryonIsDemo}}">演示效果（示意合成），接入真实引擎后变为真人试穿</view>
      <view class="tryon-close" bindtap="closeTryon">关闭</view>
    </view>
  </view>
</view>
