page { background: #f5f3f0; }
.page { padding-bottom: 140rpx; }

/* 自定义顶部导航（透明浮层） */
.custom-nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: transparent; pointer-events: none; }
.nav-bar { height: 88rpx; display: flex; align-items: center; justify-content: space-between; padding: 0 20rpx; pointer-events: auto; }
.nav-back, .nav-fav { width: 64rpx; height: 64rpx; background: rgba(0,0,0,.35); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 36rpx; color: #fff; }
.nav-back { font-size: 44rpx; line-height: 1; padding-bottom: 6rpx; }
.nav-fav.fav-on { color: #e91e63; background: rgba(233,30,99,.15); }

/* 商品/档口/详情 吸顶切换：单一白底顶部栏（含返回键 + 居中页签 + 分享键） */
.section-tabs { position: fixed; top: 0; left: 0; right: 0; z-index: 99; background: #fff; border-bottom: 1rpx solid rgba(0,0,0,0.04); box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.04); opacity: 0; pointer-events: none; transform: translateY(-100%); transition: opacity 0.22s ease, transform 0.22s ease; }
.section-tabs.show { opacity: 1; pointer-events: auto; transform: translateY(0); }
.section-tabs-inner { height: 88rpx; display: flex; align-items: center; padding: 0 16rpx; }
.st-back { width: 64rpx; height: 64rpx; display: flex; align-items: center; justify-content: center; font-size: 44rpx; line-height: 1; padding-bottom: 6rpx; color: #333; margin-right: 4rpx; }
.st-tabs { flex: 1; display: flex; align-items: center; justify-content: center; gap: 64rpx; }
.section-tab { font-size: 30rpx; color: #666; position: relative; padding: 12rpx 0; line-height: 1; }
.section-tab.active { color: #e4393c; font-weight: 600; }
.section-tab.active::after { content: ''; position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); width: 56rpx; height: 5rpx; background: #e4393c; border-radius: 4rpx; }
.st-share { width: 64rpx; height: 64rpx; display: flex; align-items: center; justify-content: center; font-size: 34rpx; line-height: 1; color: #333; padding: 0; margin: 0; background: transparent; border: none; }

/* 视频 */
.vid { width: 100%; height: 750rpx; background: #000; display: block; }

/* 媒体轮播（视频 / 模特图 / 实拍图 / 尺码） */
.media-area { position: relative; width: 100%; height: 1000rpx; overflow: hidden; }
.media-swiper { width: 100%; height: 1000rpx; background: #000; }
.media-swiper swiper-item { width: 100%; height: 100%; }
.media-video { width: 100%; height: 100%; display: block; }
.media-scroll { height: 1000rpx; width: 100%; background: #000; }
.media-item-img { width: 100%; display: block; background: #000; }
.media-item { width: 100%; height: 1000rpx; display: flex; align-items: center; justify-content: center; background: #000; }
.media-fit-img { width: 100%; height: 100%; }

/* 图片轮播 */
.swiper { width: 100%; height: 1000rpx; }
.slide-img { width: 100%; height: 100%; }
.ph { width: 100%; height: 1000rpx; background: #eee; display: flex; align-items: center; justify-content: center; color: #ccc; font-size: 28rpx; }

/* 媒体类型切换 Tab（叠在媒体区下方半透明胶囊） */
.media-tab-wrap { position: absolute; bottom: 24rpx; left: 50%; transform: translateX(-50%); z-index: 5; max-width: 86%; background: rgba(255,255,255,0.82); border-radius: 40rpx; padding: 8rpx 14rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08); }
.media-tab-scroll { white-space: nowrap; }
.media-tab { display: inline-block; padding: 10rpx 26rpx; font-size: 26rpx; color: #333; border-radius: 30rpx; }
.media-tab.active { background: #fff; color: #e4393c; font-weight: 600; box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.06); }

/* 价格区 */
.price-sec { background: #fff; padding: 20rpx 24rpx; border-bottom: 1rpx solid #f0ece8; }
.pr-row { display: flex; align-items: baseline; gap: 12rpx; }
.price { font-size: 48rpx; font-weight: 800; color: #e91e63; }
.ori { font-size: 26rpx; color: #aaa; text-decoration: line-through; }
.disc { font-size: 22rpx; color: #4caf50; background: #e8f5e9; padding: 4rpx 14rpx; border-radius: 10rpx; }
.sales { font-size: 23rpx; color: #999; display: block; margin-top: 6rpx; }
.est-row { display: flex; align-items: baseline; gap: 8rpx; margin-top: 8rpx; }
.est-label { font-size: 22rpx; color: #999; }
.est-val { font-size: 28rpx; font-weight: 700; color: #ff6a00; }

/* 批发价区域 */
.wp-row { display: flex; align-items: center; gap: 10rpx; margin-top: 10rpx; padding: 8rpx 12rpx; background: #f0faf0; border-radius: 8rpx; }
.wp-label { font-size: 22rpx; color: #4caf50; font-weight: 600; }
.wp-val { font-size: 28rpx; font-weight: 700; color: #e91e63; }
.wp-blur { letter-spacing: 2rpx; color: #999; }
.wp-hint { font-size: 20rpx; color: #2196f3; margin-left: auto; }

/* 商品名 */
.name-sec { background: #fff; padding: 20rpx 24rpx; margin-top: 8rpx; }
.name { font-size: 32rpx; font-weight: 700; color: #1a1a2e; display: block; line-height: 1.5; }
.desc { font-size: 25rpx; color: #888; display: block; margin-top: 8rpx; line-height: 1.5; }

/* 会员权益卡 */
.member-sec { background: #fff; margin-top: 8rpx; padding: 20rpx 24rpx; }
.member-card { background: linear-gradient(135deg, #fff7ed, #fef3c7); border: 1rpx solid #fde68a; border-radius: 16rpx; padding: 20rpx 24rpx; }
.member-card.upsell { background: #fff; border: 1rpx solid #f0ece8; }
.member-head { display: flex; align-items: center; gap: 12rpx; }
.member-icon { font-size: 40rpx; }
.member-title { font-size: 30rpx; font-weight: 800; color: #b45309; }
.member-sub { font-size: 23rpx; color: #92400e; margin-top: 8rpx; }
.member-desc { font-size: 25rpx; color: #78350f; margin-top: 6rpx; line-height: 1.5; }
.member-link { font-size: 23rpx; color: #e91e63; margin-top: 14rpx; font-weight: 600; }

/* 优惠券领券 */
.coupon-sec { background: #fff; margin-top: 8rpx; padding: 20rpx 24rpx; }
.sec-title { display: block; font-size: 29rpx; font-weight: 700; color: #1a1a2e; margin-bottom: 16rpx; }
.coupon-scroll { white-space: nowrap; }
.coupon { display: inline-block; width: 240rpx; margin-right: 16rpx; vertical-align: top; border-radius: 14rpx; overflow: hidden; border: 1rpx solid #fecdd3; background: #fff1f2; }
.coupon-amt { background: linear-gradient(135deg, #f43f5e, #ec4899); color: #fff; padding: 16rpx; text-align: center; font-size: 40rpx; font-weight: 800; }
.coupon-cond { font-size: 21rpx; color: #9f1239; text-align: center; padding: 8rpx 8rpx 0; }
.coupon-min { font-size: 20rpx; color: #9ca3af; text-align: center; padding: 2rpx 8rpx 10rpx; }
.coupon-btn { margin: 0 16rpx 16rpx; background: #f43f5e; color: #fff; font-size: 24rpx; border-radius: 40rpx; padding: 6rpx 0; }
.coupon-btn.claimed { background: #e5e7eb; color: #9ca3af; }

/* 尺码表 */
.size-sec { background: #fff; margin-top: 8rpx; padding: 20rpx 24rpx; }
.size-img { width: 100%; border-radius: 12rpx; border: 1rpx solid #f0ece8; }

/* 通用区块 */
.block-sec { background: #fff; margin-top: 8rpx; padding: 20rpx 24rpx; }

/* 商品标签 */
.tag-row { background: #fff; margin-top: 8rpx; padding: 12rpx 24rpx; display: flex; flex-wrap: wrap; gap: 12rpx; }
.tag { font-size: 21rpx; color: #e4393c; background: #fff0f0; border: 1rpx solid #ffd6d6; padding: 4rpx 14rpx; border-radius: 20rpx; }

/* 选择：尺码 / 颜色 */
.sel-block { display: flex; align-items: flex-start; padding: 12rpx 0; }
.sel-label { width: 80rpx; font-size: 25rpx; color: #888; padding-top: 10rpx; flex-shrink: 0; }
.chips { flex: 1; display: flex; flex-wrap: wrap; gap: 14rpx; }
.chip { font-size: 24rpx; color: #333; background: #f5f2ef; border: 1rpx solid #f0ece8; padding: 10rpx 24rpx; border-radius: 10rpx; }
.chip-on { color: #e4393c; background: #fff0f0; border-color: #e4393c; font-weight: 600; }

/* 规格表 */
.spec-table { width: 100%; }
.spec-row { display: flex; border-bottom: 1rpx solid #f9f7f4; }
.spec-label { width: 160rpx; padding: 16rpx 20rpx; font-size: 25rpx; color: #888; background: #faf8f5; }
.spec-value { flex: 1; padding: 16rpx 20rpx; font-size: 25rpx; color: #333; }

/* 详情图 */
.detail-img { width: 100%; display: block; }

/* 拿货指南/技巧 */
.guide-item { padding: 16rpx 0; border-bottom: 1rpx solid #f5f2ef; }
.guide-item:last-child { border-bottom: none; }
.guide-t { display: block; font-size: 26rpx; font-weight: 700; color: #333; }
.guide-d { display: block; font-size: 24rpx; color: #666; line-height: 1.6; margin-top: 6rpx; }

/* 评价 */
.review { padding: 20rpx 0; border-bottom: 1rpx solid #f5f2ef; }
.rv-header { display: flex; justify-content: space-between; margin-bottom: 8rpx; }
.rv-name { font-size: 26rpx; font-weight: 600; color: #333; }
.rv-date { font-size: 22rpx; color: #bbb; }
.rv-content { font-size: 25rpx; color: #555; line-height: 1.5; }

/* 数量 */
.qty-sec { background: #fff; padding: 20rpx 24rpx; margin-top: 8rpx; display: flex; align-items: center; justify-content: space-between; }
.ql { font-size: 27rpx; color: #333; font-weight: 500; }
.qb { display: flex; align-items: center; gap: 0; }
.qbtn { width: 60rpx; height: 60rpx; background: #f5f2ef; display: flex; align-items: center; justify-content: center; font-size: 32rpx; font-weight: bold; color: #333; }
.qnum { width: 80rpx; text-align: center; font-size: 28rpx; font-weight: 600; }

/* 推荐 */
.rec-sec { background: #fff; padding: 20rpx 24rpx; margin-top: 8rpx; }
.rec-title { font-size: 29rpx; font-weight: bold; color: #1a1a2e; display: block; margin-bottom: 16rpx; }
.rec-scroll { white-space: nowrap; }
.rec-item { display: inline-block; width: 240rpx; margin-right: 16rpx; vertical-align: top; }
.rec-img { width: 240rpx; height: 240rpx; border-radius: 12rpx; background: #eee; }
.rec-name { font-size: 23rpx; color: #333; display: block; margin-top: 8rpx; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.rec-price { font-size: 26rpx; color: #e91e63; font-weight: 700; display: block; margin-top: 4rpx; }

/* 底部操作栏 */
.bar { position: fixed; bottom: 0; left: 0; width: 100%; background: #fff; display: flex; align-items: center; padding: 12rpx 16rpx; box-shadow: 0 -2rpx 12rpx rgba(0,0,0,.06); z-index: 50; padding-bottom: env(safe-area-inset-bottom); }
.bar-left { display: flex; gap: 20rpx; margin-right: 16rpx; }
.bar-icon { display: flex; flex-direction: column; align-items: center; position: relative; }
.ic { font-size: 34rpx; }
.badge { position: absolute; top: -6rpx; right: -6rpx; background: #e91e63; color: #fff; font-size: 18rpx; min-width: 30rpx; height: 30rpx; border-radius: 15rpx; display: flex; align-items: center; justify-content: center; padding: 0 6rpx; }
.lab { font-size: 20rpx; color: #888; margin-top: 2rpx; }
.bar-right { display: flex; flex: 1; gap: 10rpx; }
.btn-cart { flex: 1; background: #ff9800; color: #fff; text-align: center; padding: 22rpx 0; border-radius: 14rpx; font-size: 27rpx; font-weight: 700; }
.btn-buy { flex: 1; background: linear-gradient(135deg, #e91e63, #c2185b); color: #fff; text-align: center; padding: 22rpx 0; border-radius: 14rpx; font-size: 27rpx; font-weight: 700; }
.btn-tryon { flex: 1; background: #7b61ff; color: #fff; text-align: center; padding: 22rpx 0; border-radius: 14rpx; font-size: 27rpx; font-weight: 700; }
.btn-tryon:active { opacity: .85; }

/* 试穿结果弹层 */
.tryon-mask { position: fixed; left: 0; top: 0; right: 0; bottom: 0; background: rgba(0,0,0,.78); display: flex; align-items: center; justify-content: center; z-index: 200; }
.tryon-panel { width: 86%; background: #fff; border-radius: 16rpx; padding: 24rpx; box-sizing: border-box; }
.tryon-img { width: 100%; border-radius: 12rpx; }
.tryon-tip { font-size: 22rpx; color: #999; margin-top: 12rpx; text-align: center; line-height: 1.5; }
.tryon-close { margin-top: 18rpx; text-align: center; color: #7b61ff; font-size: 30rpx; font-weight: 600; }

/* ==================== 同行风信息行（会员/优惠/发货/选择/参数/服务） ==================== */

/* 价格卡（标题上方） */
.price-card { background: #fff; padding: 24rpx 24rpx 0; }
.price-card-main { background: linear-gradient(135deg, #fff5f7, #fff0f0); border-radius: 20rpx; padding: 28rpx; display: flex; align-items: center; }
.price-item { flex: 1; display: flex; flex-direction: column; }
.price-amt { font-size: 44rpx; font-weight: 800; color: #e91e63; line-height: 1; }
.price-amt.bulk { color: #e91e63; }
.price-label { font-size: 22rpx; color: #999; margin-top: 10rpx; }
.price-tag { font-size: 20rpx; color: #e91e63; background: #fff; border: 1rpx solid #ffd6e3; padding: 2rpx 10rpx; border-radius: 8rpx; margin-left: 8rpx; }
.price-label-row { display: flex; align-items: center; margin-top: 10rpx; }
.price-divider { width: 1rpx; height: 64rpx; background: #ffd6e3; margin: 0 24rpx; }
.price-sales { display: flex; flex-direction: column; align-items: center; padding-left: 24rpx; border-left: 1rpx solid #ffd6e3; min-width: 110rpx; }
.sales-num { font-size: 36rpx; font-weight: 700; color: #333; line-height: 1; }
.sales-label { font-size: 22rpx; color: #999; margin-top: 8rpx; }

.name-sec { background: #fff; padding: 24rpx; }
.name-sec .name { font-size: 34rpx; font-weight: 700; color: #1a1a2e; line-height: 1.45; display: block; }
.name-sec .desc { font-size: 25rpx; color: #888; margin-top: 10rpx; line-height: 1.5; display: block; }

.info-row { background: #fff; display: flex; align-items: center; padding: 24rpx; border-bottom: 1rpx solid #f5f2ef; }
.info-row:last-child { border-bottom: none; }
.info-label { width: 100rpx; font-size: 28rpx; color: #999; flex-shrink: 0; }
.info-content { flex: 1; display: flex; align-items: center; gap: 12rpx; overflow: hidden; }
.info-text { font-size: 28rpx; color: #333; }
.spec-ellipsis { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.ship-row { align-items: flex-start; }
.ship-content { flex-direction: column; align-items: flex-start; gap: 0; padding: 4rpx 0; }
.ship-text { font-size: 24rpx; color: #888; line-height: 1.55; white-space: normal; word-break: break-all; }
.info-arrow { font-size: 28rpx; color: #ccc; margin-left: 8rpx; }

/* 会员行 */
.vip-badge { display: inline-flex; align-items: center; background: #1a1a2e; color: #fff0c2; border-radius: 30rpx; padding: 4rpx 16rpx 4rpx 8rpx; font-size: 24rpx; font-weight: 600; }
.vip-icon { width: 30rpx; height: 30rpx; border-radius: 50%; background: #fff0c2; color: #1a1a2e; font-size: 20rpx; font-weight: 800; display: flex; align-items: center; justify-content: center; margin-right: 8rpx; }
.vip-text { font-size: 26rpx; color: #666; }

/* 优惠行 */
.coupon-tag { display: inline-block; font-size: 22rpx; color: #e91e63; background: #fff0f4; border: 1rpx solid #ffd6e3; padding: 4rpx 12rpx; border-radius: 8rpx; }
.coupon-text { font-size: 26rpx; color: #333; }
.coupon-empty { font-size: 26rpx; color: #999; }

/* ==================== 店铺卡片 ==================== */
.shop-card { background: #fff; margin: 16rpx; padding: 24rpx; border-radius: 20rpx; display: flex; align-items: center; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03); }
.shop-card-left { flex: 1; display: flex; align-items: center; min-width: 0; }
.shop-logo { width: 80rpx; height: 80rpx; border-radius: 50%; background: #fff0f0; display: flex; align-items: center; justify-content: center; font-size: 40rpx; margin-right: 18rpx; flex-shrink: 0; }
.shop-info { flex: 1; min-width: 0; }
.shop-name { font-size: 28rpx; font-weight: 700; color: #1a1a2e; display: block; }
.shop-tags { font-size: 22rpx; color: #999; margin-top: 8rpx; display: block; }
.shop-right { display: flex; flex-direction: column; align-items: flex-end; gap: 10rpx; flex-shrink: 0; margin-left: 16rpx; }
.shop-brand { font-size: 20rpx; color: #8d6e63; background: #f5f0eb; padding: 4rpx 12rpx; border-radius: 8rpx; }
.shop-btn { font-size: 24rpx; color: #fff; background: #1a1a2e; padding: 10rpx 24rpx; border-radius: 30rpx; }

/* ==================== 店铺大卡片 / 系列推荐 / 相似推荐 ==================== */
.shop-hero-card { margin: 16rpx; border-radius: 24rpx; overflow: hidden; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08); position: relative; }
.shop-hero-img { width: 100%; height: 320rpx; display: block; }
.shop-hero-ph { width: 100%; height: 320rpx; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #1a1a2e, #3d2b3d); color: rgba(255,255,255,0.9); font-size: 30rpx; }
.shop-hero-mask { position: absolute; left: 0; right: 0; bottom: 0; top: 0; background: linear-gradient(to bottom, rgba(0,0,0,0) 40%, rgba(0,0,0,0.6)); pointer-events: none; }
.shop-hero-foot { position: absolute; left: 0; right: 0; bottom: 0; z-index: 1; display: flex; align-items: center; justify-content: space-between; padding: 22rpx 24rpx; box-sizing: border-box; }
.shop-hero-foot-title { font-size: 34rpx; font-weight: 800; color: #fff; text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.4); }
.shop-hero-btn { font-size: 24rpx; color: #1a1a2e; background: #fff; padding: 10rpx 26rpx; border-radius: 30rpx; font-weight: 600; }

.shop-two-col { display: flex; gap: 16rpx; margin: 16rpx; }
.shop-col { flex: 1; min-width: 0; background: #fff; border-radius: 20rpx; padding: 20rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03); }
.shop-col-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16rpx; }
.shop-col-title { font-size: 28rpx; font-weight: 700; color: #1a1a2e; }
.shop-col-more { font-size: 22rpx; color: #999; }
.shop-col-list { display: flex; flex-direction: column; gap: 16rpx; }
.shop-col-item { display: flex; flex-direction: column; }
.shop-col-img { width: 100%; height: 220rpx; border-radius: 14rpx; background: #f5f5f5; }
.shop-col-name { font-size: 24rpx; color: #333; margin-top: 10rpx; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.shop-col-price { font-size: 26rpx; color: #e91e63; font-weight: 700; margin-top: 6rpx; }

/* 系列切换 + 小卡轮播 */
.series-tabs { display: flex; justify-content: center; gap: 60rpx; padding: 28rpx 0 16rpx; background: #fff; }
.series-tab { font-size: 30rpx; color: #999; position: relative; padding: 8rpx 0; }
.series-tab.active { color: #1a1a2e; font-weight: 700; }
.series-tab.active::after { content: ''; position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); width: 40rpx; height: 5rpx; background: #e91e63; border-radius: 4rpx; }

.series-carousel { background: #fff; padding: 0 24rpx 32rpx; }
.series-scroll { white-space: nowrap; }
.series-card { display: inline-block; width: 220rpx; margin-right: 16rpx; vertical-align: top; }
.series-card:last-child { margin-right: 0; }
.series-img { width: 220rpx; height: 280rpx; border-radius: 16rpx; background: #f5f5f5; }
.series-name { font-size: 24rpx; color: #333; margin-top: 12rpx; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; display: block; }
.series-price { font-size: 28rpx; color: #e91e63; font-weight: 700; margin-top: 8rpx; display: block; }

.similar-sec { background: #fff; margin-top: 16rpx; padding: 24rpx 16rpx; }
.similar-header { display: flex; align-items: center; justify-content: center; gap: 20rpx; margin-bottom: 24rpx; }
.similar-line { flex: 1; height: 1rpx; background: #e5e5e5; max-width: 120rpx; }
.similar-title { font-size: 28rpx; color: #999; }
.similar-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.similar-item { width: calc(50% - 8rpx); box-sizing: border-box; }
.similar-img { width: 100%; height: 340rpx; border-radius: 16rpx; background: #f5f5f5; }
.similar-name { font-size: 25rpx; color: #333; margin-top: 12rpx; display: block; line-height: 1.4; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
.similar-price { font-size: 28rpx; color: #e91e63; font-weight: 700; margin-top: 8rpx; display: block; }

/* ==================== 图片详情头部 ==================== */
.detail-header { display: flex; align-items: center; justify-content: center; gap: 20rpx; padding: 36rpx 0 24rpx; background: #fff; }
.detail-line { flex: 1; height: 1rpx; background: #e5e5e5; max-width: 120rpx; }
.detail-title { font-size: 28rpx; color: #999; }

/* ==================== 通用弹窗遮罩 ==================== */
.panel-mask { position: fixed; left: 0; top: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.55); z-index: 200; display: flex; flex-direction: column; justify-content: flex-end; }
.panel-head { height: 96rpx; display: flex; align-items: center; justify-content: center; position: relative; border-bottom: 1rpx solid #f5f2ef; }
.panel-title { font-size: 32rpx; font-weight: 600; color: #1a1a2e; }
.panel-close { position: absolute; right: 24rpx; top: 50%; transform: translateY(-50%); width: 52rpx; height: 52rpx; border-radius: 50%; background: #f5f5f5; color: #999; font-size: 26rpx; display: flex; align-items: center; justify-content: center; }
.panel-body { padding: 24rpx; max-height: 70vh; overflow-y: auto; }

/* ==================== 优惠明细弹窗 ==================== */
.coupon-panel { background: #fff; border-radius: 32rpx 32rpx 0 0; }
.coupon-sub { font-size: 24rpx; color: #999; margin-bottom: 24rpx; display: block; }
.coupon-detail { display: flex; align-items: center; background: #fff5f7; border-radius: 20rpx; padding: 20rpx; margin-bottom: 20rpx; border: 1rpx solid #ffe0e8; }
.coupon-detail-left { width: 180rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; border-right: 1rpx dashed #ffd6e3; padding-right: 20rpx; }
.coupon-detail-tag { font-size: 20rpx; color: #e91e63; background: #fff; border: 1rpx solid #ffd6e3; padding: 2rpx 10rpx; border-radius: 8rpx; margin-bottom: 8rpx; }
.coupon-detail-amt { font-size: 28rpx; color: #e91e63; font-weight: 700; }
.coupon-detail-amt text { font-size: 48rpx; }
.coupon-detail-min { font-size: 20rpx; color: #e91e63; margin-top: 6rpx; }
.coupon-detail-mid { flex: 1; padding-left: 24rpx; }
.coupon-detail-type { font-size: 20rpx; color: #e91e63; border: 1rpx solid #ffd6e3; padding: 2rpx 8rpx; border-radius: 6rpx; margin-right: 8rpx; }
.coupon-detail-desc { font-size: 28rpx; color: #333; font-weight: 600; }
.coupon-detail-valid { font-size: 22rpx; color: #999; margin-top: 8rpx; display: block; }
.coupon-detail-btn { width: 120rpx; background: #e91e63; color: #fff; font-size: 24rpx; border: none; border-radius: 30rpx; padding: 10rpx 0; margin: 0; text-align: center; }
.coupon-detail-btn.claimed { background: #e5e7eb; color: #9ca3af; }
.coupon-empty-detail { font-size: 28rpx; color: #999; text-align: center; padding: 60rpx 0; }

/* ==================== 下单详情 / SKU 弹窗 ==================== */
.sku-panel { background: #fff; border-radius: 32rpx 32rpx 0 0; display: flex; flex-direction: column; max-height: 82vh; }
.sku-head { display: flex; align-items: center; margin-bottom: 24rpx; }
.sku-img { width: 160rpx; height: 160rpx; border-radius: 16rpx; background: #f5f5f5; margin-right: 24rpx; flex-shrink: 0; }
.sku-price-col { flex: 1; }
.sku-price-row { display: flex; align-items: baseline; gap: 24rpx; margin-bottom: 8rpx; }
.sku-price { font-size: 40rpx; font-weight: 800; color: #e91e63; }
.sku-price-bulk { font-size: 32rpx; color: #999; text-decoration: line-through; }
.sku-price-label-row { display: flex; gap: 24rpx; }
.sku-price-label { font-size: 22rpx; color: #e91e63; background: #fff0f4; padding: 4rpx 12rpx; border-radius: 8rpx; }
.sku-price-bulk-label { font-size: 22rpx; color: #999; background: #f5f5f5; padding: 4rpx 12rpx; border-radius: 8rpx; }

.sku-row { padding: 24rpx 0; border-bottom: 1rpx solid #f5f2ef; }
.sku-row:last-child { border-bottom: none; }
.sku-row-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16rpx; }
.sku-row-label { font-size: 28rpx; color: #999; width: 120rpx; display: inline-block; flex-shrink: 0; }
.sku-row-val { font-size: 28rpx; color: #333; }
.sku-row-ellipsis { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; display: block; }

/* 详细参数网格（下单详情弹窗） */
.sku-params { padding: 24rpx 0; border-bottom: 1rpx solid #f5f2ef; }
.sku-params-grid { display: flex; flex-wrap: wrap; margin-top: 16rpx; background: #faf8f6; border-radius: 12rpx; padding: 8rpx 0; }
.sku-param-item { width: 50%; display: flex; align-items: baseline; padding: 10rpx 20rpx; box-sizing: border-box; }
.sku-param-label { font-size: 24rpx; color: #999; flex-shrink: 0; margin-right: 10rpx; }
.sku-param-value { font-size: 26rpx; color: #333; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

.sku-chips { display: flex; flex-wrap: wrap; gap: 16rpx; }
.sku-chip { font-size: 26rpx; color: #333; background: #f5f5f5; padding: 12rpx 28rpx; border-radius: 30rpx; border: 1rpx solid transparent; }
.sku-chip-on { color: #e91e63; background: #fff0f4; border-color: #e91e63; }

.sku-size-link { font-size: 24rpx; color: #e91e63; }
.sku-size-list { display: flex; flex-direction: column; gap: 20rpx; }
.sku-size-item { display: flex; align-items: center; justify-content: space-between; }
.sku-size-name { font-size: 28rpx; color: #333; }
.sku-qb { display: flex; align-items: center; border: 1rpx solid #e5e5e5; border-radius: 8rpx; }
.sku-qbtn { width: 56rpx; height: 56rpx; display: flex; align-items: center; justify-content: center; font-size: 28rpx; color: #333; }
.sku-qnum { width: 72rpx; text-align: center; font-size: 28rpx; color: #333; border-left: 1rpx solid #e5e5e5; border-right: 1rpx solid #e5e5e5; }

.sku-bar { padding: 24rpx; border-top: 1rpx solid #f5f2ef; }
.sku-confirm { background: #f5c2d4; color: #fff; font-size: 30rpx; font-weight: 700; text-align: center; padding: 24rpx 0; border-radius: 40rpx; }
.sku-confirm-active { background: #e91e63; }

/* ==================== 尺码图弹窗 ==================== */
.sizechart-panel { background: #fff; border-radius: 32rpx 32rpx 0 0; max-height: 80vh; display: flex; flex-direction: column; }
.sizechart-body { flex: 1; padding: 24rpx; }
.sizechart-img { width: 100%; display: block; }
