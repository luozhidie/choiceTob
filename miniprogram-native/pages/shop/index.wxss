page { background: #faf8f6; }

.swiper { width: 100%; height: 750rpx; }
.slide-img { width: 100%; height: 100%; }
.ph { width: 100%; height: 100%; background: #f0ede9; display: flex; align-items: center; justify-content: center; color: #ccc; font-size: 28rpx; }

/* 商品信息 */
.info { padding: 32rpx; }
.name { font-size: 34rpx; font-weight: 700; color: #1a1a2e; line-height: 1.4; }
.price-row { display: flex; align-items: baseline; gap: 16rpx; margin-top: 20rpx; }
.price { font-size: 42rpx; font-weight: 900; color: #e91e63; }
.ori { font-size: 26rpx; color: #ccc; text-decoration: line-through; }
.desc { font-size: 26rpx; color: #888; margin-top: 20rpx; line-height: 1.6; }

/* 库存 */
.stock { padding: 0 32rpx 24rpx; font-size: 24rpx; color: #aaa; }

/* 数量 */
.qty { display: flex; align-items: center; justify-content: space-between; padding: 24rpx 32rpx; border-top: 1rpx solid #f0ede9; }
.ql { font-size: 28rpx; color: #333; font-weight: 500; }
.qb { display: flex; align-items: center; gap: 1rpx; background: #f5f3f1; border-radius: 12rpx; overflow: hidden; }
.qb .btn { width: 72rpx; height: 72rpx; display: flex; align-items: center; justify-content: center; font-size: 36rpx; color: #555; font-weight: 700; }
.qb .num { width: 88rpx; text-align: center; font-size: 30rpx; font-weight: 600; color: #333; background: #fff; height: 72rpx; line-height: 72rpx; }

/* 底部操作栏 */
.bar { position: fixed; bottom: 0; left: 0; right: 0; height: 110rpx; background: #fff; display: flex; align-items: center; padding: 0 24rpx; box-shadow: 0 -4rpx 24rpx rgba(0,0,0,0.06); z-index: 50; }
.bar-left { display: flex; align-items: center; }
.bar-icon { display: flex; flex-direction: column; align-items: center; position: relative; margin-right: 32rpx; }
.ic { font-size: 40rpx; }
.lab { font-size: 20rpx; color: #888; margin-top: 2rpx; }
.badge { position: absolute; top: -8rpx; right: -12rpx; background: #e91e63; color: #fff; font-size: 18rpx; min-width: 32rpx; height: 32rpx; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; padding: 0 6rpx; }
.bar-right { flex: 1; display: flex; gap: 16rpx; }
.btn-cart { flex: 1; height: 80rpx; display: flex; align-items: center; justify-content: center; background: #fff; border: 2rpx solid #e91e63; color: #e91e63; font-size: 28rpx; font-weight: 700; border-radius: 40rpx; }
.btn-buy { flex: 1; height: 80rpx; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #e91e63, #ff5722); color: #fff; font-size: 28rpx; font-weight: 700; border-radius: 40rpx; }
