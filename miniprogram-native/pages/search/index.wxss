page { background: #faf8f6; }

/* 搜索框 */
.search-bar { display: flex; align-items: center; padding: 16rpx 24rpx; background: #fff; position: sticky; top: 0; z-index: 50; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.sb-inner { flex: 1; display: flex; align-items: center; background: #f5f3f1; border-radius: 28rpx; padding: 12rpx 20rpx; gap: 12rpx; }
.sb-icon { font-size: 28rpx; }
.sb-input { flex: 1; background: transparent; font-size: 26rpx; color: #333; }
.sb-clear { font-size: 28rpx; color: #ccc; padding: 8rpx; }
.sb-cancel { font-size: 26rpx; color: #666; margin-left: 16rpx; }

/* Section */
.section { padding: 24rpx; }
.sec-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.sec-title { font-size: 26rpx; color: #999; font-weight: 500; }
.sec-clear { font-size: 24rpx; color: #e91e63; }

/* Tags */
.tags { display: flex; flex-wrap: wrap; gap: 16rpx; }
.tag { padding: 14rpx 28rpx; background: #fff; border: 1rpx solid #eee; border-radius: 24rpx; font-size: 24rpx; color: #555; }

/* 结果 */
.results { padding: 24rpx; }
.res-count { font-size: 24rpx; color: #999; margin-bottom: 20rpx; }
.res-list { display: flex; flex-direction: column; gap: 20rpx; }
.res-item { display: flex; gap: 20rpx; padding: 20rpx; background: #fff; border-radius: 16rpx; }
.ri-img { width: 160rpx; height: 160rpx; border-radius: 12rpx; background: #f0ede9; flex-shrink: 0; }
.ri-info { flex: 1; display: flex; flex-direction: column; justify-content: center; }
.ri-name { font-size: 26rpx; color: #333; font-weight: 500; line-height: 1.4; }
.ri-price { font-size: 30rpx; color: #e91e63; font-weight: 700; margin-top: 8rpx; }

/* 空状态 */
.res-empty { text-align: center; padding: 80rpx 0; }
.re-icon { font-size: 72rpx; margin-bottom: 16rpx; }
.re-text { font-size: 26rpx; color: #ccc; }

/* Loading */
.loading { text-align: center; padding: 60rpx 0; }
.load-spinner { width: 48rpx; height: 48rpx; border: 4rpx solid #f0ede9; border-top-color: #e91e63; border-radius: 50%; animation: spin 0.8s linear infinite; margin: 0 auto 16rpx; }
@keyframes spin { to { transform: rotate(360deg); } }
.load-text { font-size: 24rpx; color: #999; }
