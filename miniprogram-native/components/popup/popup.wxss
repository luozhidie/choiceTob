.popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.65);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.popup-card {
  position: relative;
  width: 100%;
  max-width: 600rpx;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.4);
  padding: 28rpx 28rpx 36rpx;
  box-sizing: border-box;
}

.popup-close {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 56rpx;
  height: 56rpx;
  background: rgba(0, 0, 0, 0.35);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 5;
}

.popup-close-icon {
  color: #fff;
  font-size: 36rpx;
  line-height: 1;
  font-weight: 300;
}

.popup-top-title {
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  margin: 6rpx 0 16rpx;
}

.popup-hero {
  position: relative;
  width: 100%;
  aspect-ratio: 3 / 4;
  border-radius: 20rpx;
  overflow: hidden;
  background-color: rgba(0, 0, 0, 0.18);
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
}

.popup-hero-placeholder {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255, 255, 255, 0.55);
  font-size: 26rpx;
}

.popup-brand-label {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  background: rgba(0, 0, 0, 0.32);
  backdrop-filter: blur(8rpx);
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
}

.popup-hero-bottom {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  text-align: right;
  text-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.45);
}

.popup-sub1 {
  font-size: 26rpx;
  font-weight: 500;
}

.popup-sub2 {
  font-size: 36rpx;
  font-weight: 700;
  margin-top: 6rpx;
}

.popup-brands {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 24rpx;
  opacity: 0.92;
}

.popup-brand {
  white-space: nowrap;
}

.popup-brand-sep {
  opacity: 0.5;
}

.popup-btn-wrap {
  margin-top: 28rpx;
  display: flex;
  justify-content: center;
}

.popup-btn {
  padding: 18rpx 56rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.18);
  white-space: nowrap;
}
